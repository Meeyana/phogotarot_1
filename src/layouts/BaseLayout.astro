                <a href="/nap-credit" class="nav-link">Bảng giá</a>
            )}
            <a href="/blog" class="nav-link">Blog</a>
            
            {Astro.locals.user ? (
                <>
                    {/* Giao diện Desktop: Dạng Icon + Dropdown */}
                    <div class="nav-item nav-dropdown desktop-only-profile">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <div class="credit-badge" title="Số lượt xem bài còn lại" style="background: rgba(242, 201, 76, 0.1); border: 1px solid var(--gold-color, #F2C94C); padding: 4px 10px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; color: var(--gold-color, #F2C94C); display: flex; align-items: center; gap: 5px; cursor: help;">
                                <i class="fa-regular fa-gem"></i> <span id="desktop-credit-balance">...</span>
