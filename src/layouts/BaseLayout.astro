                                <button type="submit" class="nav-link submenu-link" style="background: none; border: none; width: 100%; text-align: left; cursor: pointer; color: #ff6b6b; padding: 10px 15px;"><i class="fa-solid fa-right-from-bracket" style="width: 20px;"></i> Đăng xuất</button>
                            </form>
