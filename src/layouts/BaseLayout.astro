                    </div>

                    {/* Giao diện Mobile: Hiển thị dạng Dropdown */}
                    <div class="nav-item nav-dropdown mobile-only-profile" style="width: 100%; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1rem; margin-top: 0.5rem; display: flex; flex-direction: column; align-items: center;">
