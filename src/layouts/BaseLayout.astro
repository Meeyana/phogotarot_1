    <div id="history-modal-backdrop" class="modal-backdrop"></div>
    <div id="history-modal-content" class="modal-content">
        <div class="modal-header">
            <button id="history-modal-close-btn" class="modal-close-btn">&times;</button>
            <h2>Lịch sử trải bài</h2>
            <button id="clear-tarot-history-btn" class="clear-history-btn" title="Xóa toàn bộ dữ liệu">
                <i class="fa-solid fa-trash-can"></i> Xóa tất cả
            </button>
        </div>
        <div id="history-list-wrapper" class="modal-scroll-wrapper">
            <div id="history-list"></div>
        </div>
    </div>
    
    {/* {showChatbot && Astro.locals.user && <OracleChat />} */}

    <script src="/common.js" defer></script>
    
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const currentPath = window.location.pathname;
            
            // 1. Định nghĩa hàm tô màu Vàng (Active Style)
            const setActiveStyle = (element) => {
                if (!element) return;
                element.style.color = 'var(--gold-color, #F2C94C)';
                element.style.textShadow = '0 0 10px rgba(242, 201, 76, 0.5)';
                element.classList.add('active');
                
                // Nếu là SVG mũi tên bên trong, cũng cho sáng luôn
                const arrow = element.querySelector('.dropdown-arrow');
                if (arrow) arrow.style.fill = 'var(--gold-color, #F2C94C)';
            };

            // 2. Duyệt tất cả các thẻ <a> trong menu
            const navLinks = document.querySelectorAll('a.nav-link');
            navLinks.forEach(link => {
                const href = link.getAttribute('href');

                // Logic so sánh: 
                // - Trùng khớp hoàn toàn (href === currentPath)
                // - Hoặc là trang con (VD: đang ở /blog/bai-viet-1 thì menu /blog vẫn sáng), trừ trang chủ '/'
                if (href && (href === currentPath || (href !== '/' && currentPath.startsWith(href)))) {
                    
                    // A. Tô vàng chính link con đó
                    setActiveStyle(link);

                    // B. KÍCH HOẠT MENU MẸ (Quan trọng)
                    // Kiểm tra xem link này có nằm trong menu xổ xuống không
                    const parentSubmenu = link.closest('.dropdown-submenu');
                    
                    if (parentSubmenu) {
                        // Tìm thẻ cha bao bọc (nav-item)
                        const parentNavItem = parentSubmenu.closest('.nav-item');
                        if (parentNavItem) {
                            // Tìm cái nút tiêu đề (VD: Bói Tarot Free hoặc User Profile) nằm cùng cấp
                            // Nó là thẻ có class .nav-link nhưng không phải là thẻ a (hoặc có id toggle)
                            const parentToggle = parentNavItem.querySelector('#tarot-dropdown-toggle, #mobile-profile-toggle, .nav-link:not(a)');
                            setActiveStyle(parentToggle);
                        }
                    }
                }
            });

            // 3. Fetch Credit Balance
            const fetchBalance = async (force = false) => {
                const desktopBadge = document.getElementById('desktop-credit-balance');
                const mobileBadge = document.getElementById('mobile-credit-balance');
                
                if (!desktopBadge && !mobileBadge) return; // Khách chưa đăng nhập

                const renderBalance = (data) => {
                    const desktopParent = desktopBadge ? desktopBadge.closest('.credit-badge') : null;
                    const mobileParent = mobileBadge ? mobileBadge.closest('.credit-badge') : null;
                    
                    if (desktopBadge) {
                        if (data.isPremium) {
                            desktopBadge.innerHTML = 'Vô cực';
                            desktopBadge.style.color = '#FFD700';
                            if (desktopParent) {
                                desktopParent.style.border = '1px solid #FFD700';
                                const icon = desktopParent.querySelector('i');
                                if (icon) { icon.className = 'fa-solid fa-crown'; icon.style.color = '#FFD700'; }
                            }
                        } else {
                            desktopBadge.innerHTML = data.balance + ' Lượt';
                            desktopBadge.style.color = '';
                            if (desktopParent) {
                                desktopParent.style.border = '';
                                const icon = desktopParent.querySelector('i');
                                if (icon) { icon.className = 'fa-regular fa-gem'; icon.style.color = ''; }
                            }
                        }
                    }
                    
                    if (mobileBadge) {
                        if (data.isPremium) {
                            mobileBadge.innerHTML = 'Vô cực';
                            mobileBadge.style.color = '#FFD700';
                            if (mobileParent) {
                                mobileParent.style.border = '1px solid #FFD700';
                                const icon = mobileParent.querySelector('i');
                                if (icon) { icon.className = 'fa-solid fa-crown'; icon.style.color = '#FFD700'; }
                            }
                        } else {
                            mobileBadge.innerHTML = data.balance + ' Lượt';
                            mobileBadge.style.color = '';
                            if (mobileParent) {
                                mobileParent.style.border = '';
                                const icon = mobileParent.querySelector('i');
                                if (icon) { icon.className = 'fa-regular fa-gem'; icon.style.color = ''; }
                            }
                        }
                    }
                };

                // Kiểm tra cache nếu không ép buộc tải mới
                if (!force) {
                    const cachedData = sessionStorage.getItem('user_balance_cache');
                    const cachedTime = sessionStorage.getItem('user_balance_cache_time');
                    const cacheTTL = 60000; // Cực kỳ tối ưu: cache trong 1 phút (60 giây)

                    if (cachedData && cachedTime && (Date.now() - parseInt(cachedTime, 10) < cacheTTL)) {
                        try {
                            const parsed = JSON.parse(cachedData);
                            renderBalance(parsed);
                            return;
                        } catch (e) {
                            // Xóa cache bị lỗi
                            sessionStorage.removeItem('user_balance_cache');
                            sessionStorage.removeItem('user_balance_cache_time');
                        }
                    }
                }

                try {
                    const response = await fetch('/api/user/balance');
                    if (response.ok) {
                        const data = await response.json();
                        if (data.success) {
                            // Lưu vào cache
                            sessionStorage.setItem('user_balance_cache', JSON.stringify(data));
                            sessionStorage.setItem('user_balance_cache_time', Date.now().toString());
                            renderBalance(data);
                        }
                    }
                } catch (error) {
                    console.error("Lỗi fetch balance:", error);
                }
            };
            window.fetchBalance = fetchBalance;
            fetchBalance();
        });
        
        // --- HYBRID TRACKING (CAPI + PIXEL DEDUPLICATION) ---
        // Ghi đè hàm dataLayer.push để tự động bắt sự kiện 'feature_usage'
        // từ tất cả các trang web và gửi kèm lên Server CAPI.
        window.dataLayer = window.dataLayer || [];
        const originalPush = window.dataLayer.push;
        window.dataLayer.push = function() {
            // Gọi hàm gốc để GTM vẫn nhận được data bình thường
            originalPush.apply(window.dataLayer, arguments);
            
            const args = Array.prototype.slice.call(arguments);
            for (const item of args) {
                if (item && (item.event === 'feature_usage' || item['event'] === 'feature_usage')) {
                    
                    // 1. Khởi tạo EventID dùng chung để Facebook Hủy trùng lặp (Deduplication)
                    if (!item.eventID) {
                        item.eventID = 'evt_' + Math.random().toString(36).substr(2, 9) + '_' + Date.now();
                    }
                    
                    // 2. Tách event ra, giữ lại các thông số custom
                    const payloadData = { ...item };
                    delete payloadData.event;

                    // 3. Gửi thẳng data lên Server CAPI của chúng ta
                    fetch('/api/event-sync', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            eventName: 'FeatureUsage',
                            eventID: item.eventID,
                            eventURL: window.location.href,
                            eventData: payloadData
                        })
                    }).catch(err => console.warn('CAPI push failed', err));
                }
            }
        };
    </script>
</body>
</html>
