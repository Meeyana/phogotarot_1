            <div class="footer-column contact">
                <h3 class="footer-title">Thông tin liên hệ</h3>
                <ul class="footer-link-list">
                    <li>
                        <i class="fa-solid fa-location-dot"></i>
                        <span>Quận Bình Thạnh, Hồ Chí Minh, VN</span>
                    </li>
                    <li>
                        <i class="fa-solid fa-phone"></i>
