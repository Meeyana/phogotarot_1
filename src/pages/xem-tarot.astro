---
// src/pages/xem-tarot.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import TarotSpreadModal from '../components/TarotSpreadModal.astro';
import ProfileModal from '../components/ProfileModal.astro';
import { breadcrumbListSchema, faqPageSchema, graphSchema, webApplicationSchema, webPageSchema } from '../lib/schema';
import '../styles/xem-tarot.css';

const pageTitle = "Xem Tarot Online Miễn Phí Với Reader AI | Phở Gõ Tarot";
const pageDesc = "Trải bài tarot online với Reader AI, đặt câu hỏi về tình yêu, công việc và định hướng cá nhân. Mỗi ngày nhận 1 lượt xem miễn phí tại Phở Gõ Tarot.";
const pageUrl = new URL('/xem-tarot', Astro.site).href;
const yesNoUrl = new URL('/yes-no-reading', Astro.site).href;

const faqItems = [
  {
    question: "Xem tarot online là gì?",
    answer: "Xem tarot online là cách đặt câu hỏi, chọn bài và nhận luận giải ngay trên website. Tại Phở Gõ Tarot, Reader AI đọc bối cảnh câu hỏi, các lá bài bạn chọn và đưa ra gợi ý để bạn tự soi chiếu quyết định."
  },
  {
    question: "Mỗi ngày được xem miễn phí không?",
    answer: "Có. Người dùng đăng nhập có thể nhận 1 lượt xem bài miễn phí mỗi ngày. Sau khi dùng hết lượt miễn phí, bạn có thể nạp thêm credit nếu muốn tiếp tục trải bài."
  },
  {
    question: "Nên hỏi câu hỏi gì khi xem tarot online?",
    answer: "Bạn nên hỏi câu hỏi mở, có bối cảnh và tập trung vào phần mình có thể chủ động. Ví dụ: 'Tôi nên nhìn nhận mối quan hệ này như thế nào?' thường tốt hơn câu hỏi chỉ muốn đoán suy nghĩ của người khác."
  },
  {
    question: "Tarot online có thay thế reader offline không?",
    answer: "Không. Tarot online phù hợp khi bạn cần riêng tư, nhanh, chi phí thấp và có thể xem lại nội dung. Reader offline phù hợp hơn với những trường hợp cần tương tác sâu, nhiều lớp cảm xúc và đối thoại trực tiếp."
  }
];

const schema = graphSchema([
  webPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc }),
  webApplicationSchema({ url: pageUrl, name: "Xem Tarot Online Với Reader AI - Phở Gõ Tarot", description: pageDesc }),
  breadcrumbListSchema(pageUrl, [
    { name: "Trang chủ", url: "/" },
    { name: "Xem Tarot Online", url: "/xem-tarot" }
  ]),
  faqPageSchema(pageUrl, faqItems)
]);

// Lấy thông tin profile
const db = Astro.locals.runtime?.env?.DB;
let profile = {
  full_name: Astro.locals.user?.name || '',
  nickname: '',
  date_of_birth: '',
  gender: '',
  location: '',
  occupation: '',
  relationship_status: '',
  recent_events: ''
};

if (db && Astro.locals.user) {
  try {
    const data = await db.prepare('SELECT * FROM user_profiles WHERE user_id = ?').bind(Astro.locals.user.id).first();
    if (data) {
      profile = {
        ...profile,
        ...data
      };
    }
  } catch (error) {
    console.error("Lỗi lấy thông tin profile:", error);
  }
}
// Đọc gợi ý câu hỏi từ KV, nếu chưa có thì dùng mặc định
let suggestedQuestionsKV = JSON.stringify([
  { "category": "Tình Cảm", "question": "Tình cảm của tôi 3 tháng tới sẽ thế nào?" },
  { "category": "Công Việc", "question": "Công việc của tôi 3 tháng tới sẽ ra sao?" },
  { "category": "Tài Chính", "question": "Sắp tới tôi có nên đầu tư không?" },
  { "category": "Chung", "question": "Điều gì đang ảnh hưởng mạnh đến cuộc sống của tôi lúc này?" },
  { "category": "Tình Cảm", "question": "Điều gì đang ảnh hưởng đến tình cảm của tôi ở hiện tại?" },
  { "category": "Công Việc", "question": "Tôi nên làm gì để phát triển sự nghiệp của mình?" },
  { "category": "Tình Cảm", "question": "Khi nào tôi sẽ có mối quan hệ mới?" },
  { "category": "Công Việc", "question": "Tôi đang gặp khó khăn gì trong công việc mà chưa nhận ra?" },
  { "category": "Tài Chính", "question": "Cơ hội nào sắp tới có thể giúp tôi cải thiện tài chính?" },
  { "category": "Chung", "question": "Tôi cần tập trung vào khía cạnh nào của bản thân ngay bây giờ?" },
  { "category": "Chung", "question": "Thông điệp quan trọng nhất mà vũ trụ muốn gửi đến tôi là gì?" },
  { "category": "Tài Chính", "question": "Tôi nên chi tiêu hay tiết kiệm trong giai đoạn này?" }
]);
if (Astro.locals.runtime?.env?.SESSION) {
    try {
        const raw = await Astro.locals.runtime.env.SESSION.get('SUGGESTED_QUESTIONS');
        if (raw) suggestedQuestionsKV = raw;
    } catch(e) {
        console.error("Lỗi đọc SUGGESTED_QUESTIONS từ KV:", e);
    }
}
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  showChatbot={false}
>
    <!-- GIAO DIỆN CHAT CHÍNH -->
    <div class="chat-page-container">
        <!-- Header -->
        <div class="chat-header">
            <div class="header-info">
                <div class="header-avatar">
                    <img src="https://ui-avatars.com/api/?name=Pho+Go&background=F2C94C&color=0b132b&size=128" alt="Phở Gõ Tarot Avatar" />
                </div>
                <div class="header-text">
                    <div class="oracle-name">Phở Gõ Tarot</div>
                    <span class="oracle-status">Người truyền tin từ Vũ Trụ</span>
                </div>
            </div>
            <div class="header-actions-group" style="display: flex; gap: 10px;">
                <button id="share-chat-btn" class="new-chat-btn" title="Chia sẻ trải bài">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                </button>
                <button id="clear-chat-history-btn" class="new-chat-btn" title="Bắt đầu cuộc trò chuyện mới">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><line x1="9" y1="10" x2="15" y2="10"></line><line x1="12" y1="7" x2="12" y2="13"></line></svg>
                </button>
            </div>
        </div>

        <!-- Khung Chat -->
        <div id="chat-messages" class="chat-messages">
            <!-- Tin nhắn sẽ được JS tải vào đây -->
        </div>

        <div id="initial-greeting" class="initial-greeting">
            <h1 class="title-glow">Vấn đề bạn đang trăn trở là gì?</h1>
            <p class="subtitle-muted">Hãy tập trung năng lượng và đặt một câu hỏi cụ thể. Mỗi ngày bạn được tặng 1 lượt xem bài miễn phí.</p>
            {!Astro.locals.user && (
                <a href="/login?redirect=/xem-tarot" class="login-badge" style="margin-top: 15px; display: inline-block; padding: 6px 16px; background: rgba(242, 201, 76, 0.1); border: 1px solid rgba(242, 201, 76, 0.3); border-radius: 20px; color: #F2C94C; font-size: 0.95rem; text-decoration: none; transition: all 0.2s ease;">
                    <i class="fa-solid fa-lock" style="margin-right: 5px;"></i> Bạn cần đăng nhập để sử dụng miễn phí mỗi ngày
                </a>
            )}
        </div>

        <!-- Input Area -->
        <div class="chat-input-area">
            <textarea id="question-input" placeholder="Nhập câu hỏi của bạn..." rows="1"></textarea>
            <button id="submit-question-btn" title="Gửi câu hỏi">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M3.4 22a.8.8 0 0 1-.5-.1.75.75 0 0 1-.4-.8l2-9.5 12-1.6-12-1.6-2-9.5a.75.75 0 0 1 .9-.9l20 10a.75.75 0 0 1 0 1.3L3.9 21.9a.8.8 0 0 1-.5-.1Z"/></svg>
            </button>
        </div>
        
        <div class="dropdown-container initial-only-dropdown">
            <button id="suggested-questions-toggle" class="dropdown-toggle">
                <span><i class="fa-regular fa-lightbulb"></i> Gợi ý câu hỏi</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" class="arrow-icon">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
            </button>
            <div id="suggested-questions-list" class="dropdown-menu">
                <p style="padding: 1rem; opacity: 0.7; text-align: center;">Đang tải gợi ý...</p>
            </div>
        </div>

        <!-- Chọn Reader: căn giữa nằm ở dưới gợi ý câu hỏi -->
        <div class="narrative-pill-container" id="reader-selection-container">
            <div class="reader-dropdown centered-reader-dropdown">
                <button type="button" id="reader-dropdown-toggle" class="narrative-pill-btn">
                    <img id="selected-reader-avatar" src="/images/friend-bot.jpg" alt="Avatar" class="pill-avatar" />
                    <span class="pill-label">Reader:</span>
                    <span id="selected-reader-name" class="pill-name">Đang tải...</span>
                    <svg class="pill-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                    </svg>
                </button>
                <span id="selected-reader-desc" style="display: none;">Vui lòng chờ...</span>
                <div id="reader-options-list" class="reader-dropdown-menu">
                    <div style="padding: 1rem; text-align: center; color: rgba(255,255,255,0.7);">Đang tải danh sách...</div>
                </div>
            </div>
        </div>

        <!-- Dòng chữ cập nhật hồ sơ hyperlink nằm ngay dưới nút narrative -->
        {Astro.locals.user && (
            <div class="profile-helper-text">
                (<a href="#" id="open-profile-modal-btn">Cập nhật hồ sơ</a> để nhận thông điệp chính xác nhất)
            </div>
        )}

        <!-- --- PHẦN MỚI: BÀI VIẾT SEO / GEO --- -->
        <div class="seo-divider"></div>
        
        <article class="seo-guide-container">
            <h2 class="seo-title">Xem tarot online phù hợp khi nào?</h2>
            <p class="seo-intro">
                Xem tarot online phù hợp khi bạn cần một không gian riêng tư để nhìn lại chuyện tình cảm, công việc hoặc định hướng cá nhân. Thay vì chỉ tìm một câu trả lời cố định, Phở Gõ Tarot giúp bạn đặt câu hỏi, chọn bài và nhận luận giải theo bối cảnh qua Reader AI.
            </p>

            <div class="seo-tips-grid">
                <div class="seo-tip-card">
                    <h3 class="tip-title">Khi bạn cần tự soi chiếu nhanh</h3>
                    <p class="tip-content">Một lượt trải bài ngắn có thể giúp bạn gọi tên điều đang băn khoăn, nhìn rõ cảm xúc hiện tại và chọn bước tiếp theo tỉnh táo hơn.</p>
                </div>
                <div class="seo-tip-card">
                    <h3 class="tip-title">Khi vấn đề cần bối cảnh</h3>
                    <p class="tip-content">Với câu hỏi mở về tình yêu, công việc hoặc lựa chọn cá nhân, hãy chia sẻ thêm hoàn cảnh để Reader AI luận giải sát hơn.</p>
                </div>
                <div class="seo-tip-card">
                    <h3 class="tip-title">Khi bạn muốn xem lại lời khuyên</h3>
                    <p class="tip-content">Trải bài online giúp bạn lưu lại nội dung, đọc lại sau khi cảm xúc lắng xuống và tự đánh giá điều nào thật sự hữu ích.</p>
                </div>
            </div>

            <div class="seo-examples">
                <h2 class="example-title">Cách đặt câu hỏi để Reader AI luận giải tốt hơn</h2>
                <p>Hãy ưu tiên câu hỏi mở, có bối cảnh và tập trung vào phần bạn có thể chủ động. Thay vì hỏi người khác đang nghĩ gì, hãy hỏi bạn nên hiểu tình huống ra sao hoặc nên chuẩn bị điều gì.</p>
                <ul class="example-list">
                    <li><strong>Tình yêu:</strong> "Tôi nên nhìn nhận mối quan hệ này như thế nào để không lặp lại cảm giác cũ?"</li>
                    <li><strong>Công việc:</strong> "Tôi cần cân nhắc điều gì trước khi đổi hướng công việc trong 3 tháng tới?"</li>
                    <li><strong>Định hướng:</strong> "Điều gì đang cản tôi đưa ra quyết định rõ ràng hơn lúc này?"</li>
                </ul>
            </div>

            <div class="seo-examples">
                <h2 class="example-title">Nên chọn trải bài 1 lá, 3 lá hay 5 lá?</h2>
                <p>Trải bài 1 lá hợp với câu hỏi nhanh hoặc thông điệp trong ngày. Trải bài 3 lá hợp với bối cảnh quá khứ, hiện tại, lời khuyên. Trải bài 5 lá phù hợp khi bạn cần nhìn nhiều lớp hơn về nguyên nhân, trở ngại và hướng hành động.</p>
                <p>Nếu câu hỏi chỉ cần câu trả lời Có hoặc Không, bạn có thể dùng <a href={yesNoUrl} style="color: var(--gold-color); text-decoration: underline; font-weight: 600;">Tarot Yes/No online</a>.</p>
            </div>

            <div class="seo-examples">
                <h2 class="example-title">Xem tarot online khác gì xem offline?</h2>
                <p>Tarot online tiện hơn khi bạn muốn hỏi nhanh, riêng tư và có thể xem lại nội dung. Tarot offline phù hợp hơn nếu bạn cần tương tác trực tiếp với reader, trao đổi cảm xúc sâu hoặc có một phiên đồng hành dài hơn.</p>
            </div>

            <div class="seo-examples" id="faq">
                <h2 class="example-title">Câu hỏi thường gặp</h2>
                {faqItems.map((item) => (
                    <details class="seo-faq-item">
                        <summary>{item.question}</summary>
                        <p>{item.answer}</p>
                    </details>
                ))}
            </div>
        </article>
        <!-- --- HẾT PHẦN BÀI VIẾT SEO --- -->


    </div>

    <TarotSpreadModal />

    <ProfileModal profile={profile} />

    <script 
      type="application/ld+json" 
      slot="head"
      set:html={JSON.stringify(schema)}
    />

    <link rel="preload" href="/card-back.jpg" as="image">

    <!-- Thư viện Showdown để parse markdown -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/showdown/2.1.0/showdown.min.js"></script>

    <script define:vars={{ isLoggedIn: !!Astro.locals.user, serverUserId: Astro.locals.user?.id }}>
        window.IS_LOGGED_IN = isLoggedIn;
        window.SERVER_USER_ID = serverUserId || null;
    </script>

    <div id="suggested-questions-data" style="display:none;" data-questions={suggestedQuestionsKV}></div>

    <script>
        // CONFIG
        const N8N_VALIDATE_URL = '/api/tarot-validate'; // API Validate câu hỏi
        const N8N_WEBHOOK_URL = '/api/tarot-interpret';
        const CHAT_HISTORY_KEY = 'phogo_tarot_chat_page_history';
        const READING_ID_KEY = 'phogo_reading_id';

        let currentReaderId = null;
        let currentReaderAvatar = '/images/friend-bot.jpg';

        let currentReadingId = localStorage.getItem(READING_ID_KEY);
        if (!currentReadingId) {
            currentReadingId = crypto.randomUUID();
            localStorage.setItem(READING_ID_KEY, currentReadingId);
        }
        
        let currentUserId;
        if (window.IS_LOGGED_IN && window.SERVER_USER_ID) {
            currentUserId = window.SERVER_USER_ID;
            localStorage.setItem('phogo_user_id', currentUserId);
        } else {
            currentUserId = localStorage.getItem('phogo_user_id');
            // Nếu chưa đăng nhập mà ID cũ trong storage không phải dạng guest_ (do phiên trước đăng nhập để lại)
            // thì phải xóa đi và cấp guest ID mới để tránh Guest dùng nhầm ID của user thật.
            if (!currentUserId || !currentUserId.startsWith('guest_')) {
                currentUserId = 'guest_' + crypto.randomUUID();
                localStorage.setItem('phogo_user_id', currentUserId);
            }
        }

        // DOM Elements
        const chatMessages = document.getElementById('chat-messages');
        const questionInput = document.getElementById('question-input');
        const submitBtn = document.getElementById('submit-question-btn');
        const clearBtn = document.getElementById('clear-chat-history-btn');
        const shareChatBtn = document.getElementById('share-chat-btn');

        if (shareChatBtn) {
            shareChatBtn.addEventListener('click', async () => {
                let conversationText = '';
                document.querySelectorAll('.message').forEach((msgEl) => {
                    const isUser = msgEl.classList.contains('user-message');
                    // Không lấy nội dung của system message (thông báo hết credit, gợi ý reset)
                    if (msgEl.textContent.includes('💡 Hệ thống:') || msgEl.textContent.includes('Vũ trụ đã gửi khá nhiều thông điệp')) {
                        return;
                    }

                    const text = msgEl.querySelector('.message-text-content')?.textContent?.trim() || '';
                    if (isUser) {
                        conversationText += `👤 Bạn: ${text}\n\n`;
                    } else {
                        let cardsText = '';
                        msgEl.querySelectorAll('.chat-card-item').forEach(cardEl => {
                            const name = cardEl.querySelector('.chat-card-name')?.textContent;
                            const orientation = cardEl.querySelector('.chat-card-orientation')?.textContent;
                            if(name) cardsText += `- ${name} ${orientation}\n`;
                        });
                        if (cardsText) conversationText += `🃏 Trải bài:\n${cardsText}\n`;
                        if (text) conversationText += `🔮 Vũ trụ: ${text}\n\n`;
                    }
                });

                if (!conversationText.trim()) {
                    alert('Chưa có nội dung để chia sẻ!');
                    return;
                }

                const shareText = `🌟 LỊCH SỬ TRẢI BÀI TAROT 🌟\n\n${conversationText}\n✨ Khám phá thông điệp Vũ Trụ dành riêng cho bạn! Nhận ngay 1 lượt bốc bài Tarot hoàn toàn miễn phí mỗi ngày.\n👉 Trải nghiệm ngay tại: https://phogotarot.com`;

                if (navigator.share) {
                    try {
                        await navigator.share({
                            title: 'Trải bài Tarot - Phở Gõ Tarot',
                            text: shareText,
                            url: window.location.href
                        });
                    } catch (err) {
                        console.log('User cancelled share or share failed', err);
                    }
                } else {
                    try {
                        await navigator.clipboard.writeText(shareText);
                        alert('Đã copy toàn bộ nội dung trải bài!');
                    } catch (err) {
                        alert('Không thể copy nội dung');
                    }
                }
            });
        }

        // Reader Selection DOM
        const readerDropdownToggle = document.getElementById('reader-dropdown-toggle');
        const readerOptionsList = document.getElementById('reader-options-list');
        const selectedReaderName = document.getElementById('selected-reader-name');
        const selectedReaderDesc = document.getElementById('selected-reader-desc');
        const selectedReaderAvatar = document.getElementById('selected-reader-avatar');
        
        const tarotModal = document.getElementById('tarot-modal');
        const screens = document.querySelectorAll('.screen');
        const shufflingQuestionDisplay = document.getElementById('shuffling-question-display');
        const drawingQuestionDisplay = document.getElementById('drawing-question-display');
        
        // Tarot Elements
        const spreadContainer = document.getElementById('card-spread-container');
        const chosenCardsDisplay = document.getElementById('chosen-cards-display');

        // State
        let cardData = [];
        let allCardImagesLoaded = false;
        const cardImageCache = new Map();
        let selectedCards = [];
        let isAnimating = false;
        let isThinking = false;
        let userQuestion = '';
        let lastValidationUsage = null;
        let lastValidationModel = null;
        let currentCycleDrawnCardIds = []; // Mảng chứa ID các lá bài đã rút trong phiên (tối đa 21 lá)
        let targetSpreadCount = 3; // Số lá bài cần bốc (1, 3, 5)

        function normalizeImageUrl(url) {
            if (!url) return '';
            try {
                if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
                    const parsed = new URL(url, window.location.origin);
                    if (parsed.hostname === 'phogotarot.com' && parsed.pathname.startsWith('/images/uploads/cards/')) {
                        return parsed.pathname;
                    }
                }
                return new URL(url, window.location.origin).href;
            } catch (e) {
                return url;
            }
        }

        function preloadCardImage(url) {
            const normalizedUrl = normalizeImageUrl(url);
            if (!normalizedUrl) return Promise.resolve();
            if (cardImageCache.has(normalizedUrl)) {
                return cardImageCache.get(normalizedUrl).promise;
            }

            const img = new Image();
            img.decoding = 'async';
            const promise = new Promise((resolve) => {
                img.onload = () => resolve(img);
                img.onerror = () => resolve(img);
            });
            img.src = normalizedUrl;
            cardImageCache.set(normalizedUrl, { img, promise });
            return promise;
        }

        function whenCardImageReady(url) {
            return preloadCardImage(url);
        }

        const sendIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M3.4 22a.8.8 0 0 1-.5-.1.75.75 0 0 1-.4-.8l2-9.5 12-1.6-12-1.6-2-9.5a.75.75 0 0 1 .9-.9l20 10a.75.75 0 0 1 0 1.3L3.9 21.9a.8.8 0 0 1-.5-.1Z"/></svg>`;
        const spinnerIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="animate-spin" style="animation: spin 1s linear infinite;"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>`;

        const styleSheet = document.createElement("style");
        styleSheet.type = "text/css";
        styleSheet.innerText = `@keyframes spin { 100% { transform: rotate(360deg); } }`;
        document.head.appendChild(styleSheet);

        // === CHAT LOGIC ===

        async function syncHistoryIfLoggedin(history) {
            if (!window.IS_LOGGED_IN || history.length === 0) return;
            
            const SYNC_KEY = `is_synced_${currentReadingId}`;
            if (localStorage.getItem(SYNC_KEY)) return;

            try {
                const response = await fetch('/api/tarot-sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ history, readingId: currentReadingId })
                });
                if (response.ok) {
                    localStorage.setItem(SYNC_KEY, 'true');
                }
            } catch (err) {
                console.error('Lỗi sync lịch sử:', err);
            }
        }

        async function loadReaders() {
            try {
                const res = await fetch('/api/readers');
                const data = await res.json();
                if (data.success && data.data.length > 0) {
                    const readers = data.data;
                    
                    if (!currentReaderId) {
                        const savedReader = localStorage.getItem('phogo_selected_reader');
                        const defaultReader = readers.find(r => r.id === savedReader) || readers.find(r => r.id === 'friend') || readers[0];
                        currentReaderId = defaultReader.id;
                        currentReaderAvatar = defaultReader.avatar_url || '/images/friend-bot.jpg';
                        if (selectedReaderName) selectedReaderName.textContent = defaultReader.name;
                        if (selectedReaderDesc) selectedReaderDesc.textContent = defaultReader.description;
                        if (selectedReaderAvatar) selectedReaderAvatar.src = currentReaderAvatar;
                    }

                    if (readerOptionsList) {
                        readerOptionsList.innerHTML = '';
                        readers.forEach(reader => {
                            const opt = document.createElement('div');
                            opt.className = 'reader-option';
                            opt.innerHTML = `
                                <img src="${reader.avatar_url || '/images/default-avatar.png'}" class="reader-option-avatar" />
                                <div class="reader-option-info">
                                    <span class="reader-option-name">${reader.name}</span>
                                    <span class="reader-option-desc">${reader.description}</span>
                                </div>
                            `;
                            opt.addEventListener('click', () => {
                                // --- GTM Tracking ---
                                window.dataLayer = window.dataLayer || [];
                                window.dataLayer.push({
                                    'event': 'feature_usage',
                                    'feature_name': 'tarot_chat',
                                    'action': 'select_reader',
                                    'reader_id': reader.id
                                });
                                // --------------------
                                currentReaderId = reader.id;
                                currentReaderAvatar = reader.avatar_url || '/images/friend-bot.jpg';
                                selectedReaderName.textContent = reader.name;
                                selectedReaderDesc.textContent = reader.description;
                                selectedReaderAvatar.src = currentReaderAvatar;
                                readerOptionsList.classList.remove('show');
                                localStorage.setItem('phogo_selected_reader', reader.id);
                            });
                            readerOptionsList.appendChild(opt);
                        });
                    }
                }
            } catch (e) {
                console.error('Failed to load readers', e);
            }
        }

        if (readerDropdownToggle) {
            readerDropdownToggle.addEventListener('click', () => {
                readerOptionsList.classList.toggle('show');
            });
            document.addEventListener('click', (e) => {
                if (!readerDropdownToggle.contains(e.target) && !readerOptionsList.contains(e.target)) {
                    readerOptionsList.classList.remove('show');
                }
            });
        }

        function initChat() {
            loadReaders();
            const history = JSON.parse(localStorage.getItem(CHAT_HISTORY_KEY) || '[]');
            syncHistoryIfLoggedin(history);
            const container = document.querySelector('.chat-page-container');
            if (history.length === 0) {
                container.classList.add('initial-state');
            } else {
                container.classList.remove('initial-state');
                history.forEach(msg => {
                    addMessage(msg.text, msg.sender, false, msg.cards);
                });

                const pendingConfirm = localStorage.getItem('waitingForTarotConfirm');
                if (pendingConfirm) {
                    userQuestion = pendingConfirm;
                    lastValidationUsage = JSON.parse(localStorage.getItem('pending_validation_usage') || 'null');
                    lastValidationModel = JSON.parse(localStorage.getItem('pending_validation_model') || 'null');
                    targetSpreadCount = parseInt(localStorage.getItem('targetSpreadCount')) || 3;
                    showConfirmationBox(pendingConfirm, targetSpreadCount);
                    return; // Không chạy logic self-healing bên dưới nữa
                }

                // Phục hồi trạng thái đang bốc bài xong nhưng bị rớt mạng / F5 trước khi có kết quả
                const pendingCardsStr = localStorage.getItem('pending_tarot_cards');
                if (pendingCardsStr) {
                    const lastMsg = history[history.length - 1];
                    if (lastMsg && lastMsg.sender === 'user') {
                        userQuestion = lastMsg.text;
                        selectedCards = JSON.parse(pendingCardsStr);
                        // Khôi phục token usage
                        lastValidationUsage = JSON.parse(localStorage.getItem('pending_validation_usage') || 'null');
                        lastValidationModel = JSON.parse(localStorage.getItem('pending_validation_model') || 'null');
                        
                        // Tự động gọi lại luận giải
                        isThinking = true;
                        setTimeout(() => {
                            requestInterpretation();
                        }, 500);
                        return; // Bỏ qua self-healing cơ bản
                    } else {
                        // Rác, dọn dẹp
                        localStorage.removeItem('pending_tarot_cards');
                        localStorage.removeItem('isDrawingTarot');
                        localStorage.removeItem('pending_validation_usage');
                        localStorage.removeItem('pending_validation_model');
                    }
                }

                const isDrawingTarot = localStorage.getItem('isDrawingTarot');
                if (isDrawingTarot) {
                    userQuestion = isDrawingTarot;
                    lastValidationUsage = JSON.parse(localStorage.getItem('pending_validation_usage') || 'null');
                    lastValidationModel = JSON.parse(localStorage.getItem('pending_validation_model') || 'null');
                    targetSpreadCount = parseInt(localStorage.getItem('targetSpreadCount')) || 3;
                    openTarotModal();
                    return; // Bỏ qua self-healing cơ bản
                }

                // Tự phục hồi trạng thái (Self-healing UX):
                // Nếu tin nhắn cuối cùng là của user, nghĩa là tiến trình bị gián đoạn giữa chừng (do F5).
                // Ta sẽ tự động chạy lại câu hỏi này để trả về hộp thoại xác nhận hoặc câu trả lời tương ứng.
                const lastMsg = history[history.length - 1];
                if (lastMsg && lastMsg.sender === 'user') {
                    // KHÔNG xóa tin nhắn khỏi giao diện nữa để user vẫn nhìn thấy câu hỏi của mình
                    userQuestion = lastMsg.text;
                    
                    // Tự động gọi lại tiến trình xử lý
                    setTimeout(() => {
                        handleSend(true); // isResume = true
                    }, 300);
                }
            }
        }

        function saveMessage(text, sender, cards = null, usage = null, model = null) {
            let history = JSON.parse(localStorage.getItem(CHAT_HISTORY_KEY) || '[]');
            history.push({ text, sender, cards, usage, model, timestamp: new Date().toISOString() });
            
            // Giới hạn lịch sử lưu ở Client để không bị tràn RAM/LocalStorage (Issue #5)
            if (history.length > 50) {
                history = history.slice(history.length - 50);
            }
            
            localStorage.setItem(CHAT_HISTORY_KEY, JSON.stringify(history));
        }

        function addMessage(text, sender, save = true, cards = null, usage = null, model = null) {
            if (save) saveMessage(text, sender, cards, usage, model);
            
            // Ẩn bảng chọn Tarot Reader khi cuộc trò chuyện đã bắt đầu
            const readerContainer = document.getElementById('reader-selection-container');
            if (readerContainer) {
                readerContainer.style.display = 'none';
            }

            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${sender}-message`;
            
            if (sender === 'bot') {
                const avatarDiv = document.createElement('div');
                avatarDiv.className = 'bot-avatar';
                avatarDiv.innerHTML = `<img src="${currentReaderAvatar}" alt="Phở Gõ Tarot Avatar" />`;
                msgDiv.appendChild(avatarDiv);
            }

            const contentDiv = document.createElement('div');
            contentDiv.className = 'message-content';
            
            // Xử lý markdown đơn giản
            const renderMarkdown = (rawText) => {
                if (typeof showdown !== 'undefined') {
                    const converter = new showdown.Converter({ simpleLineBreaks: true, emoji: true });
                    return converter.makeHtml(rawText);
                }
                return rawText.replace(/\n/g, '<br>');
            };
            
            // Thêm bài đã chọn vào bong bóng chat (Nằm TRÊN)
            if (cards && cards.length > 0) {
                const cardsContainer = document.createElement('div');
                cardsContainer.className = 'chat-drawn-cards';
                cards.forEach(c => {
                    cardsContainer.innerHTML += `
                        <div class="chat-card-item">
                            <img src="${c.image}" class="${c.isReversed ? 'reversed' : ''}" alt="${c.name}">
                            <div class="chat-card-name">${c.name}</div>
                            <div class="chat-card-orientation">(${c.orientation})</div>
                        </div>
                    `;
                });
                contentDiv.appendChild(cardsContainer);
            }

            const textDiv = document.createElement('div');
            textDiv.className = 'message-text-content';
            const finalHtml = renderMarkdown(text);
            
            // Hiệu ứng "Livestream" gõ từng chữ cho Bot (chỉ áp dụng cho tin nhắn mới thực sự, save=true)
            if (sender === 'bot' && save) {
                let i = 0;
                let currentHTML = "";
                textDiv.innerHTML = "";
                
                function typeHTML() {
                    // Chạy mỗi lần 8 ký tự cho nhanh, giống tốc độ livestream cực nhanh
                    let charsToType = 8; 
                    while (charsToType > 0 && i < finalHtml.length) {
                        if (finalHtml[i] === '<') {
                            let tag = "";
                            while (finalHtml[i] !== '>' && i < finalHtml.length) {
                                tag += finalHtml[i];
                                i++;
                            }
                            tag += '>';
                            currentHTML += tag;
                            i++;
                        } else {
                            currentHTML += finalHtml[i];
                            i++;
                            charsToType--;
                        }
                    }
                    textDiv.innerHTML = currentHTML;
                    scrollToBottom();
                    
                    if (i < finalHtml.length) {
                        setTimeout(typeHTML, 10);
                    }
                }
                setTimeout(typeHTML, 10); // Bắt đầu sau một chút delay rất nhỏ (10ms) để cho cảm giác tức thì
            } else {
                textDiv.innerHTML = finalHtml;
            }
            
            contentDiv.appendChild(textDiv);
            msgDiv.appendChild(contentDiv);
            chatMessages.appendChild(msgDiv);
            scrollToBottom();

            // TÍNH NĂNG CHỐT PHIÊN (PHASE A.3) & TÓM TẮT CHÂN DUNG (PHASE B.2)
            if (sender === 'bot' && save) {
                const history = JSON.parse(localStorage.getItem(CHAT_HISTORY_KEY) || '[]');
                
                // Phase B.2: Cứ 5 tin nhắn user, gọi API chạy ngầm tóm tắt
                const userMsgCount = history.filter(m => m.sender === 'user').length;
                if (userMsgCount > 0 && userMsgCount % 5 === 0) {
                    fetch('/api/tarot-summarize', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ readingId: currentReadingId })
                    }).catch(err => console.error('Lỗi tóm tắt ngầm:', err));
                }
                
                // Phase A.3: Khi đạt 16 tin nhắn (8 cặp), nhắc nhở nhẹ nhàng (không block)
                if (history.length === 16) {
                    setTimeout(() => {
                        const systemMsg = document.createElement('div');
                        systemMsg.className = 'message bot-message';
                        systemMsg.innerHTML = `
                            <div class="message-content" style="background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,215,0,0.5); font-style: italic;">
                                🌌 Vũ trụ đã gửi khá nhiều thông điệp cho chủ đề này. Để năng lượng được thanh tẩy và câu trả lời được tập trung hơn, bạn có thể cân nhắc nhấn nút <strong>Tạo mới trò chuyện (Biểu tượng Dấu cộng)</strong> ở góc trên bên phải để bắt đầu một phiên trải bài hoàn toàn mới nhé!
                            </div>
                        `;
                        chatMessages.appendChild(systemMsg);
                        scrollToBottom();
                    }, 1000);
                }
            }

            return msgDiv;
        }

        function scrollToBottom() {
            if (window.closeMobileNav) window.closeMobileNav();
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function addTypingIndicator(message = 'Đang soạn tin nhắn...') {
            const typingDiv = document.createElement('div');
            typingDiv.id = 'typing-indicator';
            typingDiv.className = 'typing-indicator';
            typingDiv.innerHTML = `
                <div class="loader-planet-system" style="width:30px; height:30px;">
                    <div class="loader-planet-sphere" style="width:15px; height:15px;"></div>
                    <div class="loader-orbit orbit-1"></div>
                    <div class="loader-orbit orbit-2"></div>
                </div>
                <span>${message}</span>
            `;
            chatMessages.appendChild(typingDiv);
            scrollToBottom();
        }

        function removeTypingIndicator() {
            const el = document.getElementById('typing-indicator');
            if (el) el.remove();
        }

        function autoGrow(element) {
            element.style.height = 'auto';
            element.style.height = Math.min(120, Math.max(48, element.scrollHeight)) + 'px';
        }

        // === TAROT DATA LOAD ===
        
        async function loadTarotData() {
            try {
                const response = await fetch('/api/tarot-cards');
                if (!response.ok) throw new Error('Không thể tải dữ liệu bài Tarot từ Database');
                
                const cards = await response.json();
                
                cardData = cards.map(card => ({
                    id: card.id,
                    name: card.name,
                    image: normalizeImageUrl(card.image)
                }));

                // Preload images
                const uniqueImageUrls = [...new Set(cardData.map(card => card.image).filter(Boolean))];
                const promises = uniqueImageUrls.map(preloadCardImage);
                Promise.all(promises).then(() => allCardImagesLoaded = true);
            } catch (err) {
                console.error("Lỗi tải data bài:", err);
            }
        }

        // === FLOW XỬ LÝ CÂU HỎI & RÚT BÀI ===

        async function handleSend(isResume = false) {
            if (typeof isResume !== 'boolean') {
                isResume = false;
            }
            if (!window.IS_LOGGED_IN) {
                window.location.href = '/login?redirect=' + encodeURIComponent(window.location.pathname);
                return;
            }
            
            const question = isResume ? userQuestion : questionInput.value.trim();
            if (!question || isThinking) return;

            const container = document.querySelector('.chat-page-container');
            if (container.classList.contains('initial-state')) {
                container.classList.remove('initial-state');
            }

            if (!isResume) {
                // 1. Thêm tin nhắn user vào chat
                addMessage(question, 'user');
                questionInput.value = '';
                questionInput.style.height = 'auto';
                userQuestion = question;
            }
            
            isThinking = true;

            submitBtn.disabled = true;
            submitBtn.innerHTML = spinnerIcon;

            // KIỂM TRA LỊCH SỬ BỐC BÀI NGAY LÚC NÀY
            const history = JSON.parse(localStorage.getItem(CHAT_HISTORY_KEY) || '[]');
            // Lọc bỏ tin nhắn user vừa gửi ở trên để kiểm tra lịch sử trước đó
            const priorHistory = history.slice(0, -1);
            const hasDrawnBefore = priorHistory.some(m => m.sender === 'bot' && m.cards && m.cards.length > 0);

            if (hasDrawnBefore) {
                try {
                    // Trích xuất 3 lá bài GẦN NHẤT đã bốc từ localStorage để gửi kèm cho n8n
                    const drawnMsgs = priorHistory.filter(m => m.sender === 'bot' && m.cards && m.cards.length > 0);
                    const drawnMsg = drawnMsgs.length > 0 ? drawnMsgs[drawnMsgs.length - 1] : null;
                    const drawnCards = drawnMsg
                        ? drawnMsg.cards.map(c => ({ name: c.name, orientation: c.orientation, isReversed: c.isReversed }))
                        : [];

                    // Trích xuất lịch sử hội thoại (cả user và bot) - Cắt ngọn 12 tin nhắn gần nhất (Sliding Window)
                    const chatHistory = priorHistory
                        .filter(m => m.text && m.text.trim())
                        .map(m => ({ role: m.sender === 'bot' ? 'assistant' : 'user', content: m.text }))
                        .slice(-12);

                    // Luôn validate trước - mọi turn đều phải qua bước này
                    addTypingIndicator();
                    const response = await fetch(N8N_VALIDATE_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            question,
                            readingId: currentReadingId,
                            userId: currentUserId,
                            isFollowUp: true,
                            cards: drawnCards,    // 3 lá bài đã bốc
                            history: chatHistory,  // Lịch sử hội thoại để LLM có context
                            reader_id: currentReaderId // Narrative Reader
                        })
                    });

                    if (!response.ok) {
                        if (response.status === 402) {
                            const errorData = await response.json().catch(() => ({}));
                            throw new Error(errorData.error || 'OUT_OF_CREDITS');
                        }
                        throw new Error('Lỗi xác thực');
                    }
                    const result = await response.json();

                    if (result && (result.isValid === "true" || result.isValid === true)) {
                        if (result.pick_card === false || result.pick_card === "false") {
                            // pick_card=false: n8n đã gọi LLM conversational, trả về câu trả lời trong reason
                            addMessage(result?.reason || "Mình luôn sẵn sàng lắng nghe! Bạn còn thắc mắc gì về trải bài này không?", 'bot', true, null, result.usage, result.model);
                            
                            if (result.creditDeducted) {
                                setTimeout(() => {
                                    addMessage("💡 Hệ thống: Bạn vừa trò chuyện đủ 10 tin nhắn, 1 Credit đã được sử dụng. Xin mời tiếp tục tâm sự nhé!", 'bot', false);
                                }, 500);
                            }
                            
                            isThinking = false;
                            
                            // Gọi hàm fetchBalance() toàn cục để cập nhật số dư nếu bị trừ
                            if (typeof window.fetchBalance === 'function') window.fetchBalance(true);
                        } else {
                            // pick_card=true: Câu hỏi tarot mới -> Hiện box xác nhận bốc bài (giống Turn 1)
                            // isThinking giữ nguyên = true cho đến khi user click Đồng ý / Từ chối
                            lastValidationUsage = result.usage || null;
                            lastValidationModel = result.model || null;
                        localStorage.setItem('pending_topic', result.topic || 'general');
                        targetSpreadCount = parseInt(result.numbercard) || 3;
                            showConfirmationBox(question, targetSpreadCount);
                        }
                    } else {
                        // Không hợp lệ -> Từ chối lịch sự
                        addMessage(result?.reason || "Câu hỏi của bạn chưa phù hợp, hãy đặt câu hỏi mở hơn nhé.", 'bot', true, null, result.usage, result.model);
                        isThinking = false;
                    }
                } catch (err) {
                    // KHÔNG xóa tin nhắn user khỏi localStorage hay UI nữa, để họ vẫn thấy câu hỏi
                    // Trả lại text vào ô input để tiện sửa đổi nếu muốn (chỉ khi không phải resume)
                    if (!isResume) {
                        questionInput.value = question;
                    }

                    if (err.message && (err.message === 'OUT_OF_CREDITS' || err.message.includes('hết lượt'))) {
                        addMessage(err.message, 'bot', false);
                    } else {
                        addMessage('Đã xảy ra lỗi kết nối với máy chủ AI. Câu hỏi chưa được tính, vui lòng thử lại sau.', 'bot', false);
                    }
                    isThinking = false;
                } finally {
                    removeTypingIndicator();
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = sendIcon;
                }
                return; // Kết thúc sớm luồng
            }

            // --- NẾU CHƯA TỪNG BỐC BÀI: TIẾP TỤC CHẠY LUỒNG VALIDATE ---
            try {
                addTypingIndicator();
                
                // 2. Validate câu hỏi
                const response = await fetch(N8N_VALIDATE_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ question, readingId: currentReadingId, userId: currentUserId, reader_id: currentReaderId })
                });

                if (!response.ok) {
                    if (response.status === 402) {
                        const errorData = await response.json().catch(() => ({}));
                        throw new Error(errorData.error || 'OUT_OF_CREDITS');
                    }
                    throw new Error('Lỗi xác thực');
                }
                const result = await response.json();

                if (result && (result.isValid === "true" || result.isValid === true)) {
                    if (result.pick_card === false || result.pick_card === "false") {
                        // Trả lời câu chào xã giao trực tiếp từ result.reason
                        addMessage(result?.reason || "Chào bạn, mình luôn ở đây để giúp bạn giải đáp những thắc mắc qua lăng kính Tarot. Bạn có câu hỏi nào không?", 'bot', true, null, result.usage, result.model);
                        
                        if (result.creditDeducted) {
                            setTimeout(() => {
                                addMessage("💡 Hệ thống: Bạn vừa trò chuyện đủ 10 tin nhắn, 1 Credit đã được sử dụng. Xin mời tiếp tục tâm sự nhé!", 'bot', false);
                            }, 500);
                        }
                        
                        isThinking = false;
                        
                        if (typeof window.fetchBalance === 'function') window.fetchBalance(true);
                    } else {
                        // Câu hỏi hợp lệ (pick_card = true hoặc undefined) -> Hiện box xác nhận trải bài
                        lastValidationUsage = result.usage || null;
                        lastValidationModel = result.model || null;
                        localStorage.setItem('pending_topic', result.topic || 'general');
                        targetSpreadCount = parseInt(result.numbercard) || 3;
                        showConfirmationBox(question, targetSpreadCount);
                    }
                } else {
                    // Không hợp lệ -> Trả lời từ chối lịch sự trong chat
                    addMessage(result?.reason || "Câu hỏi của bạn chưa phù hợp, hãy đặt câu hỏi mở hơn nhé.", 'bot', true, null, result.usage, result.model);
                    isThinking = false;
                }
            } catch (err) {
                // KHÔNG xóa tin nhắn user khỏi localStorage hay UI nữa, để họ vẫn thấy câu hỏi
                // Trả lại text vào ô input để tiện sửa đổi nếu muốn (chỉ khi không phải resume)
                if (!isResume) {
                    questionInput.value = question;
                }

                if (err.message && (err.message === 'OUT_OF_CREDITS' || err.message.includes('hết lượt'))) {
                    addMessage(err.message, 'bot', false);
                } else {
                    addMessage('Đã xảy ra lỗi kết nối với máy chủ AI. Câu hỏi chưa được tính, vui lòng thử lại sau.', 'bot', false);
                }
                isThinking = false;
            } finally {
                removeTypingIndicator();
                submitBtn.disabled = false;
                submitBtn.innerHTML = sendIcon;
            }
        }

        // --- INTERACTIVE CONFIRMATION & FOLLOW-UP INTERPRETATION ---

        function showConfirmationBox(question, count = 3) {
            // Ghi nhớ trạng thái đang chờ xác nhận
            localStorage.setItem('waitingForTarotConfirm', question);
            localStorage.setItem('targetSpreadCount', count.toString());
            localStorage.setItem('pending_validation_usage', JSON.stringify(lastValidationUsage));
            localStorage.setItem('pending_validation_model', JSON.stringify(lastValidationModel));

            // Tạo bong bóng chat của Bot có kèm 2 nút tương tác Xác nhận / Từ chối (save = false vì đây là tin nhắn tương tác tạm thời)
            const msgDiv = addMessage(`Để giải đáp câu hỏi này, hệ thống cần thực hiện một Trải bài Tarot gồm **${count} lá bài**. Mỗi lượt trải bài sẽ tốn **1 Credit**. Bạn có đồng ý bốc bài không?`, 'bot', false);
            
            const contentDiv = msgDiv.querySelector('.message-content');
            if (contentDiv) {
                const confirmBox = document.createElement('div');
                confirmBox.className = 'confirm-reading-box';
                confirmBox.innerHTML = `
                    <div class="confirm-buttons">
                        <button class="confirm-btn yes-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="m4.93 4.93 4.24 4.24M14.83 9.17l4.24-4.24M14.83 14.83l4.24 4.24M9.17 14.83l-4.24 4.24"/>
                            </svg>
                            Đồng ý trải bài 🔮
                        </button>
                        <button class="confirm-btn no-btn">
                            Từ chối / Hỏi câu khác 💬
                        </button>
                    </div>
                    <div class="confirm-credit-balance">Số credit: <span class="credit-num">đang tải...</span></div>
                `;

                // Fetch số dư credit thực tế của người dùng để cập nhật hiển thị
                fetch('/api/user/balance')
                    .then(res => res.json())
                    .then(data => {
                        if (data && data.success) {
                            const balanceText = data.balance !== undefined ? data.balance : 0;
                            const creditSpan = confirmBox.querySelector('.confirm-credit-balance .credit-num');
                            if (creditSpan) {
                                creditSpan.textContent = balanceText;
                            }
                        }
                    })
                    .catch(err => {
                        console.error('Lỗi lấy số dư credit:', err);
                        const creditSpan = confirmBox.querySelector('.confirm-credit-balance .credit-num');
                        if (creditSpan) {
                            creditSpan.textContent = '0';
                        }
                    });

                const yesBtn = confirmBox.querySelector('.yes-btn');
                const noBtn = confirmBox.querySelector('.no-btn');

                yesBtn.addEventListener('click', () => {
                    localStorage.removeItem('waitingForTarotConfirm');
                    localStorage.setItem('isDrawingTarot', question);
                    msgDiv.remove();
                    openTarotModal();
                });

                noBtn.addEventListener('click', () => {
                    localStorage.removeItem('waitingForTarotConfirm');
                    localStorage.removeItem('targetSpreadCount');
                    localStorage.removeItem('isDrawingTarot');
                    localStorage.removeItem('pending_validation_usage');
                    localStorage.removeItem('pending_validation_model');
                    msgDiv.remove();
                    addMessage("Được chứ, lữ khách cứ tự nhiên. Mình luôn sẵn sàng chia sẻ thêm hoặc trò chuyện cùng bạn. Bạn muốn hỏi gì khác không?", 'bot', true);
                    isThinking = false;
                });

                contentDiv.appendChild(confirmBox);
            }
        }



        // --- MODAL LOGIC ---

        function showScreen(id) {
            screens.forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function openTarotModal() {
            document.body.style.overflow = 'hidden';
            tarotModal.classList.remove('hidden');
            shufflingQuestionDisplay.textContent = userQuestion;
            drawingQuestionDisplay.textContent = userQuestion;
            
            if (targetSpreadCount === 5) {
                chosenCardsDisplay.classList.add('spread-5');
                chosenCardsDisplay.classList.remove('spread-3');
            } else {
                chosenCardsDisplay.classList.remove('spread-5');
                chosenCardsDisplay.classList.add('spread-3');
            }
            
            showScreen('shuffling-screen');
            const shuffleTime = 2500;
            const startTime = Date.now();

            function check() {
                if (allCardImagesLoaded && (Date.now() - startTime) >= shuffleTime) {
                    startDrawing();
                } else {
                    setTimeout(check, 100);
                }
            }
            check();
        }

        function closeTarotModal() {
            document.body.style.overflow = '';
            tarotModal.classList.add('hidden');
        }

        let tempDrawnIndices = []; // Định nghĩa biến toàn cục
        function startDrawing() {
            spreadContainer.innerHTML = '';
            selectedCards = [];
            tempDrawnIndices = []; // Reset mảng tạm mỗi khi bắt đầu phiên mới
            
            const subheader = document.getElementById('drawing-subheader');
            if (subheader) {
                subheader.innerText = `Hãy chọn ${targetSpreadCount} lá bài theo trực giác`;
            }
            
            updateChosenCards();
            showScreen('drawing-screen');

            // Tính toán số lá bài đã rút trong phiên (lịch sử)
            const history = JSON.parse(localStorage.getItem(CHAT_HISTORY_KEY) || '[]');
            let allDrawnCardIds = [];
            for (const msg of history) {
                if (msg.sender === 'bot' && msg.cards && msg.cards.length > 0) {
                    msg.cards.forEach(c => {
                        if (c.id !== undefined) {
                            allDrawnCardIds.push(c.id);
                        } else if (c.name) {
                            // Cố gắng map lại từ name nếu history cũ không có id
                            const matchedCard = cardData.find(cd => cd.name === c.name);
                            if (matchedCard) allDrawnCardIds.push(matchedCard.id);
                        }
                    });
                }
            }
            
            // Xóa duplicate just in case
            allDrawnCardIds = [...new Set(allDrawnCardIds)];
            
            // Nếu bốc đủ 21 lá, reset vòng lặp (lấy phần dư để biết cycle hiện tại)
            const drawnCount = allDrawnCardIds.length;
            const cycleCount = Math.floor(drawnCount / 21);
            currentCycleDrawnCardIds = allDrawnCardIds.slice(cycleCount * 21);

            let drawnIndices = JSON.parse(localStorage.getItem(`drawn_indices_${currentReadingId}`) || '[]');
            let cycleIndices = drawnIndices.slice(cycleCount * 21);
            
            // Fallback: Nếu lịch sử cũ chưa có lưu vị trí rút, ta tự random vị trí đục lỗ để khớp số lượng bài đã rút
            let missingIndicesCount = currentCycleDrawnCardIds.length - cycleIndices.length;
            if (missingIndicesCount > 0) {
                for (let k = 0; k < missingIndicesCount; k++) {
                    let randIdx;
                    do {
                        randIdx = Math.floor(Math.random() * 78);
                    } while (cycleIndices.includes(randIdx));
                    cycleIndices.push(randIdx);
                    drawnIndices.push(randIdx);
                }
                localStorage.setItem(`drawn_indices_${currentReadingId}`, JSON.stringify(drawnIndices));
            }

            // BẮT BUỘC: Nếu đã bốc đủ 21 lá (tức còn lại <= 57 lá), reset lại toàn bộ 78 lá
            if (cycleIndices.length >= 21) {
                console.log(`[Tarot Spread] Đã bốc ${cycleIndices.length} lá (còn lại ${78 - cycleIndices.length} lá). Kích hoạt cơ chế RESET về 78 lá!`);
                drawnIndices = drawnIndices.slice(0, cycleCount * 21);
                cycleIndices = [];
                currentCycleDrawnCardIds = [];
                localStorage.setItem(`drawn_indices_${currentReadingId}`, JSON.stringify(drawnIndices));
            }

            const remainingCardsCount = 78 - cycleIndices.length;
            console.log(`[Tarot Spread] Số lá bài còn lại trên bàn hiện tại: ${remainingCardsCount}`);

            // Gom các thẻ chưa bị bốc lại
            const visibleCards = [];
            for (let i = 0; i < 78; i++) {
                if (!cycleIndices.includes(i)) {
                    visibleCards.push(i);
                }
            }

            // Responsive: Chia thành nhiều hàng. Mobile: 20 lá/hàng, Desktop: 39 lá/hàng.
            const isTabletDeck = (window.innerWidth > 768 && window.innerWidth <= 1180) ||
                (window.matchMedia("(pointer: coarse)").matches && window.innerWidth > 768 && window.innerWidth <= 1366) ||
                /iPad/i.test(navigator.userAgent);
            const isMobileDeck = window.innerWidth <= 768 ||
                window.matchMedia("(max-width: 768px)").matches ||
                /Android|webOS|iPhone|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

            if (isMobileDeck || isTabletDeck) {
                const cardsPerRow = isTabletDeck ? Math.ceil(visibleCards.length / 2) : 20;
                for (let i = 0; i < visibleCards.length; i += cardsPerRow) {
                    const row = document.createElement('div');
                    row.className = `card-row mobile-card-row${isTabletDeck ? ' tablet-card-row' : ''}`;
                    visibleCards.slice(i, i + cardsPerRow).forEach((idx, j) => {
                        const card = document.createElement('div');
                        card.className = 'facedown-card';
                        card.dataset.idx = idx;
                        card.innerHTML = '<img class="mobile-card-back-img" src="/card-back.jpg" alt="" decoding="async" draggable="false">';
                        card.style.animation = `dealCardIn 0.3s ease-out forwards ${(i + j) * 18}ms`;
                        card.addEventListener('click', (e) => handleCardSelect(e.currentTarget));
                        row.appendChild(card);
                    });
                    spreadContainer.appendChild(row);
                }
                return;
            }

            const fanStage = document.createElement('div');
            fanStage.className = `card-fan-stage spread-${targetSpreadCount}`;
            const ringSplit = Math.ceil(visibleCards.length / 2);
            const setFanVars = (card, order, total) => {
                const isOuterRing = order < ringSplit;
                const ringIndex = isOuterRing ? order : order - ringSplit;
                const ringTotal = isOuterRing ? ringSplit : Math.max(total - ringSplit, 1);
                const progress = ringTotal <= 1 ? 0.5 : ringIndex / (ringTotal - 1);
                const arc = isOuterRing ? 92 : 82;
                const angle = -arc / 2 + progress * arc;
                card.style.setProperty('--fan-angle', `${angle}deg`);
                card.style.setProperty('--fan-bottom', isOuterRing ? '26px' : '-34px');
                card.style.setProperty('--fan-origin', isOuterRing ? '820px' : '730px');
                card.style.setProperty('--fan-z', `${isOuterRing ? ringIndex : ringSplit + ringIndex + 8}`);
            };

            visibleCards.forEach((idx, order) => {
                const card = document.createElement('div');
                card.className = 'facedown-card fan-card';
                card.dataset.idx = idx;
                setFanVars(card, order, visibleCards.length);
                card.style.animation = `fanCardIn 0.38s ease-out forwards ${order * 14}ms`;
                card.addEventListener('click', (e) => handleCardSelect(e.currentTarget));
                fanStage.appendChild(card);
            });

            spreadContainer.appendChild(fanStage);
        }

        function handleCardSelect(el) {
            if (selectedCards.length >= targetSpreadCount || isAnimating) return;
            pauseFanHover(el);
            const idx = el.dataset.idx;
            const cards = document.querySelectorAll(`.facedown-card[data-idx="${idx}"]`);
            if (cards[0].style.display === 'none') return;

            isAnimating = true;
            createPickBurst(el, tarotModal);
            
            // Chỉ lưu tạm vị trí lá bài, chưa lưu vào LocalStorage (tránh lỗi reload mất bài)
            tempDrawnIndices.push(parseInt(idx));

            const avail = cardData.filter(c => 
                !selectedCards.some(sc => sc.id === c.id) &&
                !currentCycleDrawnCardIds.includes(c.id)
            );
            
            // Nếu lỡ hết bài (fallback an toàn), reset bài
            const safeAvail = avail.length > 0 ? avail : cardData;
            
            const randomCard = safeAvail[Math.floor(Math.random() * safeAvail.length)];
            const isReversed = Math.random() < 0.5;
            const chosen = { ...randomCard, isReversed, orientation: isReversed ? 'Ngược' : 'Xuôi' };

            const target = document.querySelectorAll('#chosen-cards-display .chosen-card-placeholder')[0];
            if (target) {
                animateFlight(el, target, chosen);
            }
        }

        function animateFlight(startEl, endEl, cardInfo) {
            whenCardImageReady(cardInfo.image).then(() => {
                const sRect = startEl.getBoundingClientRect();
                const eRect = endEl.getBoundingClientRect();
                
                // Ẩn lá bài ngay lập tức khỏi flow để các lá bài khác trượt vào lấp đầy khoảng trống
                startEl.style.display = 'none';
                
                const flying = document.createElement('div');
                flying.className = 'flying-card-animator';
                flying.innerHTML = `<div class="flying-card-inner"><div class="flying-card-back"></div><div class="flying-card-front"><img src="${cardInfo.image}" class="${cardInfo.isReversed ? 'reversed' : ''}"></div></div>`;
                
                const modal = document.getElementById('tarot-modal');
                const scrollTop = modal.scrollTop || 0;
                const scrollLeft = modal.scrollLeft || 0;
                const deltaX = eRect.left - sRect.left;
                const deltaY = eRect.top - sRect.top;
                const scaleX = eRect.width / Math.max(sRect.width, 1);
                const scaleY = eRect.height / Math.max(sRect.height, 1);

                flying.style.top = `${sRect.top + scrollTop}px`;
                flying.style.left = `${sRect.left + scrollLeft}px`;
                flying.style.width = `${sRect.width}px`;
                flying.style.height = `${sRect.height}px`;
                flying.style.transform = 'translate3d(0, 0, 0) rotate(-12deg) scale(1)';
                
                modal.appendChild(flying);
                
                requestAnimationFrame(() => {
                    flying.style.transform = `translate3d(${deltaX}px, ${deltaY}px, 0) rotate(0deg) scale(${scaleX}, ${scaleY})`;
                    flying.querySelector('.flying-card-inner').style.transform = 'rotateY(180deg) translateZ(0)';
                });

                let isDone = false;
                const finishAnimation = () => {
                    if (isDone) return;
                    isDone = true;
                    if (flying.parentNode) flying.remove();
                    createPickBurst(endEl, tarotModal);
                    selectedCards.push(cardInfo);
                    updateChosenCards();
                    isAnimating = false;

                    if (selectedCards.length === targetSpreadCount) {
                        // Phiên bốc bài hoàn tất, giờ mới lưu các vị trí đã bốc vào LocalStorage
                        let finalDrawnIndices = JSON.parse(localStorage.getItem(`drawn_indices_${currentReadingId}`) || '[]');
                        finalDrawnIndices.push(...tempDrawnIndices);
                        localStorage.setItem(`drawn_indices_${currentReadingId}`, JSON.stringify(finalDrawnIndices));

                        localStorage.setItem('pending_tarot_cards', JSON.stringify(selectedCards));
                        setTimeout(() => {
                            closeTarotModal();
                            requestInterpretation();
                        }, 1500);
                    }
                };

                flying.addEventListener('transitionend', function handler(e) {
                    if (e.target !== flying) return;
                    flying.removeEventListener('transitionend', handler);
                    finishAnimation();
                });

                // Fallback nếu transitionend không chạy trên Mobile Safari
                setTimeout(finishAnimation, 2400);
            });
        }

        function pauseFanHover(cardEl) {
            const fanStage = cardEl?.closest('.card-fan-stage');
            if (!fanStage) return;
            fanStage.classList.add('hover-paused');
            clearTimeout(fanStage._hoverPauseTimer);
            fanStage._hoverPauseTimer = setTimeout(() => {
                fanStage.classList.remove('hover-paused');
            }, 2000);
        }

        function createPickBurst(anchorEl, parentEl = document.body) {
            if (!anchorEl || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            const rect = anchorEl.getBoundingClientRect();
            const parentRect = parentEl === document.body
                ? { top: -window.scrollY, left: -window.scrollX }
                : parentEl.getBoundingClientRect();
            const burst = document.createElement('span');
            burst.className = 'tarot-pick-burst';
            burst.style.left = `${rect.left - parentRect.left + rect.width / 2}px`;
            burst.style.top = `${rect.top - parentRect.top + rect.height / 2}px`;
            parentEl.appendChild(burst);
            burst.addEventListener('animationend', () => burst.remove(), { once: true });
            setTimeout(() => burst.remove(), 900);
        }

        function updateChosenCards() {
            if (selectedCards.length === 0) {
                chosenCardsDisplay.innerHTML = '';
                for (let i = 0; i < targetSpreadCount; i++) {
                    chosenCardsDisplay.innerHTML += `<div class="chosen-card-placeholder"><span>${i + 1}</span></div>`;
                }
                return;
            }

            const placeholders = chosenCardsDisplay.querySelectorAll('.chosen-card-placeholder');
            if (placeholders.length > 0) {
                const c = selectedCards[selectedCards.length - 1];
                const newItem = document.createElement('div');
                newItem.className = 'chosen-card-item';
                newItem.innerHTML = `
                    <img src="${c.image}" class="${c.isReversed ? 'reversed' : ''}">
                    <div class="card-name">${c.name} ${c.isReversed ? '(Ngược)' : ''}</div>
                `;
                placeholders[0].replaceWith(newItem);
            }
        }

        // === FETCH API LUẬN GIẢI ===

        async function requestInterpretation() {
            // --- GTM Tracking: Event feature_usage ---
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                'event': 'feature_usage',
                'feature_name': 'tarot_reading',
                'action': 'start_reading'
            });
            // -----------------------------------------
            
            addTypingIndicator('Đang luận giải các lá bài của bạn... Thời gian dự kiến khoảng 40-60 giây, bạn vui lòng chờ và không cần tải lại trang nhé.');
            
            // Khôi phục lại usage nếu bị refresh
            if (!lastValidationUsage) {
                lastValidationUsage = JSON.parse(localStorage.getItem('pending_validation_usage') || 'null');
            }
            if (!lastValidationModel) {
                lastValidationModel = JSON.parse(localStorage.getItem('pending_validation_model') || 'null');
            }
            
            try {
                const topic = localStorage.getItem('pending_topic') || 'general';
                const response = await fetch(N8N_WEBHOOK_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        question: userQuestion,
                        cards: selectedCards.map(c => ({ 
                            name: c.name, 
                            orientation: c.orientation,
                            meaning: c.isReversed ? c.meaning_rev : c.meaning_up
                        })),
                        readingId: currentReadingId,
                        userId: currentUserId,
                        reader_id: currentReaderId, // Narrative Reader
                        validationUsage: lastValidationUsage,
                        validationModel: lastValidationModel,
                        topic: localStorage.getItem('pending_topic') || 'general'
                    })
                });

                // Clear sau khi đã gửi đi
                lastValidationUsage = null;
                lastValidationModel = null;

                if (!response.ok) {
                    if (response.status === 402) {
                        const errorData = await response.json().catch(() => ({}));
                        throw new Error(errorData.error || 'OUT_OF_CREDITS');
                    }
                    throw new Error('Lỗi luận giải');
                }
                const result = await response.json();

                removeTypingIndicator();
                if (result && result.interpretation) {
                    addMessage(result.interpretation, 'bot', true, selectedCards, result.usage, result.model);
                    // Dọn dẹp pending vì đã thành công
                    localStorage.removeItem('pending_tarot_cards');
                    localStorage.removeItem('isDrawingTarot');
                    localStorage.removeItem('targetSpreadCount');
                    localStorage.removeItem('pending_validation_usage');
                    localStorage.removeItem('pending_validation_model');
                    
                    if (typeof window.fetchBalance === 'function') window.fetchBalance(true);
                } else {
                    throw new Error('Không nhận được thông điệp');
                }
            } catch (err) {
                removeTypingIndicator();
                
                if (err.message && (err.message === 'OUT_OF_CREDITS' || err.message.includes('hết lượt'))) {
                    addMessage(err.message, 'bot', false, selectedCards);
                    // Dọn dẹp state để user có thể nạp tiền và bốc bài mới
                    localStorage.removeItem('pending_tarot_cards');
                    localStorage.removeItem('isDrawingTarot');
                    return;
                }
                
                // addMessage với save=false vì đây là tin nhắn lỗi tạm thời, có thể thử lại
                const errorMsgDiv = addMessage("Kết nối vũ trụ bị gián đoạn. Vui lòng thử lại sau nha.", 'bot', false, selectedCards);
                const contentDiv = errorMsgDiv?.querySelector('.message-content');
                if (contentDiv) {
                    const retryContainer = document.createElement('div');
                    retryContainer.className = 'retry-container';
                    retryContainer.style.marginTop = '12px';
                    retryContainer.style.display = 'flex';
                    retryContainer.style.justifyContent = 'flex-start';

                    const retryBtn = document.createElement('button');
                    retryBtn.className = 'retry-btn';
                    retryBtn.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;">
                            <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/>
                        </svg>
                        Thử lại
                    `;
                    retryBtn.style.padding = '8px 16px';
                    retryBtn.style.background = 'linear-gradient(135deg, #D4AF37 0%, #F2C94C 100%)';
                    retryBtn.style.color = '#111827';
                    retryBtn.style.fontWeight = '600';
                    retryBtn.style.border = 'none';
                    retryBtn.style.borderRadius = '8px';
                    retryBtn.style.cursor = 'pointer';
                    retryBtn.style.fontSize = '13px';
                    retryBtn.style.display = 'inline-flex';
                    retryBtn.style.alignItems = 'center';
                    retryBtn.style.boxShadow = '0 2px 4px rgba(0,0,0,0.2)';
                    retryBtn.style.transition = 'all 0.2s ease';

                    retryBtn.onmouseover = () => {
                        retryBtn.style.transform = 'translateY(-1px)';
                        retryBtn.style.boxShadow = '0 4px 6px rgba(0,0,0,0.3)';
                    };
                    retryBtn.onmouseout = () => {
                        retryBtn.style.transform = 'none';
                        retryBtn.style.boxShadow = '0 2px 4px rgba(0,0,0,0.2)';
                    };

                    retryBtn.addEventListener('click', async () => {
                        errorMsgDiv.remove();
                        isThinking = true;
                        await requestInterpretation();
                    });

                    retryContainer.appendChild(retryBtn);
                    contentDiv.appendChild(retryContainer);
                }
            } finally {
                isThinking = false;
            }
        }

        // INIT
        document.addEventListener('DOMContentLoaded', () => {
            initChat();
            loadTarotData();

            questionInput.addEventListener('input', () => autoGrow(questionInput));
            
            questionInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    handleSend();
                }
            });

            submitBtn.addEventListener('click', handleSend);

            clearBtn.addEventListener('click', () => {
                if (confirm('Bắt đầu một phiên trò chuyện mới? Các tin nhắn hiện tại đã được lưu vào lịch sử.')) {
                    localStorage.removeItem(CHAT_HISTORY_KEY);
                    localStorage.removeItem(READING_ID_KEY); // Force new conversation_id
                    window.location.reload(); // Reload for a fresh state
                }
            });
            
            // LOGIC GỢI Ý CÂU HỎI (Cloudflare KV)
            const suggestedQuestionsToggle = document.getElementById('suggested-questions-toggle');
            const suggestedQuestionsList = document.getElementById('suggested-questions-list');
            
            async function loadSuggestedQuestions() {
                if (!suggestedQuestionsList) return;
                try {
                    const dataDiv = document.getElementById('suggested-questions-data');
                    let rawData = [];
                    if (dataDiv && dataDiv.dataset.questions) {
                        try {
                            rawData = JSON.parse(dataDiv.dataset.questions);
                        } catch(e) { console.error("Lỗi parse KV JSON:", e); }
                    }
                    
                    if (!rawData || rawData.length === 0) {
                        suggestedQuestionsList.innerHTML = '<p style="padding: 1rem; opacity: 0.7; text-align: center;">Chưa có câu hỏi gợi ý nào. Quản trị viên cần thêm dữ liệu vào KV (SUGGESTED_QUESTIONS).</p>';
                        return;
                    }

                    const grouped = {};
                    rawData.forEach(item => {
                        if (!item.category || !item.question) return;
                        if (!grouped[item.category]) grouped[item.category] = [];
                        grouped[item.category].push(item.question);
                    });

                    let html = '';
                    for (const category in grouped) {
                        html += `<h4 class="category-title">${category}</h4>`;
                        grouped[category].forEach(question => {
                            const safe = question.replace(/"/g, '&quot;');
                            html += `<button class="suggestion-item" data-question="${safe}">${question}</button>`;
                        });
                    }
                    suggestedQuestionsList.innerHTML = html;
                } catch (error) {
                    console.error('Lỗi tải câu hỏi gợi ý:', error);
                    suggestedQuestionsList.innerHTML = '<p style="padding: 1rem; opacity: 0.7; text-align: center;">Không thể tải gợi ý.</p>';
                }
            }

            if (suggestedQuestionsToggle && suggestedQuestionsList) {
                loadSuggestedQuestions();

                suggestedQuestionsToggle.addEventListener('click', () => {
                    // Chỉ track khi modal chưa mở (tức là hành động này sẽ MỞ modal)
                    if (!suggestedQuestionsList.classList.contains('open')) {
                        // --- GTM Tracking ---
                        window.dataLayer = window.dataLayer || [];
                        window.dataLayer.push({
                            'event': 'feature_usage',
                            'feature_name': 'tarot_chat',
                            'action': 'view_suggested_questions'
                        });
                        // --------------------
                    }
                    suggestedQuestionsList.classList.toggle('open');
                    suggestedQuestionsToggle.classList.toggle('open');
                });

                suggestedQuestionsList.addEventListener('click', (e) => {
                    const btn = e.target.closest('.suggestion-item');
                    if (btn) {
                        questionInput.value = btn.dataset.question || btn.textContent;
                        suggestedQuestionsList.classList.remove('open');
                        suggestedQuestionsToggle.classList.remove('open');
                        autoGrow(questionInput);
                    }
                });

                document.addEventListener('click', (e) => {
                    if (!suggestedQuestionsToggle.contains(e.target) && !suggestedQuestionsList.contains(e.target)) {
                        suggestedQuestionsList.classList.remove('open');
                        suggestedQuestionsToggle.classList.remove('open');
                    }
                });
            }

            // LOGIC MODAL PROFILE
            const openProfileModalBtn = document.getElementById('open-profile-modal-btn');
            const closeProfileModalBtn = document.getElementById('close-profile-modal-btn');
            const profileModalContainer = document.getElementById('profile-modal-container');
            
            if (openProfileModalBtn && profileModalContainer && closeProfileModalBtn) {
                openProfileModalBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    // --- GTM Tracking ---
                    window.dataLayer = window.dataLayer || [];
                    window.dataLayer.push({
                        'event': 'feature_usage',
                        'feature_name': 'tarot_chat',
                        'action': 'open_profile_modal'
                    });
                    // --------------------
                    profileModalContainer.classList.remove('hidden');
                });
                closeProfileModalBtn.addEventListener('click', () => {
                    profileModalContainer.classList.add('hidden');
                });
                // Nhấn ngoài modal để đóng
                profileModalContainer.addEventListener('click', (e) => {
                    if (e.target === profileModalContainer) {
                        profileModalContainer.classList.add('hidden');
                    }
                });
            }

            const inlineProfileForm = document.getElementById('inline-profile-form');
            if (inlineProfileForm) {
                inlineProfileForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const submitBtn = document.getElementById('inline-submit-btn');
                    const btnText = submitBtn.querySelector('.btn-text');
                    const spinner = submitBtn.querySelector('.spinner');
                    const errorMsg = document.getElementById('inline-form-error');
                    const successMsg = document.getElementById('inline-form-success');

                    submitBtn.disabled = true;
                    btnText.style.display = 'none';
                    spinner.style.display = 'block';
                    errorMsg.style.display = 'none';
                    successMsg.style.display = 'none';

                    const formData = new FormData(inlineProfileForm);
                    const data = Object.fromEntries(formData.entries());
                    // Remove partial date selects — only date_of_birth (combined) is needed
                    delete data.dob_day;
                    delete data.dob_month;
                    delete data.dob_year;

                    try {
                        const response = await fetch('/api/profile/update', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data),
                        });
                        const result = await response.json();
                        if (response.ok) {
                            successMsg.style.display = 'block';
                            const desktopName = document.querySelector('.desktop-only-profile strong');
                            const mobileName = document.querySelector('.mobile-only-profile strong');
                            if (desktopName) desktopName.textContent = data.full_name;
                            if (mobileName) mobileName.textContent = data.full_name;
                            
                            // Tự động đóng modal sau 2s
                            setTimeout(() => {
                                profileModalContainer.classList.add('hidden');
                                successMsg.style.display = 'none';
                            }, 2000);
                        } else {
                            errorMsg.textContent = result.error || 'Đã có lỗi xảy ra.';
                            errorMsg.style.display = 'block';
                        }
                    } catch (error) {
                        errorMsg.textContent = 'Mất kết nối. Vui lòng kiểm tra mạng.';
                        errorMsg.style.display = 'block';
                    } finally {
                        submitBtn.disabled = false;
                        btnText.style.display = 'block';
                        spinner.style.display = 'none';
                    }
                });
            }
        });
    </script>
</BaseLayout>
