---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articleSchema, breadcrumbListSchema, graphSchema, webApplicationSchema, webPageSchema } from '../lib/schema';
import '../styles/than-so-hoc.css';

const pageTitle = "Tra Cứu Thần Số Học Miễn Phí - Luận Giải Chi Tiết | Phở Gõ Tarot";
const pageDesc = "Công cụ tra cứu Thần Số Học miễn phí, chính xác nhất theo trường phái Pythagoras. Khám phá Số Chủ Đạo, Sứ Mệnh, Linh Hồn qua Họ Tên và Ngày Sinh.";
const pageUrl = new URL('/than-so-hoc', Astro.site).href;

// Kiểm tra trạng thái đăng nhập để truyền xuống client
const isLoggedIn = !!Astro.locals.user;

// Cấu trúc dữ liệu SEO (Schema Markup)
const schema = graphSchema([
  webPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc }),
  webApplicationSchema({
    url: pageUrl,
    name: 'Công Cụ Tra Cứu Thần Số Học Phở Gõ',
    description: 'Phần mềm tra cứu thần số học online miễn phí, luận giải chi tiết bản đồ cuộc đời.'
  }),
  articleSchema({
    url: pageUrl,
    title: 'Thần Số Học Là Gì? Hướng Dẫn Tra Cứu Bản Đồ Vận Mệnh Chuẩn Xác',
    description: 'Tìm hiểu về Thần số học Pythagoras và cách sử dụng công cụ tra cứu để thấu hiểu bản thân, định hướng tương lai.',
    image: 'https://phogotarot.com/images/than-so-hoc-cover.jpg',
    datePublished: '2023-10-25'
  }),
  breadcrumbListSchema(pageUrl, [
    { name: 'Trang chủ', url: '/' },
    { name: 'Thần số học', url: '/than-so-hoc' }
  ])
]);
---

<BaseLayout title={pageTitle} description={pageDesc} >
  <!-- Inject JSON-LD Schema -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)}></script>

  <!-- Hiệu ứng sao nền -->
  <div id="stars-bg"></div>
  
  <main class="numerology-container fade-in-up">
    
    <!-- 1. HERO & FORM SECTION -->
    <section class="hero-section text-center">
      <h1 class="hero-title">Tra Cứu Thần Số Học</h1>
      <p class="hero-subtitle">
        Nhập <span class="text-gold">Họ Tên</span> trên giấy khai sinh và <span class="text-gold">Ngày Sinh</span> dương lịch để vũ trụ gửi đến bạn bản đồ định mệnh.
      </p>
      
      {!isLoggedIn && (
        <a href="/login?redirect=/than-so-hoc" class="login-badge" style="margin-top: 15px; display: inline-block; padding: 6px 16px; background: rgba(242, 201, 76, 0.1); border: 1px solid rgba(242, 201, 76, 0.3); border-radius: 20px; color: #F2C94C; font-size: 0.95rem; text-decoration: none; transition: all 0.2s ease;">
            <i class="fa-solid fa-lock" style="margin-right: 5px;"></i> Bạn cần đăng nhập để sử dụng miễn phí
        </a>
      )}
    </section>

    <!-- Input Form - Style Dark Glass -->
    <section class="input-section">
      <div class="mystic-form-box">
        
        <!-- Decorative Elements -->
        <div class="corner-decoration top-left"></div>
        <div class="corner-decoration top-right"></div>
        <div class="corner-decoration bottom-left"></div>
        <div class="corner-decoration bottom-right"></div>

        <div class="form-grid">
          <!-- 1. Họ Tên -->
          <div class="input-group">
            <label for="fullName">Họ và Tên Đầy Đủ <span class="required">*</span></label>
            <input type="text" id="fullName" class="mystic-input" placeholder="Ví dụ: NGUYEN VAN A" autocomplete="off">
          </div>

          <!-- 2. Biệt Danh -->
          <div class="input-group">
            <label for="nickname">Biệt Danh / Tên Thường Gọi</label>
            <input type="text" id="nickname" class="mystic-input" placeholder="Ví dụ: Anna" autocomplete="off">
          </div>
          
          <!-- 3. Ngày Sinh -->
          <div class="input-group">
            <label for="dob">Ngày Sinh (Dương Lịch) <span class="required">*</span></label>
            <input type="date" id="dob" class="mystic-input">
          </div>

          <!-- 4. Giới Tính -->
          <div class="input-group">
            <label for="gender">Giới Tính</label>
            <select id="gender" class="mystic-input">
                <option value="male">Nam</option>
                <option value="female">Nữ</option>
                <option value="other">Khác</option>
            </select>
          </div>
        </div>

        <div class="action-area">
            <button id="btn-analyze" class="btn-primary mystic-btn" data-is-logged-in={isLoggedIn ? 'true' : 'false'}>
                Giải Mã Định Mệnh
            </button>
            <p id="error-msg" class="error-text hidden">Vui lòng nhập đầy đủ thông tin bắt buộc.</p>
        </div>
      </div>
    </section>

    <!-- NEW: PRICING & PREMIUM CTA INFO SECTION (COMPACT & SLEEK) -->
    <section class="premium-info-section container">
      <div class="mystic-pricing-card compact-version">
        <div class="glow-effect"></div>
        <div class="corner-decoration top-left"></div>
        <div class="corner-decoration top-right"></div>
        <div class="corner-decoration bottom-left"></div>
        <div class="corner-decoration bottom-right"></div>
        
        <div class="pricing-compact-content">
          <div class="pricing-compact-text">
            <span class="pricing-badge"><i class="fa-solid fa-gem"></i> Bản Đồ Thần Số Học</span>
            <h3 class="pricing-compact-title">Khám Phá Bản Thân Linh Hoạt</h3>
            <p class="pricing-compact-desc">
              Hệ thống hỗ trợ tra cứu <strong>Miễn phí</strong> các chỉ số cơ bản, biểu đồ ngày sinh và biểu đồ nghề nghiệp. Để xem trọn vẹn luận giải chi tiết chuyên sâu (6 chỉ số phụ, nợ nghiệp, đỉnh cao cuộc đời và dự báo tháng/năm...), bạn chỉ cần <strong>3 Credits/lượt</strong> (mở khóa một lần, lưu tài khoản xem lại mãi mãi).
            </p>
            <div class="pricing-compact-highlight">
              <i class="fa-solid fa-crown text-gold animate-pulse-slow"></i>
              <span>Hoặc nâng cấp gói <strong>Premium</strong> để tra cứu và lưu trữ <strong>không giới hạn</strong> tất cả hồ sơ mà không cần tốn credit.</span>
            </div>
          </div>
          
          <div class="pricing-compact-actions">
            <a href="/nap-credit?from=tsh" class="btn-upgrade-premium compact-btn">
              <i class="fa-solid fa-crown"></i> Nâng Cấp Premium
            </a>
            <a href="/nap-credit" class="btn-buy-credits compact-btn">
              <i class="fa-solid fa-coins"></i> Nạp Credit (3đ/lượt)
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="container"><div class="divider"></div></div>

    <!-- 2. SEO ARTICLE CONTENT SECTION -->
    <section class="content-section container">
      
      <article class="seo-article">
        <h2 class="section-title text-center">Thần Số Học Là Gì? <br/>Khám Phá Bí Ẩn Đằng Sau Những Con Số</h2>
        
        <div class="content-wrapper">
          <p class="section-text">
            Bạn có bao giờ tự hỏi tại sao mình lại có những nét tính cách đặc biệt, hay tại sao cuộc đời mình lại trải qua những thăng trầm nhất định? <strong>Thần số học (Numerology)</strong> chính là chìa khóa để giải mã những bí ẩn đó.
          </p>

          <h3 class="section-subtitle-small">🪐 Khoa Học Của Những Con Số</h3>
          <p class="section-text">
            Thần số học, đặc biệt là trường phái <strong>Pythagoras</strong>, là một môn khoa học huyền bí nghiên cứu về sự rung động của các con số và ảnh hưởng của chúng lên đời sống con người. Mỗi con số từ 1 đến 9 (và các số Master 11, 22, 33) đều mang một tần số năng lượng riêng biệt, đại diện cho những đặc điểm tính cách, điểm mạnh, điểm yếu và bài học cuộc đời của mỗi người.
          </p>
          <p class="section-text">
            Không giống như bói toán dựa trên sự may rủi, Thần số học dựa trên dữ liệu cụ thể là <span class="text-gold">Họ Tên</span> và <span class="text-gold">Ngày Sinh</span> của bạn để phân tích. Nó giống như một tấm bản đồ GPS cho tâm hồn, giúp bạn đi đúng hướng trên con đường đời.
          </p>

          <div class="highlight-box">
            <h3 class="section-subtitle-small text-center" style="margin-top:0;">✨ 3 Chỉ Số Quan Trọng Nhất</h3>
            <ul class="mystic-list">
              <li><strong>Số Chủ Đạo (Life Path Number):</strong> Con số quyền năng nhất, tiết lộ con đường sự nghiệp, tính cách chủ đạo và bài học lớn nhất bạn cần tốt nghiệp trong kiếp sống này.</li>
              <li><strong>Chỉ Số Linh Hồn (Soul Urge):</strong> Khát khao thầm kín bên trong, động lực thực sự khiến bạn cảm thấy hạnh phúc và thỏa mãn.</li>
              <li><strong>Chỉ Số Sứ Mệnh (Destiny Number):</strong> Vai trò của bạn trong xã hội, năng lực bẩm sinh và những gì bạn được định sẵn để đạt được.</li>
            </ul>
          </div>

          <h2 class="section-title text-center" style="margin-top: 3rem;">Hướng Dẫn Tra Cứu Chuẩn Xác</h2>
          
          <p class="section-text">
            Để nhận được kết quả luận giải chính xác nhất từ công cụ của <strong>Phở Gõ Tarot</strong>, bạn vui lòng lưu ý các bước nhập liệu sau:
          </p>

          <div class="steps-container">
            <div class="step-item">
              <span class="step-number">1</span>
              <div>
                <h4 class="step-title">Họ Tên Khai Sinh</h4>
                <p class="section-text">Nhập chính xác họ tên đầy đủ như trên giấy khai sinh (hoặc thẻ CCCD). Hệ thống sẽ tự động chuyển đổi sang Tiếng Việt không dấu để tính toán chính xác bảng chữ cái Pythagoras.</p>
              </div>
            </div>

            <div class="step-item">
              <span class="step-number">2</span>
              <div>
                <h4 class="step-title">Ngày Sinh Dương Lịch</h4>
                <p class="section-text">Thần số học Pythagoras chỉ sử dụng ngày sinh <strong>Dương Lịch</strong>. Nếu giấy tờ của bạn là ngày âm, hãy chuyển đổi sang dương lịch trước khi nhập nhé.</p>
              </div>
            </div>

            <div class="step-item">
              <span class="step-number">3</span>
              <div>
                <h4 class="step-title">Biệt Danh (Tùy Chọn)</h4>
                <p class="section-text">Tên thường gọi ở nhà hoặc nghệ danh cũng mang một năng lượng bổ trợ. Nhập thêm biệt danh sẽ giúp bản luận giải của bạn phong phú hơn.</p>
              </div>
            </div>
          </div>

          <p class="section-text text-center" style="margin-top: 2rem;">
            <em>"Nhân số học không quyết định số phận, nó giúp bạn hiểu mình để làm chủ số phận."</em> <br/>
            Hãy bắt đầu hành trình khám phá bản thân ngay hôm nay cùng <strong>Phở Gõ Tarot</strong>!
          </p>

        </div>
      </article>
    </section>

  </main>

  <script>
    const btnAnalyze = document.getElementById('btn-analyze');
    const errorMsg = document.getElementById('error-msg');
    const inputs = document.querySelectorAll('.mystic-input');

    // Xóa lỗi khi người dùng bắt đầu nhập liệu
    inputs.forEach(input => {
        input.addEventListener('input', () => {
            if (errorMsg) errorMsg.classList.add('hidden');
        });
    });

    if (btnAnalyze) {
        btnAnalyze.addEventListener('click', () => {
            // Lấy giá trị từ 4 trường
            const nameInput = document.getElementById('fullName') as HTMLInputElement;
            const dobInput = document.getElementById('dob') as HTMLInputElement;
            const nicknameInput = document.getElementById('nickname') as HTMLInputElement;
            const genderInput = document.getElementById('gender') as HTMLSelectElement;

            const name = nameInput.value.trim();
            const dob = dobInput.value;
            const nickname = nicknameInput.value.trim();
            const gender = genderInput.value;

            // Validate các trường bắt buộc (Tên & Ngày sinh)
            if (!name || !dob) {
                if (errorMsg) errorMsg.classList.remove('hidden');
                
                // Hiệu ứng rung lắc báo lỗi
                const box = document.querySelector('.mystic-form-box');
                if (box) {
                    box.classList.add('shake');
                    setTimeout(() => box.classList.remove('shake'), 500);
                }
                return;
            }

            // Animation loading trên nút
            btnAnalyze.innerHTML = '<span class="animate-spin">✦</span> Đang Kết Nối...';
            (btnAnalyze as HTMLButtonElement).style.opacity = "0.8";
            (btnAnalyze as HTMLButtonElement).disabled = true;

            // --- GTM Tracking: Event feature_usage ---
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                'event': 'feature_usage',
                'feature_name': 'numerology',
                'action': 'submit_info'
            });
            // -----------------------------------------

            // Tạo URL params với đủ 4 trường
            const params = new URLSearchParams({ name, dob, nickname, gender });
            
            // Delay nhẹ để người dùng thấy hiệu ứng
            setTimeout(() => {
                const isLoggedIn = btnAnalyze.getAttribute('data-is-logged-in') === 'true';
                const targetUrl = `/ket-qua-than-so-hoc?${params.toString()}`;
                if (!isLoggedIn) {
                    window.location.href = `/login?redirect=${encodeURIComponent(targetUrl)}`;
                } else {
                    window.location.href = targetUrl;
                }
            }, 800);
        });
    }

    // --- GTM Tracking for CTA Buttons ---
    const btnUpgrade = document.querySelector('.btn-upgrade-premium');
    if (btnUpgrade) {
        btnUpgrade.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                'event': 'feature_usage',
                'feature_name': 'numerology',
                'action': 'click_upgrade_premium_cta'
            });
        });
    }

    const btnBuyCredits = document.querySelector('.btn-buy-credits');
    if (btnBuyCredits) {
        btnBuyCredits.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                'event': 'feature_usage',
                'feature_name': 'numerology',
                'action': 'click_buy_credits_cta'
            });
        });
    }
  </script>

</BaseLayout>