---
// 1. IMPORT
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbListSchema, graphSchema, webPageSchema } from '../lib/schema';

// 2. TẠO METADATA VÀ SCHEMA
const pageTitle = "Disclaimer - Miễn Trừ Trách Nhiệm | Phở Gõ Tarot";
const pageDesc = "Đọc kỹ các điều khoản miễn trừ trách nhiệm khi sử dụng dịch vụ và nội dung tại Phở Gõ Tarot.";
const pageUrl = new URL('/disclaimer', Astro.site).href;

const schema = graphSchema([
  webPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc, type: 'WebPage' }),
  breadcrumbListSchema(pageUrl, [
    { name: 'Trang chủ', url: '/' },
    { name: pageTitle.replace(' | Phở Gõ Tarot', ''), url: '/disclaimer' }
  ])
]);
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
>
    <main id="disclaimer-content">
        <section class="homepage-section" style="padding-top: 3rem; min-height: 80vh;">
            <div class="container text-content-container">
                
                <!-- Yêu cầu: Heading lớn, căn trái -->
                <h2 class="section-title" style="text-align: left; margin-bottom: 2rem;">
                    Disclaimer - Miễn Trừ Trách Nhiệm
                </h2>
                
                <!-- Bỏ class "disclaimer-box" -->
                <div>
                    <p class="section-text">Bằng việc truy cập, đăng ký tài khoản, giao dịch nạp credit hoặc sử dụng bất kỳ dịch vụ nào trên website Phở Gõ Tarot, bạn tự nguyện xác nhận đã đọc, hiểu rõ và hoàn toàn đồng ý tuân thủ các điều khoản miễn trừ trách nhiệm quan trọng dưới đây. Nếu bạn không đồng ý với bất kỳ phần nào của các điều khoản này, vui lòng ngừng sử dụng website ngay lập tức.</p>

                    <h3 class="section-subtitle">1. Giới Hạn Độ Tuổi & Năng Lực Hành Vi</h3>
                    <p class="section-text">Các dịch vụ, nội dung và trải nghiệm trên trang web này không hướng tới và không dành cho người dưới 18 tuổi. Bằng cách tiếp tục sử dụng website, bạn cam kết rằng bạn đã đủ 18 tuổi hoặc có đầy đủ năng lực hành vi dân sự để thực hiện các hành vi và tự chịu trách nhiệm pháp lý đối với mọi quyết định cá nhân của mình. Chúng tôi từ chối mọi trách nhiệm pháp lý nếu người dùng dưới 18 tuổi hoặc người không đủ năng lực hành vi dân sự truy cập và sử dụng dịch vụ trên hệ thống.</p>

                    <h3 class="section-subtitle">2. Chỉ Dành Cho Mục Đích Giải Trí & Tham Khảo</h3>
                    <p class="section-text">Tất cả các dịch vụ, bài viết chia sẻ, câu trả lời từ AI Chatbot, kết quả trải bài Tarot (bao gồm bói bài tự động, Tarot Yes/No, Zodiac Tarot hàng ngày) và các phân tích Thần số học đều được tạo ra hoặc diễn giải tự động dựa trên thuật toán AI hoặc các lý thuyết huyền học mang tính giải trí. 
                    Chúng tôi hoàn toàn **không cam kết, không đảm bảo tính chính xác, tính tuyệt đối hay bất kỳ khả năng tiên tri nào** đối với cuộc sống thực tế của bạn. Bạn không nên tin tưởng hoặc coi các kết quả này là căn cứ duy nhất để đưa ra bất kỳ quyết định quan trọng nào trong đời sống.</p>

                    <h3 class="section-subtitle">3. Miễn Trừ Trách Nhiệm Về Trí Tuệ Nhân Tạo (Generative AI)</h3>
                    <p class="section-text">Phở Gõ Tarot tích hợp các công nghệ Trí tuệ nhân tạo (GenAI) hiện đại để cung cấp phản hồi và phân tích cá nhân hóa trong thời gian thực. Bạn hiểu và chấp nhận rằng:
                    <br>- Câu trả lời của AI có thể chứa lỗi logic, thông tin không chính xác hoặc các hiện tượng "ảo giác" (hallucinations) đặc trưng của mô hình ngôn ngữ lớn.
                    <br>- Hệ thống và ban quản trị không kiểm soát thủ công từng phản hồi của AI và không chịu bất kỳ trách nhiệm nào liên quan đến nội dung do AI tự động tạo ra.
                    <br>- AI không có cảm xúc, không có nhận thức tâm lý thực tế và không thể thay thế việc kết nối trực tiếp giữa người với người trong tư vấn tâm lý.</p>

                    <h3 class="section-subtitle">4. Không Thay Thế Lời Khuyên Của Chuyên Gia</h3>
                    <p class="section-text">Dịch vụ của chúng tôi hoàn toàn không thể thay thế cho các ý kiến chuyên môn từ những chuyên gia được cấp phép trong các lĩnh vực cụ thể. Phở Gõ Tarot đặc biệt tuyên bố miễn trừ mọi trách nhiệm tư vấn chuyên sâu:</p>
                    <ul class="section-list">
                        <li><strong>Sức khỏe & Tâm lý trị liệu:</strong> Chúng tôi không cung cấp dịch vụ khám bệnh, chẩn đoán, điều trị y tế hoặc tham vấn tâm lý trị liệu. Nếu bạn có bất kỳ vấn đề nào về sức khỏe thể chất hoặc tinh thần (bao gồm trầm cảm, lo âu kéo dài, ý định tự hại), hãy liên hệ ngay với bác sĩ, bệnh viện hoặc chuyên gia tâm lý có thẩm quyền.</li>
                        <li><strong>Tài chính, Đầu tư & Pháp lý:</strong> Mọi gợi ý hoặc phân tích liên quan đến tiền bạc, kinh doanh, sự nghiệp từ các lá bài hay Thần số học chỉ mang tính chiêm nghiệm. Chúng tôi không phải là chuyên gia tài chính, cố vấn đầu tư hay luật sư. Bạn tuyệt đối không được sử dụng thông tin từ website để thực hiện giao dịch tài chính hoặc đưa ra quyết định pháp lý.</li>
                    </ul>

                    <h3 class="section-subtitle">5. Chính Sách Nạp Credit & Nâng Cấp Premium (Tuyệt Đối Không Hoàn Tiền)</h3>
                    <p class="section-text">Hệ thống Phở Gõ Tarot vận hành theo mô hình Freemium (tặng lượt dùng thử miễn phí và cung cấp các gói trả phí). Khi bạn thực hiện nạp Credit (lượt xem) hoặc nâng cấp gói Premium, bạn hoàn toàn đồng ý rằng:
                    <br>- <strong>Tính chất sản phẩm:</strong> Credit và gói Premium nâng cấp là các sản phẩm nội dung số, dịch vụ phần mềm ảo, được tiêu dùng và kích hoạt sử dụng ngay lập tức sau khi giao dịch thành công.
                    <br>- <strong>Chính sách không hoàn tiền:</strong> Tất cả các giao dịch nạp Credit, nâng cấp gói dịch vụ hoặc mua sắm trên Phở Gõ Tarot là <strong>giao dịch cuối cùng, không thể hủy bỏ, không thể quy đổi ngược thành tiền mặt và tuyệt đối không được hoàn tiền</strong> dưới bất kỳ hình thức hoặc lý do nào (bao gồm cả trường hợp lỗi hệ thống tạm thời, gián đoạn kết nối, người dùng không hài lòng với kết quả xem bài, hoặc tài khoản bị khóa do vi phạm điều khoản dịch vụ).
                    <br>- <strong>Giá trị Credit:</strong> Credit không phải là tiền tệ, không có giá trị lưu hành thực tế bên ngoài hệ thống và không được bảo lãnh bởi bất kỳ tổ chức tài chính nào. Ban quản trị có toàn quyền điều chỉnh cơ cấu giá, số lượng Credit tiêu hao cho mỗi tính năng hoặc thu hồi các Credit lỗi/gian lận mà không cần báo trước.</p>

                    <h3 class="section-subtitle">6. Giới Hạn Trách Nhiệm Pháp Lý Tối Đa</h3>
                    <p class="section-text">Trong phạm vi tối đa được pháp luật hiện hành cho phép, Phở Gõ Tarot cùng những người điều hành, sáng lập, cộng tác viên và đối tác kỹ thuật của chúng tôi <strong>sẽ không phải chịu trách nhiệm</strong> đối với bất kỳ thiệt hại trực tiếp, gián tiếp, vô ý, đặc biệt, mang tính hệ quả hoặc trừng phạt nào (bao gồm nhưng không giới hạn ở: mất mát doanh thu, tổn thất tài chính, tổn thương tâm lý, rạn nứt quan hệ tình cảm, gián đoạn công việc hoặc bất kỳ thiệt hại phi vật chất nào khác) phát sinh trực tiếp hoặc gián tiếp từ việc sử dụng hoặc không thể sử dụng dịch vụ của website, bất kỳ nội dung sai sót nào được hiển thị, hoặc sự cố máy chủ, rò rỉ dữ liệu ngoài tầm kiểm soát của chúng tôi.
                    <br><br>Trong mọi trường hợp, nếu phát sinh tranh chấp pháp lý và cơ quan có thẩm quyền phán quyết Phở Gõ Tarot có lỗi, <strong>tổng mức trách nhiệm bồi thường thiệt hại cao nhất của chúng tôi đối với bạn sẽ chỉ giới hạn ở mức tối đa bằng số tiền thực tế bạn đã thanh toán cho Phở Gõ Tarot trong vòng ba mươi (30) ngày gần nhất</strong> trước khi xảy ra sự kiện dẫn đến yêu cầu bồi thường.</p>

                    <h3 class="section-subtitle">7. Điều Khoản Tự Do Ý Chí</h3>
                    <p class="section-text">Lá bài hay những con số Thần số học chỉ mở ra những hướng đi mang tính gợi mở để bạn tự soi chiếu nội tâm. Quyền tự quyết và Ý chí tự do (Free Will) hoàn toàn thuộc về bạn. Bạn đồng ý chịu trách nhiệm 100% đối với mọi hành vi, quyết định, và hệ quả xảy ra trong cuộc sống của mình sau khi tham khảo các thông tin tại Phở Gõ Tarot.</p>
                    
                    <p class="section-text" style="margin-top: 2rem; border-top: 1px solid var(--card-back-border); padding-top: 1.5rem; font-style: italic; font-weight: 600;">
                        Bằng cách tiếp tục duy trì tài khoản và sử dụng các tính năng trên website Phở Gõ Tarot, bạn xác nhận đã hoàn toàn hiểu rõ và tự nguyện chấp nhận toàn bộ các điều khoản miễn trừ trách nhiệm pháp lý nêu trên.
                    </p>
                </div>

            </div>
        </section>
    </main>
    
    <!-- Thêm JSON-LD schema vào <head> -->
    <script 
      type="application/ld+json" 
      slot="head"
      set:html={JSON.stringify(schema)}
    />

    <!-- Lấy các style cần thiết từ about-us.astro -->
    <style>
        .homepage-section { 
            padding: 4rem 1rem; 
            position: relative;
        }
        .container { 
            max-width: 1400px; 
            margin: auto; 
            padding: 0;
        }
        
        .section-title { 
            font-family: var(--font-title); 
            color: var(--title-color); 
            font-size: 3rem; 
            margin-bottom: 3rem; 
            text-align: center; /* Mặc định là center, nhưng bị override inline */
        }

        .section-subtitle { 
            font-family: var(--font-title); 
            color: var(--title-color); 
            font-size: 1.75rem;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .section-text { 
            font-size: 1rem;
            opacity: 0.9; 
            margin-bottom: 1.5rem; 
            text-shadow: none; 
            line-height: 1.8;
        }

        .text-content-container {
            max-width: 900px;
            padding: 0 1rem;
            text-align: left;
        }

        .section-list {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.8;
            margin-bottom: 1.5rem;
            padding-left: 2rem;
        }
        .section-list li {
            margin-bottom: 0.75rem;
        }

        /* Bỏ các style cho box */
    </style>
</BaseLayout>