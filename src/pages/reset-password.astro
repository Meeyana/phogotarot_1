---
import BaseLayout from '../layouts/BaseLayout.astro';

// Lấy token từ URL
const token = Astro.url.searchParams.get('token');

// Nếu đã đăng nhập, chuyển hướng sang trang chủ
if (Astro.locals.user) {
  return Astro.redirect('/');
}
---

<BaseLayout title="Đặt Lại Mật Khẩu - Phở Gõ Tarot" description="Nhập mật khẩu mới cho tài khoản của bạn" showChatbot={false}>
  <main class="auth-page">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <h1>Đặt Lại Mật Khẩu</h1>
          <p>Tạo mật khẩu mới an toàn hơn</p>
        </div>

        {token ? (
          <form id="reset-form" class="auth-form">
            <input type="hidden" name="token" value={token} />
            
            <div class="form-group">
              <label for="password">Mật khẩu mới</label>
              <input type="password" id="password" name="password" placeholder="Tối thiểu 6 ký tự" required minlength="6" />
            </div>

            <div class="form-group">
              <label for="confirm_password">Nhập lại mật khẩu</label>
              <input type="password" id="confirm_password" name="confirm_password" placeholder="Nhập lại để xác nhận" required minlength="6" />
            </div>

            <div id="error-message" class="error-message" style="display: none;"></div>
            <div id="success-message" class="success-message" style="display: none;"></div>

            <button type="submit" class="submit-btn" id="submit-btn">Đổi Mật Khẩu</button>
          </form>
        ) : (
          <div class="error-message" style="display: block;">
            Liên kết không hợp lệ hoặc không có mã xác thực (token). Vui lòng kiểm tra lại email.
          </div>
        )}

        <div class="auth-footer">
          <p><a href="/login">Quay lại đăng nhập</a></p>
        </div>
      </div>
    </div>
  </main>

  <script>
    const resetForm = document.getElementById('reset-form');
    const errorMessage = document.getElementById('error-message');
    const successMessage = document.getElementById('success-message');
    const submitBtn = document.getElementById('submit-btn');

    if (resetForm && errorMessage && successMessage && submitBtn) {
      resetForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMessage.style.display = 'none';
        successMessage.style.display = 'none';
        
        const formData = new FormData(resetForm as HTMLFormElement);
        const data = Object.fromEntries(formData.entries());

        if (data.password !== data.confirm_password) {
          errorMessage.innerText = 'Mật khẩu xác nhận không khớp!';
          errorMessage.style.display = 'block';
          return;
        }
        
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'Đang xử lý...';
        submitBtn.setAttribute('disabled', 'true');

        try {
          const res = await fetch('/api/auth/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if (!res.ok) {
            errorMessage.innerText = result.error || 'Đã có lỗi xảy ra.';
            errorMessage.style.display = 'block';
            submitBtn.innerText = originalText;
            submitBtn.removeAttribute('disabled');
          } else {
            successMessage.innerText = 'Đổi mật khẩu thành công! Đang chuyển hướng...';
            successMessage.style.display = 'block';
            setTimeout(() => {
              window.location.href = '/login';
            }, 1500);
          }
        } catch (error) {
          errorMessage.innerText = 'Lỗi kết nối. Vui lòng thử lại sau.';
          errorMessage.style.display = 'block';
          submitBtn.innerText = originalText;
          submitBtn.removeAttribute('disabled');
        }
      });
    }
  </script>

  <style>
    .auth-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 6rem 1rem 2rem 1rem;
      position: relative;
      z-index: 1;
    }
    
    .auth-container {
      width: 100%;
      max-width: 450px;
    }

    .auth-card {
      background: rgba(10, 15, 36, 0.7);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(242, 201, 76, 0.2);
      border-radius: 24px;
      padding: 3rem 2.5rem;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), 0 0 20px rgba(242, 201, 76, 0.1);
    }

    .auth-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .auth-header h1 {
      font-family: var(--font-title);
      color: var(--gold-color, #F2C94C);
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 15px rgba(242, 201, 76, 0.4);
    }

    .auth-header p {
      color: #aaa;
      font-size: 1rem;
      margin: 0;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      color: #ddd;
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
      font-weight: 500;
    }

    .form-group input {
      width: 100%;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: #fff;
      padding: 1rem 1.2rem;
      border-radius: 12px;
      font-size: 1rem;
      transition: all 0.3s ease;
      font-family: inherit;
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--gold-color, #F2C94C);
      box-shadow: 0 0 10px rgba(242, 201, 76, 0.2);
      background: rgba(0, 0, 0, 0.5);
    }

    .error-message {
      background: rgba(231, 76, 60, 0.1);
      color: #ff6b6b;
      border: 1px solid rgba(231, 76, 60, 0.3);
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      text-align: center;
    }

    .success-message {
      background: rgba(46, 204, 113, 0.1);
      color: #2ecc71;
      border: 1px solid rgba(46, 204, 113, 0.3);
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      text-align: center;
    }

    .submit-btn {
      width: 100%;
      background: linear-gradient(135deg, #D4AF37 0%, #F2C94C 50%, #FFD700 100%);
      color: #050A1F;
      border: none;
      padding: 1rem;
      border-radius: 12px;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }

    .submit-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 0 20px rgba(242, 201, 76, 0.6);
      background: linear-gradient(135deg, #FFF 0%, #FFD700 50%, #F2C94C 100%);
    }

    .submit-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    .auth-footer {
      margin-top: 2rem;
      text-align: center;
      font-size: 0.95rem;
      color: #aaa;
    }

    .auth-footer a {
      color: var(--gold-color, #F2C94C);
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .auth-footer a:hover {
      color: #fff;
      text-shadow: 0 0 10px rgba(242, 201, 76, 0.5);
    }
  </style>
</BaseLayout>
