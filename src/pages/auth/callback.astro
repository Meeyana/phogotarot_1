---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Đang xác thực..." description="Đang xử lý đăng nhập Google" showChatbot={false}>
  <main class="callback-page">
    <div class="callback-container">
      <div class="loader"></div>
      <h2>Đang đồng bộ tài khoản...</h2>
      <p>Vui lòng đợi trong giây lát, hệ thống đang kết nối bạn với vũ trụ Tarot.</p>
      <div id="error-message" class="error-message" style="display: none;"></div>
    </div>
  </main>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const errorMessage = document.getElementById('error-message');
    const runtimeEnv = {
      PUBLIC_SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL || '',
      PUBLIC_SUPABASE_ANON_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''
    };

    const supabase = createClient(runtimeEnv.PUBLIC_SUPABASE_URL, runtimeEnv.PUBLIC_SUPABASE_ANON_KEY);

    // Bắt sự kiện khi Supabase parse được token từ URL Hash
    supabase.auth.onAuthStateChange(async (event, session) => {
      if (event === 'SIGNED_IN' && session) {
        try {
          // Gửi token về backend để xác thực bảo mật và tạo phiên (Session) của riêng hệ thống D1
          const res = await fetch('/api/auth/sync', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ access_token: session.access_token })
          });

          const data = await res.json();
          if (res.ok && data.success) {
            window.location.href = '/'; // Đăng nhập thành công, về trang chủ
          } else {
            if (errorMessage) {
              errorMessage.style.display = 'block';
              errorMessage.innerText = data.error || 'Lỗi đồng bộ tài khoản.';
            }
          }
        } catch (error) {
          if (errorMessage) {
            errorMessage.style.display = 'block';
            errorMessage.innerText = 'Lỗi kết nối máy chủ.';
          }
        }
      }
    });

    // Nếu sau 5 giây không có event SIGNED_IN (vd user truy cập nhầm trang)
    setTimeout(() => {
      if (!errorMessage || errorMessage.style.display === 'block') return;
      supabase.auth.getSession().then(({ data }) => {
        if (!data.session) {
          errorMessage.style.display = 'block';
          errorMessage.innerText = 'Không tìm thấy phiên đăng nhập. Vui lòng thử lại.';
        }
      });
    }, 5000);
  </script>

  <style>
    .callback-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 6rem 1rem 2rem 1rem;
    }
    
    .callback-container {
      text-align: center;
      background: rgba(10, 15, 36, 0.7);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(242, 201, 76, 0.2);
      border-radius: 24px;
      padding: 3rem;
      max-width: 500px;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    }

    h2 {
      color: var(--gold-color, #F2C94C);
      font-family: var(--font-title);
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    p {
      color: #aaa;
    }

    .error-message {
      margin-top: 1rem;
      padding: 1rem;
      background: rgba(231, 76, 60, 0.1);
      color: #ff6b6b;
      border: 1px solid rgba(231, 76, 60, 0.3);
      border-radius: 8px;
    }

    .loader {
      border: 4px solid rgba(255, 255, 255, 0.1);
      border-left-color: var(--gold-color, #F2C94C);
      border-radius: 50%;
      width: 50px;
      height: 50px;
      animation: spin 1s linear infinite;
      margin: 0 auto;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>
</BaseLayout>
