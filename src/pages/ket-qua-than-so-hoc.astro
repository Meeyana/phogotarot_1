---
import BaseLayout from '../layouts/BaseLayout.astro';
import { 
    calculateLifePath, calculateDestiny, calculateSoul, 
    calculatePersonality, calculateAttitude, calculateMaturity, 
    calculateRationalThought, calculatePyramid, calculateChartData,
    calculatePeriodCycles, calculateKarmicDebt, calculateKarmicLessons,
    calculatePersonalityPercentages, calculateCareerPercentages,
    calculateForecast
} from '../utils/numerology';

// Import Data Access Layer
import * as numData from '../utils/numerology-data';

// Import components
import NumerologyPyramid from '../components/NumerologyPyramid.astro';
import NumerologyCTA from '../components/NumerologyCTA.astro';
import LifePathSection from '../components/numerology/LifePathSection.astro';
import CoreStatsSection from '../components/numerology/CoreStatsSection.astro';
import ChartGridSection from '../components/numerology/ChartGridSection.astro';
import KarmicSection from '../components/numerology/KarmicSection.astro';
import PeriodCyclesSection from '../components/numerology/PeriodCyclesSection.astro';
import ForecastSection from '../components/numerology/ForecastSection.astro';
import PersonalityCareerSection from '../components/numerology/PersonalityCareerSection.astro';
import PyramidSection from '../components/numerology/PyramidSection.astro';
import UnlockBanner from '../components/numerology/UnlockBanner.astro';
import '../styles/ket-qua-than-so-hoc.css';
import { getDB } from '../db';
import { hasUnlockedProfile } from '../lib/auth';

// 1. Lấy tham số URL
const url = Astro.url;
const fullName = url.searchParams.get('name') || "Bạn Mình";
const dobStr = url.searchParams.get('dob') || "2000-01-01";
const nickname = url.searchParams.get('nickname') || "";
const gender = url.searchParams.get('gender') || "";

// KIỂM TRA QUYỀN TRUY CẬP (PAYWALL)
const user = Astro.locals.user;

// Bảo vệ route: Nếu chưa đăng nhập thì đẩy ra trang đăng nhập
if (!user) {
    return Astro.redirect(`/login?redirect=${encodeURIComponent(url.pathname + url.search)}`);
}

let isPremium = false;
let hasUnlocked = false;
const profileId = `${fullName.toLowerCase().trim()}|${dobStr}|${nickname.toLowerCase().trim()}|${gender.toLowerCase().trim()}`;

if (user) {
    const rawDB = Astro.locals.runtime?.env?.DB || process.env.DB;
    if (user.premiumUntil && user.premiumUntil.getTime() > Date.now()) {
        isPremium = true;
    } else if (rawDB) {
        // Tự động tạo bảng nếu chưa có (fix lỗi no such table trên local D1)
        try {
            await rawDB.prepare(`CREATE TABLE IF NOT EXISTS unlocked_numerology_profiles (id TEXT PRIMARY KEY, user_id TEXT NOT NULL, profile_id TEXT NOT NULL, unlocked_at INTEGER DEFAULT CURRENT_TIMESTAMP)`).run();
        } catch (e) {
            console.error('Lỗi khi tạo bảng:', e);
        }
        hasUnlocked = await hasUnlockedProfile(rawDB, user.id, profileId, `${fullName.toLowerCase().trim()}|${dobStr}`);
    }
}

const isLocked = !isPremium && !hasUnlocked;

// 2. Xử lý ngày sinh
const [yStr, mStr, dStr] = dobStr.split('-');
const day = parseInt(dStr);
const month = parseInt(mStr);
const year = parseInt(yStr);
const formattedDob = `${day}/${month}/${year}`;

// 3. Tính toán toàn bộ chỉ số (SSR)
const lifePath = calculateLifePath(day, month, year);
const destiny = calculateDestiny(fullName);
const soul = calculateSoul(fullName);
const personality = calculatePersonality(fullName);
const attitude = calculateAttitude(day, month);
const maturity = calculateMaturity(lifePath, destiny);
const rational = calculateRationalThought(day, destiny);
const pyramid = calculatePyramid(day, month, year, lifePath);
const chartData = calculateChartData(day, month, year, fullName, nickname);
const periodCycles = calculatePeriodCycles(day, month, year, lifePath);
const karmicDebts = calculateKarmicDebt(day, month, year, fullName);
const karmicLessons = calculateKarmicLessons(fullName);
const personalityStats = calculatePersonalityPercentages(chartData.strengthData, chartData.nameData, lifePath, destiny, soul, personality);
const careerStats = calculateCareerPercentages(day, month, year, fullName, nickname, lifePath, destiny, soul);
const forecast = calculateForecast(day, month);

const renderCell = (number: number, countsArray: number[]) => {
    const count = countsArray[number - 1];
    if (!count || count === 0) return '';
    return String(number).repeat(count);
};

// 4. Chuẩn bị data map cho CoreStatsSection
const coreStatsDataMap = {
  destiny: numData.getDestinyData(destiny),
  soul: numData.getSoulData(soul),
  personality: numData.getPersonalityData(personality),
  attitude: numData.getAttitudeData(attitude),
  maturity: numData.getMaturityData(maturity),
  rational: numData.getRationalData(rational)
};

// Chuẩn bị data cho ChartGridSection
const strengthDataStore: Record<number, any> = {};
chartData.strengthData.forEach((count: number, index: number) => {
  if (count > 0) strengthDataStore[index + 1] = numData.getGridData('strengthGrid', index + 1);
});
const synthesisDataStore: Record<number, any> = {};
chartData.synthesisData.forEach((count: number, index: number) => {
  if (count > 0) synthesisDataStore[index + 1] = numData.getGridData('synthesisGrid', index + 1);
});

// Chuẩn bị mũi tên
const arrowStore: Record<string, any> = {};
const mapArrows = (arrowList: any[], chartType: 'strength' | 'synthesis') => {
  if (!arrowList) return;
  arrowList.forEach(arrow => {
    if (!arrowStore[arrow.id]) arrowStore[arrow.id] = {};
    arrowStore[arrow.id][arrow.type] = numData.getArrowData(chartType, arrow.id, arrow.type);
  });
};
mapArrows(chartData.strengthArrows, 'strength');
mapArrows(chartData.synthesisArrows, 'synthesis');

// Chuẩn bị số thiếu
const missingStore: Record<number, any> = {};
const mapMissing = (missingList: number[], chartType: 'strength' | 'synthesis') => {
  if (!missingList) return;
  missingList.forEach(num => {
    missingStore[num] = numData.getMissingNumberData(chartType, num);
  });
};
mapMissing(chartData.strengthMissingNums, 'strength');
mapMissing(chartData.synthesisMissingNums, 'synthesis');

// Chuẩn bị chu kỳ
const cyclesDataStore: Record<number, any> = {
  [periodCycles.c1.number]: numData.getPeriodCycleData(periodCycles.c1.number),
  [periodCycles.c2.number]: numData.getPeriodCycleData(periodCycles.c2.number),
  [periodCycles.c3.number]: numData.getPeriodCycleData(periodCycles.c3.number)
};

// Chuẩn bị dự báo
const yearDataStore: Record<number, any> = {};
forecast.years.forEach((y: any) => yearDataStore[y.number] = numData.getForecastYearData(y.number));
const monthDataStore: Record<number, any> = {};
forecast.months.forEach((m: any) => monthDataStore[m.number] = numData.getForecastMonthData(m.number));

// Chuẩn bị pyramid data store
const pyramidDataStore = {
  peaks: {
    [pyramid.peaks.p1]: numData.getPyramidData('peaks', pyramid.peaks.p1),
    [pyramid.peaks.p2]: numData.getPyramidData('peaks', pyramid.peaks.p2),
    [pyramid.peaks.p3]: numData.getPyramidData('peaks', pyramid.peaks.p3),
    [pyramid.peaks.p4]: numData.getPyramidData('peaks', pyramid.peaks.p4)
  },
  challenges: {
    [pyramid.challenges.c1]: numData.getPyramidData('challenges', pyramid.challenges.c1),
    [pyramid.challenges.c2]: numData.getPyramidData('challenges', pyramid.challenges.c2),
    [pyramid.challenges.c3]: numData.getPyramidData('challenges', pyramid.challenges.c3),
    [pyramid.challenges.c4]: numData.getPyramidData('challenges', pyramid.challenges.c4)
  }
};

const pageTitle = `Hồ Sơ: ${fullName}`;
---

<BaseLayout title={pageTitle} showChatbot={false}>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>
    <script is:inline src="/js/numerology-charts.js"></script>

    {/* Inline script inject data for charts */}
    <script define:vars={{
      personalityStats,
      careerStats,
      day,
      month
    }}>
      window.__NUMEROLOGY_DATA__ = {
        personalityStats,
        careerStats,
        day,
        month
      };
    </script>
    <script is:inline src="/js/numerology-result.js"></script>

    <div id="stars-bg"></div>

    <main id="homepage-content">
        <section class="homepage-section">
            <div class="container">
                
                <header class="report-header mb-12 fade-in" style="text-align:center;margin-bottom:2rem;">
                    <h2 class="hero-title-small">{fullName.toUpperCase()}</h2>
                    <div class="info-badges" style="justify-content:center;">
                        <div class="badge-item">
                            <span class="badge-label">Ngày sinh:</span>
                            <span class="badge-value">{formattedDob}</span>
                        </div>
                        {nickname && (
                            <div class="badge-item">
                                <span class="badge-label">Biệt danh:</span>
                                <span class="badge-value">{nickname}</span>
                            </div>
                        )}
                    </div>
                </header>

                <div class="chart-section fade-in-up">
                    <div class="hero-numerology mb-0">
                        <div class="mandala-wrapper">
                            <div class="mandala-ring ring-1"></div>
                            <div class="mandala-ring ring-2"></div>
                            <div class="mandala-ring ring-3"></div>
                            <div class="main-number-box">
                                <span class="label-hero">SỐ CHỦ ĐẠO</span>
                                <span class="number-hero text-gold">{lifePath}</span>
                            </div>
                        </div>
                    </div>
              
                    <div class="sub-grid-container fade-in-up mt-8 mb-12">
                        <div class="glass-card sub-card">
                            <span class="sub-label">Sứ Mệnh</span><span class="sub-val">{destiny}</span>
                        </div>
                        <div class="glass-card sub-card">
                            <span class="sub-label">Linh Hồn</span><span class="sub-val">{soul}</span>
                        </div>
                        <div class="glass-card sub-card">
                            <span class="sub-label">Nhân Cách</span><span class="sub-val">{personality}</span>
                        </div>
                        <div class="glass-card sub-card">
                            <span class="sub-label">Thái Độ</span><span class="sub-val">{attitude}</span>
                        </div>
                        <div class="glass-card sub-card">
                            <span class="sub-label">Tư Duy</span><span class="sub-val">{rational}</span>
                        </div>
                        <div class="glass-card sub-card">
                            <span class="sub-label">Trưởng Thành</span><span class="sub-val">{maturity}</span>
                        </div>
                    </div>

                    <div class="main-section-title text-center mb-8 fade-in-up">
                        <h2 class="text-2xl md:text-3xl font-bold text-gold uppercase tracking-wider head-outline">I. Nền Tảng Cốt Lõi</h2>
                        <div class="w-24 h-1 bg-gold mx-auto mt-2 opacity-50"></div>
                    </div>
                    
                    <div class="max-w-4xl mx-auto rich-text-content mt-8">
                        <LifePathSection lifePath={lifePath} data={numData.getLifePathData(lifePath)} />
                    </div>
                </div>

                <CoreStatsSection stats={[
                    { key: 'destiny', label: 'Số Sứ Mệnh', value: destiny },
                    { key: 'soul', label: 'Số Linh Hồn', value: soul },
                    { key: 'personality', label: 'Số Nhân Cách', value: personality },
                    { key: 'attitude', label: 'Số Thái Độ', value: attitude },
                    { key: 'rational', label: 'Số Tư Duy', value: rational },
                    { key: 'maturity', label: 'Số Trưởng Thành', value: maturity }
                ]} dataMap={coreStatsDataMap} />

                <div class="divider-section"></div>

                <div class="main-section-title text-center mb-8 fade-in-up">
                    <h2 class="text-2xl md:text-3xl font-bold text-gold uppercase tracking-wider head-outline">II. Biểu Đồ & Cấu Trúc</h2>
                    <div class="w-24 h-1 bg-gold mx-auto mt-2 opacity-50"></div>
                </div>

                <div class="chart-section fade-in-up">
                    <div class="section-header text-center mb-8">
                        <h3 class="section-subtitle">Biểu Đồ Ngày Sinh</h3>
                        <p class="section-text opacity-70">Sức mạnh bẩm sinh của bạn qua các con số</p>
                    </div>
        
                    <div class="single-chart-layout">
                        <div class="chart-card glass-card chart-container mx-auto" id="strength-grid-source">
                            <div class="numerology-grid">
                                <div class="grid-cell">{renderCell(3, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(6, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(9, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(2, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(5, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(8, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(1, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(4, chartData.strengthData)}</div>
                                <div class="grid-cell">{renderCell(7, chartData.strengthData)}</div>
                            </div>
                        </div>
                        <div class="interpretations-container mt-8 rich-text-content">
                            <ChartGridSection chartType="strength" countsArray={chartData.strengthData} arrowsList={chartData.strengthArrows} missingList={chartData.strengthMissingNums} dataStore={strengthDataStore} arrowStore={arrowStore} missingStore={missingStore} />
                        </div>
                    </div>
                </div>

                <div class="chart-section fade-in-up mt-12">
                    <div class="section-header text-center mb-8">
                        <h3 class="section-subtitle">Biểu Đồ Tên & Tổng Hợp</h3>
                        <p class="section-text opacity-70">Sự kết hợp giữa năng lực tự nhiên và cái tên của bạn</p>
                    </div>
                    <div class="dual-charts-wrapper">
                        <div class="chart-column">
                            <div class="chart-card glass-card chart-container" id="name-grid-source">
                                <h4 class="text-center text-gold mb-2 text-lg uppercase">Biểu Đồ Tên</h4>
                                <p class="text-center text-sm opacity-70 mb-4">
                                    (Sử dụng: <span class="text-gold font-bold">{chartData.usedName.toUpperCase()}</span>)
                                </p>
                                <div class="numerology-grid">
                                    <div class="grid-cell">{renderCell(3, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(6, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(9, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(2, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(5, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(8, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(1, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(4, chartData.nameData)}</div>
                                    <div class="grid-cell">{renderCell(7, chartData.nameData)}</div>
                                </div>
                            </div>
                        </div>
    
                        <div class="chart-column">
                            <div class="chart-card glass-card chart-container" id="synthesis-grid-source">
                                <h4 class="text-center text-gold mb-6 text-lg uppercase">Biểu Đồ Tổng Hợp</h4>
                                <div class="numerology-grid">
                                    <div class="grid-cell text-synthesis">{renderCell(3, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(6, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(9, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(2, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(5, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(8, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(1, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(4, chartData.synthesisData)}</div>
                                    <div class="grid-cell text-synthesis">{renderCell(7, chartData.synthesisData)}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                   
                    <div class="interpretations-container max-w-4xl mx-auto rich-text-content">
                        <ChartGridSection chartType="synthesis" countsArray={chartData.synthesisData} arrowsList={chartData.synthesisArrows} missingList={chartData.synthesisMissingNums} dataStore={synthesisDataStore} arrowStore={arrowStore} missingStore={missingStore} isLocked={isLocked} />
                    </div>
                </div>

                <NumerologyPyramid pyramid={pyramid} day={day} month={month} year={year} />

                <div class="max-w-4xl mx-auto rich-text-content mt-8">
                    <PyramidSection pyramidInfo={pyramid} pyramidDataStore={pyramidDataStore} isLocked={isLocked} />
                </div>

                <KarmicSection debts={karmicDebts} lessons={karmicLessons} debtDataStore={karmicDebts.reduce((acc, curr) => ({...acc, [curr]: numData.getKarmicDebtData(curr)}), {} as Record<number,any>)} lessonDataStore={karmicLessons.reduce((acc, curr) => ({...acc, [curr]: numData.getKarmicLessonData(curr)}), {} as Record<number,any>)} isLocked={isLocked} />

                <div class="divider-section"></div>

                <div class="main-section-title text-center mb-8 fade-in-up">
                    <h2 class="text-2xl md:text-3xl font-bold text-gold uppercase tracking-wider head-outline">III. Nhóm Tính Cách & Định Hướng</h2>
                    <div class="w-24 h-1 bg-gold mx-auto mt-2 opacity-50"></div>
                </div>

                <PersonalityCareerSection personalityStats={personalityStats} careerStats={careerStats} pData={numData.getPersonalityChartData()} cData={numData.getCareerChartData()} isLocked={isLocked} />

                <div class="divider-section"></div>

                <div class="main-section-title text-center mb-8 fade-in-up">
                    <h2 class="text-2xl md:text-3xl font-bold text-gold uppercase tracking-wider head-outline">IV. Dòng Thời Gian – Chu Kỳ Vận Động</h2>
                    <div class="w-24 h-1 bg-gold mx-auto mt-2 opacity-50"></div>
                </div>

                <div class="chart-section fade-in-up">
                    <div class="section-header text-center mb-8">
                        <h3 class="section-subtitle">Chu Kỳ Đường Đời</h3>
                        <p class="section-text opacity-70">3 Giai đoạn phát triển chính của cuộc đời bạn</p>
                    </div>
                    
                    <div class="interpretations-container max-w-4xl mx-auto rich-text-content">
                        <PeriodCyclesSection periodCycles={periodCycles} cyclesDataStore={cyclesDataStore} isLocked={isLocked} />
                    </div>
                </div>

                 <div class="chart-section fade-in-up mt-12">
                     <div class="section-header text-center">
                        <h3 class="section-subtitle">Chu Kỳ Vận Số 9 Năm</h3>
                         <p class="section-text opacity-70 mb-6">Biểu đồ sóng năng lượng cá nhân</p>
                    </div>
                    <div class="chart-card glass-card" id="wave-chart-source">
                        <div class="chart-wrapper">
                            <canvas id="personalYearChart"></canvas>
                        </div>
                        <div class="current-year-note mt-4 text-center" style="margin-top: 1rem;">
                            <span class="icon text-gold">✦</span> Năm hiện tại của bạn: Số <strong id="current-year-display" class="text-gold text-xl">...</strong>
                        </div>
                    </div>
                </div>

                <ForecastSection forecastYears={forecast.years} forecastMonths={forecast.months} yearDataStore={yearDataStore} monthDataStore={monthDataStore} isLocked={isLocked} />
                
                {isLocked && <UnlockBanner fullName={fullName} dobStr={dobStr} nickname={nickname} gender={gender} currentCredit={user?.credits || 0} />}

            </div> 
        </section> 
    </main>
    
    <div id="toc-container" class="toc-wrapper">
        <button id="toc-toggle" class="toc-btn" aria-label="Mục lục">
            <i class="fas fa-list-ol"></i>
        </button>
        
        <nav id="toc-content" class="toc-dropdown">
            <div class="toc-header-title">Mục Lục Báo Cáo</div>
            <ul id="toc-list"></ul>
        </nav>
    </div>

    <div class="divider-section"></div>

    <NumerologyCTA />

</BaseLayout>