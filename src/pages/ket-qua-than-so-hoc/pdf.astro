---
import PdfContentBlock from '../../components/numerology/pdf/PdfContentBlock.astro';
import { buildNumerologyReport, getNumerologyProfileId } from '../../lib/numerology-report';
import { hasUnlockedProfile } from '../../lib/auth';
import { numerologyDefinitions } from '../../data/numerology-definitions';

export const prerender = false;

const url = Astro.url;
const fullName = url.searchParams.get('name') || 'Bạn Mình';
const dobStr = url.searchParams.get('dob') || '2000-01-01';
const nickname = url.searchParams.get('nickname') || '';
const gender = url.searchParams.get('gender') || '';
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(url.pathname + url.search)}`);
}

const profileId = getNumerologyProfileId({ fullName, dobStr, nickname, gender });
const legacyProfileId = `${fullName.toLowerCase().trim()}|${dobStr}`;
const rawDB = Astro.locals.runtime?.env?.DB || process.env.DB;
let isPremium = false;
let hasUnlocked = false;

if (user.premiumUntil && user.premiumUntil.getTime() > Date.now()) {
  isPremium = true;
} else if (rawDB) {
  try {
    await rawDB.prepare(`CREATE TABLE IF NOT EXISTS unlocked_numerology_profiles (id TEXT PRIMARY KEY, user_id TEXT NOT NULL, profile_id TEXT NOT NULL, unlocked_at INTEGER DEFAULT CURRENT_TIMESTAMP)`).run();
  } catch (e) {
    console.error('Không thể kiểm tra bảng mở khóa thần số học:', e);
  }
  hasUnlocked = await hasUnlockedProfile(rawDB, user.id, profileId, legacyProfileId);
}

const isLocked = !isPremium && !hasUnlocked;

if (isLocked) {
  return new Response('PDF chi kha dung sau khi ho so than so hoc da duoc mo khoa.', {
    status: 403,
    headers: {
      'content-type': 'text/plain; charset=utf-8'
    }
  });
}

const report = await buildNumerologyReport({ fullName, dobStr, nickname, gender });
const { input, numbers, chartData, pyramid, periodCycles, karmicDebts, karmicLessons, personalityStats, careerStats, forecast, content } = report;
const generatedAt = new Date().toLocaleDateString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', day: '2-digit', month: '2-digit', year: 'numeric' });
const topTraits = [...personalityStats].sort((a, b) => b.percent - a.percent).slice(0, 3);
const topCareer = [...careerStats].sort((a, b) => b.percent - a.percent).slice(0, 3);
const yearRelationLabels = ['Năm trước', 'Hiện tại', 'Năm tới'];

const renderCell = (number: number, countsArray: number[]) => {
  const count = countsArray[number - 1];
  if (!count || count === 0) return '';
  return String(number).repeat(count);
};

const tocGroupsSource = [
  {
    title: 'I. NỀN TẢNG CỐT LÕI',
    items: [
      `Số chủ đạo của bạn: Số ${numbers.lifePath}`,
      `Số Sứ Mệnh của bạn: Số ${numbers.destiny}`,
      `Số Linh Hồn của bạn: Số ${numbers.soul}`,
      `Số Nhân Cách của bạn: Số ${numbers.personality}`,
      `Số Thái Độ của bạn: Số ${numbers.attitude}`,
      `Số Tư Duy của bạn: Số ${numbers.rational}`,
      `Số Trưởng Thành của bạn: Số ${numbers.maturity}`
    ]
  },
  {
    title: 'II. BIỂU ĐỒ & CẤU TRÚC',
    items: ['Biểu Đồ Ngày Sinh', 'Biểu Đồ Tên & Tổng Hợp', 'Kim Tự Tháp Thần Số', 'Chỉ Số Nợ Nghiệp', 'Bài Học Đường Đời (Điểm Yếu)']
  },
  {
    title: 'III. NHÓM TÍNH CÁCH & ĐỊNH HƯỚNG',
    items: ['Nhóm Tính Cách Bản Ngã', 'Tỉ Lệ Nhóm Ngành Phù Hợp']
  },
  {
    title: 'IV. DÒNG THỜI GIAN - CHU KỲ VẬN ĐỘNG',
    items: ['Chu Kỳ Đường Đời', 'Chu Kỳ Vận Số 9 Năm', 'Dự Báo Năm Cá Nhân', 'Dự Báo Tháng Cá Nhân']
  }
];

let tocIndex = 0;
const tocGroups = tocGroupsSource.map((group) => ({
  ...group,
  items: group.items.map((label) => ({ number: ++tocIndex, label }))
}));

const coreContent = [
  ['Số Sứ Mệnh', numbers.destiny, content.coreStatsDataMap.destiny, numerologyDefinitions.destiny, isLocked],
  ['Số Linh Hồn', numbers.soul, content.coreStatsDataMap.soul, numerologyDefinitions.soul, isLocked],
  ['Số Nhân Cách', numbers.personality, content.coreStatsDataMap.personality, numerologyDefinitions.personality, false],
  ['Số Thái Độ', numbers.attitude, content.coreStatsDataMap.attitude, numerologyDefinitions.attitude, false],
  ['Số Tư Duy', numbers.rational, content.coreStatsDataMap.rational, numerologyDefinitions.rational, isLocked],
  ['Số Trưởng Thành', numbers.maturity, content.coreStatsDataMap.maturity, numerologyDefinitions.maturity, isLocked]
];

const cycleList = [
  { id: 1, label: 'Gieo Hạt', data: periodCycles.c1 },
  { id: 2, label: 'Chín', data: periodCycles.c2 },
  { id: 3, label: 'Thu Hoạch', data: periodCycles.c3 }
];

const makeTextData = (text: string) => ({ blocks: [{ type: 'text', content: text }] });
const fallbackPersonalityMeanings: Record<string, any> = {
  1: makeTextData('Bạn nổi bật với tinh thần độc lập, khả năng tự quyết và xu hướng chủ động dẫn dắt tình huống. Khi năng lượng này cân bằng, bạn dễ trở thành người mở đường, dám chịu trách nhiệm và truyền cảm hứng bằng sự tự tin. Bài học quan trọng là mềm lại khi cần, lắng nghe người khác và tránh biến sự quyết đoán thành áp đặt.'),
  2: makeTextData('Bạn có thế mạnh về sự tinh tế, khả năng lắng nghe và cảm nhận bầu không khí xung quanh. Đây là nhóm tính cách giúp bạn kết nối, hòa giải và nhận ra những chi tiết cảm xúc mà người khác dễ bỏ qua. Điều cần rèn là giữ ranh giới cá nhân, tránh chiều lòng quá mức hoặc để cảm xúc bên ngoài kéo mình dao động.'),
  3: makeTextData('Bạn mang màu sắc sáng tạo, hoạt bát và có khả năng biểu đạt tốt. Khi được đặt trong môi trường phù hợp, bạn dễ lan tỏa sự vui vẻ, ý tưởng mới và tinh thần lạc quan. Bài học là duy trì kỷ luật, hoàn thành đến cùng và không để sự hứng khởi ban đầu bị phân tán quá nhanh.'),
  4: makeTextData('Bạn thiên về sự thực tế, cẩn trọng và thích xây dựng mọi thứ theo nền tảng chắc chắn. Đây là nhóm tính cách mạnh về tổ chức, quy trình và độ tin cậy. Mặt cần cân bằng là giảm cầu toàn, linh hoạt hơn trước thay đổi và cho bản thân quyền thử nghiệm thay vì luôn phải chắc chắn tuyệt đối.'),
  5: makeTextData('Bạn có nhu cầu trải nghiệm, học nhanh và thích sự linh hoạt. Nhóm năng lượng này giúp bạn thích nghi tốt, tò mò và dễ nhìn thấy nhiều lựa chọn trong một vấn đề. Bài học là chọn trọng tâm, tránh ôm quá nhiều hướng cùng lúc và biến sự tự do thành năng lực hành động có định hướng.'),
  6: makeTextData('Bạn có xu hướng quan tâm, bảo vệ và đặt trách nhiệm với người thân hoặc cộng đồng lên cao. Đây là nhóm tính cách giàu tình cảm, đáng tin và có khả năng tạo cảm giác an toàn. Điều cần lưu ý là tránh gánh thay phần của người khác, học cách chăm sóc chính mình trước khi tiếp tục cho đi.'),
  7: makeTextData('Bạn thiên về chiều sâu, quan sát, phân tích và tìm kiếm bản chất phía sau sự việc. Nhóm tính cách này phù hợp với học hỏi, nghiên cứu và những không gian cần sự tập trung. Bài học là chia sẻ nhiều hơn, tránh khép kín quá lâu và cho phép trực giác đi cùng lý trí.'),
  8: makeTextData('Bạn có năng lượng kỷ luật, định hướng kết quả và cảm quan mạnh về công bằng, hiệu quả. Khi phát huy tốt, bạn biết quản trị nguồn lực, đặt mục tiêu rõ và kiên trì với tiêu chuẩn cao. Điều cần cân bằng là mềm mỏng trong giao tiếp, không quá kiểm soát và nhớ rằng thành công bền vững cần cả con người lẫn kết quả.'),
  9: makeTextData('Bạn có màu sắc bao dung, lý tưởng và dễ nhìn vấn đề bằng góc nhìn rộng. Nhóm tính cách này giúp bạn thấu hiểu, truyền cảm hứng và quan tâm đến giá trị lớn hơn lợi ích trước mắt. Bài học là thực tế hóa lý tưởng, tránh ôm nỗi niềm của quá nhiều người và giữ năng lượng cho chính mình.')
};

const fallbackCareerMeanings: Record<string, any> = {
  management: makeTextData('Bạn phù hợp với các vai trò cần định hướng, ra quyết định, phát triển kinh doanh hoặc dẫn dắt đội nhóm. Nhóm này phát huy tốt khi bạn có quyền chủ động, mục tiêu rõ và không gian để biến ý tưởng thành kết quả. Hãy ưu tiên môi trường có lộ trình tăng trưởng, đo lường hiệu quả minh bạch và cho phép bạn chịu trách nhiệm thực sự.'),
  business: makeTextData('Bạn hợp với các công việc cần sự ổn định, quy trình, số liệu, vận hành, hành chính, tài chính hoặc quản trị chi tiết. Điểm mạnh của nhóm này là tính cẩn thận, khả năng duy trì hệ thống và làm việc đáng tin cậy. Môi trường phù hợp là nơi có cấu trúc rõ, tiêu chuẩn cụ thể và ghi nhận sự bền bỉ.'),
  technical: makeTextData('Bạn có độ phù hợp cao với nhóm kỹ thuật, công nghệ, vận hành thực tế, công cụ, dữ liệu hoặc các công việc cần tư duy xử lý vấn đề. Nhóm này cần không gian để đào sâu, thử nghiệm và nhìn thấy kết quả cụ thể. Bạn nên chọn môi trường coi trọng năng lực thật, tính logic và khả năng cải tiến liên tục.'),
  research: makeTextData('Bạn phù hợp với các hướng nghiên cứu, phân tích, giáo dục, tư vấn chuyên sâu, dữ liệu hoặc những lĩnh vực cần đào sâu bản chất. Điểm mạnh là khả năng quan sát, tìm mẫu hình và kiên nhẫn với vấn đề phức tạp. Môi trường tốt nhất là nơi tôn trọng chiều sâu, thời gian suy nghĩ và chất lượng chuyên môn.'),
  social: makeTextData('Bạn hợp với các công việc liên quan đến con người như chăm sóc khách hàng, đào tạo, nhân sự, tư vấn, cộng đồng, chữa lành hoặc dịch vụ hỗ trợ. Nhóm này phát huy khi bạn được kết nối, lắng nghe và tạo giá trị trực tiếp cho người khác. Cần lưu ý giữ ranh giới để không bị tiêu hao cảm xúc.'),
  artistic: makeTextData('Bạn phù hợp với các lĩnh vực sáng tạo, truyền thông, nội dung, nghệ thuật, thiết kế, biểu đạt cá nhân hoặc những công việc cần ý tưởng mới. Nhóm này cần không gian tự do và cảm hứng, nhưng vẫn nên đi cùng deadline rõ ràng để ý tưởng thành sản phẩm. Môi trường lý tưởng là nơi tôn trọng cá tính và cho phép thử nghiệm.')
};

const getPersonalityMeaning = (id: string | number) => content.personalityChart?.meanings?.[id] || fallbackPersonalityMeanings[String(id)];
const getCareerMeaning = (id: string) => content.careerChart?.meanings?.[id] || fallbackCareerMeanings[id];
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PDF Thần Số Học - {input.fullName}</title>
    <style>
      :root {
        --ink: #1f2633;
        --muted: #667085;
        --gold: #c7972f;
        --navy: #0b132b;
        --line: #e8dcc4;
        --paper: #fffaf0;
        --soft: #f7efe0;
      }

      * { box-sizing: border-box; }
      html { background: #ece6d8; color: var(--ink); font-family: "Times New Roman", Arial, serif; }
      body { margin: 0; counter-reset: page; }
      .toolbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        justify-content: center;
        gap: 12px;
        padding: 12px;
        background: rgba(11, 19, 43, 0.92);
      }
      .toolbar a,
      .toolbar button {
        border: 1px solid rgba(255,255,255,0.24);
        border-radius: 6px;
        padding: 10px 14px;
        background: transparent;
        color: #fff;
        font: 700 14px Arial, sans-serif;
        text-decoration: none;
        cursor: pointer;
      }
      .toolbar button.primary {
        background: var(--gold);
        border-color: var(--gold);
        color: #111827;
      }

      .report {
        width: 210mm;
        margin: 18px auto;
        background: var(--paper);
        box-shadow: 0 14px 40px rgba(31, 38, 51, 0.18);
      }
      .page {
        position: relative;
        padding: 28mm 24mm 34mm;
        border: 1px solid var(--line);
        page-break-before: always;
        overflow: visible;
      }
      .page:first-child {
        page-break-before: auto;
      }
      .page::before {
        content: "";
        position: absolute;
        inset: 10mm;
        border: 1px solid rgba(199, 151, 47, 0.45);
        pointer-events: none;
      }
      .page::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 350px;
        height: 350px;
        background-image: url('/images/logo-l.png');
        background-repeat: no-repeat;
        background-position: center center;
        background-size: contain;
        opacity: 0.08;
        pointer-events: none;
        z-index: 0;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page-content { position: relative; z-index: 1; }
      .cover::after {
        display: none !important;
      }
      .cover {
        min-height: 297mm;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        text-align: center;
        page-break-after: always;
        background: url('/images/cover-artwork.png') center center / cover no-repeat;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        color: #0b132b;
        padding: 20mm;
      }
      .cover .page-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        margin: auto 0;
        z-index: 2;
      }
      .brand-logo { width: 110px; height: auto; margin-bottom: 24px; }
      .cover-title { margin: 0 0 20px; font-size: 52px; line-height: 1.1; letter-spacing: 0; font-weight: bold; text-transform: uppercase; color: #0b132b; }
      .cover-name { color: #0b132b; font-size: 28px; line-height: 1.25; text-transform: uppercase; font-weight: bold; margin-bottom: 30px; }
      .cover-meta { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 10mm; width: 100%; max-width: 420px; text-align: left; }
      .meta-box { padding: 10px 0; background: transparent; border: none; border-bottom: 1px solid rgba(11,19,43,0.15); }
      .meta-label { display: block; color: rgba(11,19,43,0.7); font: 400 12px Arial, sans-serif; text-transform: uppercase; }
      .meta-value { display: block; margin-top: 6px; font-size: 18px; color: #0b132b; font-weight: bold; }
      .cover-note { color: rgba(11,19,43,0.5); font: 12px/1.6 Arial, sans-serif; max-width: 140mm; margin: 0 auto; padding-bottom: 10mm; z-index: 2; }
      
      .back-cover {
        min-height: 297mm;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: url('/images/cover-artwork.png') center bottom / cover no-repeat;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        color: #0b132b;
        padding: 40mm 20mm;
        page-break-before: always;
      }
      .back-cover .page-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        max-width: 500px;
        z-index: 2;
      }
      .back-cover-body h2 { color: #0b132b; font-size: 32px; line-height: 1.3; margin-bottom: 20px; font-weight: bold; }
      .back-cover-body p { color: rgba(11,19,43,0.85); font-size: 15px; line-height: 1.6; margin-bottom: 30px; }
      .cta-box { background: transparent; border: 1px solid rgba(11,19,43,0.3); border-radius: 8px; padding: 30px; margin: 40px 0; }
      .cta-box h3 { color: #0b132b; font-size: 22px; margin-top: 0; margin-bottom: 15px; }
      .cta-button { display: inline-block; background: #0b132b; color: #fff; font-weight: bold; font-size: 16px; text-decoration: none; padding: 14px 32px; border-radius: 30px; margin-top: 15px; transition: all 0.3s; }
      .cta-button:hover { background: #172341; transform: translateY(-2px); }
      .social-links { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }
      .social-links a { color: #0b132b; text-decoration: none; font-size: 14px; letter-spacing: 1px; font-weight: bold; }

      h1, h2, h3, h4 { break-after: avoid; }
      h1, h2, h3 { margin: 0; color: var(--navy); line-height: 1.2; }
      h2 { font-size: 25px; color: var(--gold); margin-bottom: 12px; }
      h3 { margin-top: 18px; font-size: 18px; color: #2e3545; }
      p, li,
      .pdf-content-block p,
      .pdf-content-block li {
        font-size: 13px;
        line-height: 1.58;
      }
      .muted {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.55;
      }
      .definition-text {
        color: #2f3a4c;
        font-size: 13px;
        line-height: 1.58;
        font-style: italic;
      }
      .section-card {
        margin: 15px 0 18px;
        padding: 0;
        border: 0;
        border-radius: 0;
        background: transparent;
        break-inside: auto;
      }
      .section-card > h4 {
        margin: 16px 0 8px;
        color: var(--navy);
        font: 700 18px "Times New Roman", Arial, serif;
        line-height: 1.3;
        text-transform: none;
        padding-bottom: 0;
        border-bottom: 0;
      }
      .pdf-report .outline-heading {
        display: block !important;
        margin: 20px 0 12px !important;
        color: var(--navy) !important;
        font: 700 24px/1.22 "Times New Roman", Arial, serif !important;
        text-transform: none !important;
        padding: 0 0 7px !important;
        border: 0 !important;
        border-bottom: 2px solid var(--gold) !important;
      }
      .pdf-report .section-heading {
        color: #b07a13 !important;
        font-size: 28px !important;
        padding-bottom: 0 !important;
        border-bottom: 0 !important;
      }
      .pdf-block h4,
      .pdf-content-block h4 {
        margin: 14px 0 8px;
        color: var(--navy);
        font: 700 16px "Times New Roman", Arial, serif;
        line-height: 1.3;
        text-transform: none;
      }
      .pdf-block { break-inside: auto; }
      .pdf-block p,
      .pdf-content-block p {
        margin: 0 0 9px;
        text-align: justify;
      }
      .pdf-block ul { margin: 8px 0 12px; padding-left: 24px; }
      .pdf-block li { margin-bottom: 8px; break-inside: avoid; }
      blockquote {
        margin: 10px 0;
        padding: 10px 12px;
        border-left: 3px solid var(--gold);
        background: var(--soft);
        color: #475467;
      }

      .toc-groups { margin: 16px 0 0; }
      .toc-group {
        margin: 0 0 18px;
        break-inside: avoid;
      }
      .toc-group h3 {
        margin: 0 0 8px;
        color: var(--gold);
        font: 700 16px "Times New Roman", Arial, serif;
        text-transform: uppercase;
      }
      .toc-group ol {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .toc-group li {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 8px;
        padding: 6px 0;
        border-bottom: 1px solid var(--line);
        font-size: 14px;
      }
      .toc-number {
        color: var(--gold);
        font-weight: 700;
        text-align: right;
      }

      .number-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        margin-top: 14px;
      }
      .number-card {
        min-height: 76px;
        padding: 10px;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #fff;
        text-align: center;
      }
      .number-label { color: var(--muted); font: 700 11px Arial, sans-serif; text-transform: uppercase; }
      .number-value { margin-top: 6px; color: var(--gold); font-size: 30px; font-weight: 700; }

      .chart-row { display: grid; grid-template-columns: 72mm 1fr; gap: 14px; align-items: start; margin-top: 14px; break-inside: avoid; }
      .numerology-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        aspect-ratio: 1 / 1;
        border: 1px solid var(--gold);
        background: #fff;
      }
      .grid-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        color: var(--navy);
        font-size: 25px;
        font-weight: 700;
      }
      .mini-table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 12px; }
      .mini-table th,
      .mini-table td { border: 1px solid var(--line); padding: 7px; text-align: left; vertical-align: top; }
      .mini-table th { background: var(--soft); color: #344054; font-family: Arial, sans-serif; }
      .pyramid-visual {
        width: 100%;
        max-width: 150mm;
        margin: 14px auto 18px;
        break-inside: avoid;
      }
      .pyramid-visual svg {
        display: block;
        width: 100%;
        height: auto;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 6px;
      }
      .pyramid-line { stroke: var(--gold); stroke-width: 3; fill: none; }
      .pyramid-line.soft { stroke-opacity: 0.38; }
      .pyramid-node { fill: #0b132b; stroke: var(--gold); stroke-width: 3; }
      .pyramid-node.challenge { stroke: #98a2b3; }
      .pyramid-node.base { fill: #fffaf0; }
      .pyramid-number {
        fill: #fff;
        font: 700 26px "Times New Roman", Arial, serif;
        text-anchor: middle;
        dominant-baseline: central;
      }
      .pyramid-number.dark { fill: var(--navy); }
      .pyramid-label {
        fill: #344054;
        font: 700 12px Arial, sans-serif;
        text-anchor: middle;
      }
      .pyramid-age {
        fill: #667085;
        font: 11px Arial, sans-serif;
        text-anchor: middle;
      }
      .chart-panel {
        margin: 12px 0 18px;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #fff;
        break-inside: avoid;
      }
      .chart-panel-title {
        margin: 0 0 10px;
        color: var(--navy);
        font: 700 15px Arial, sans-serif;
      }
      .bar-list { display: grid; gap: 8px; margin-top: 12px; }
      .bar-item { break-inside: avoid; }
      .bar-head { display: flex; justify-content: space-between; gap: 12px; font: 700 12px Arial, sans-serif; }
      .percent-track {
        display: block;
        width: 100%;
        height: 12px;
        margin-top: 4px;
        background-color: #fffaf0;
        border: 1px solid #e8dcc4;
        border-radius: 999px;
        overflow: hidden;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .percent-fill {
        height: 100%;
        border-radius: 999px;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .detail-list {
        margin-top: 14px;
      }
      .locked-box {
        margin-top: 10px;
        padding: 12px;
        border: 1px dashed #c7972f;
        border-radius: 6px;
        background: rgba(199,151,47,0.08);
        color: #7a5b19;
        font: 700 12px/1.5 Arial, sans-serif;
      }
      .footer {
        position: absolute;
        left: 18mm;
        right: 18mm;
        bottom: 14mm;
        display: flex;
        justify-content: space-between;
        color: #98a2b3;
        font: 10px Arial, sans-serif;
      }
      .print-footer {
        display: none;
      }

      @media print {
        @page { size: 210mm 297mm; margin: 0 !important; }
        html, body {
          background: #fff;
          color: #050a1f;
          font-family: "Times New Roman", Arial, serif;
          margin: 0;
          padding: 0;
        }

        .report {
          width: 100% !important;
          margin: 0 !important;
          padding: 0 !important;
          box-shadow: none !important;
          background: transparent !important;
        }

        /* Enforce table layout for repeating margins */
        #print-layout-table {
          width: 210mm !important;
          border-collapse: collapse;
          border: none;
          margin: 0;
          padding: 0;
        }
        #print-layout-table > thead > tr > td { padding: 0 !important; border: 0 !important; }
        #print-layout-table > tbody > tr > td { padding: 0 16mm !important; border: 0 !important; }
        #print-layout-table > tfoot > tr > td { padding: 0 !important; border: 0 !important; }

        .print-header-space { height: 18mm !important; display: block !important; }
        .print-footer-space { height: 18mm !important; display: block !important; }

        body::before { display: none !important; }
        body::after {
          content: "";
          position: fixed;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          width: 350px;
          height: 350px;
          background-image: url('/images/logo-l.png');
          background-repeat: no-repeat;
          background-position: center center;
          background-size: contain;
          pointer-events: none;
          z-index: 10;
          opacity: 0.08;
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
        
        .toolbar, .tune-panel, .tune-page-guide, #tune-float { display: none !important; }
        
        .page {
          width: auto;
          min-height: auto;
          padding: 0 !important;
          border: 0 !important;
          page-break-after: always;
          overflow: visible;
          position: relative;
          z-index: 20;
        }
        .page:first-child { page-break-before: auto; }
        .page::before { display: none !important; }
        .page::after { display: none !important; }

        .section-page { page-break-before: always !important; }
        .toc-page { page-break-after: always !important; }
        
        /* Cover page: pulled outside the table to avoid table footers */
        .cover, .back-cover {
          margin: 0 !important;
          padding: 20mm 16mm 22mm !important;
          height: 297mm !important;
          width: 210mm !important;
          box-sizing: border-box !important;
          background-color: #fff !important; /* solid background hides watermark */
          background-image: url('/images/cover-artwork.png') !important;
          background-position: center center !important;
          background-size: cover !important;
          background-repeat: no-repeat !important;
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          position: relative;
          z-index: 10000 !important; /* higher than fixed watermark */
          overflow: hidden;
          page-break-after: always;
          border: none;
        }
        .back-cover { background-position: center bottom !important; page-break-before: always !important; page-break-after: auto !important; }
        .cover > .brand-logo, .back-cover > .brand-logo { margin-top: 0; }

        /* Fixed Footer */
        .footer { display: none !important; }
        .print-footer {
          position: fixed;
          bottom: 8mm !important;
          left: 16mm !important;
          right: 16mm !important;
          z-index: 50; /* lower than cover */
          display: block !important;
          padding-top: 6px;
          border-top: 1px solid #d4af37;
          color: #050a1f;
          font: 12px Arial, sans-serif;
        }
        .print-footer::before {
          content: "© Copyright 2026 - phogotarot.com - " attr(data-name) " - " attr(data-dob);
          display: block;
          font-weight: normal;
          font-style: italic;
        }
        .section-card {
          margin: 15px 0 20px;
          break-inside: auto;
          border: none !important;
          background: transparent !important;
          box-shadow: none !important;
          padding: 0 !important;
        }
        .section-card::before { display: none !important; }
        
        /* Compact TOC for print */
        .toc-group {
          margin: 0 0 16px !important;
        }
        .toc-groups {
          column-count: 1;
        }
        .toc-group h3 {
          font-size: 16px !important;
          margin: 0 0 8px !important;
        }
        .toc-group li {
          font-size: 15px !important;
          padding: 8px 0 !important;
          line-height: 1.4 !important;
          font-family: Arial, sans-serif !important;
        }

        blockquote {
          border: none !important;
          background: transparent !important;
          padding: 0 0 0 20px !important;
          margin: 10px 0 !important;
          box-shadow: none !important;
        }
        .pdf-block,
        .pdf-content-block {
          break-inside: auto;
        }
        .pdf-block p,
        .pdf-content-block p,
        .pdf-content-block li,
        .muted,
        .definition-text,
        p,
        li {
          font-size: 16.5px !important;
          line-height: 1.62 !important;
        }
        .definition-text {
          font-style: italic;
        }
        h2 {
          margin-top: 0;
          font-size: 27px;
          color: var(--gold);
        }
        .section-card > h4,
        .pdf-block h4,
        .pdf-content-block h4 {
          font-size: 20px !important;
          margin: 20px 0 10px !important;
          line-height: 1.3;
          padding-bottom: 0;
          border-bottom: 0;
        }
        .pdf-report .outline-heading {
          display: block !important;
          margin: 20px 0 12px !important;
          color: var(--navy) !important;
          font: 700 24px/1.22 "Times New Roman", Arial, serif !important;
          text-transform: none !important;
          padding: 0 0 7px !important;
          border: 0 !important;
          border-bottom: 2px solid var(--gold) !important;
        }
        .pdf-report .section-heading {
          color: #b07a13 !important;
          font-size: 28px !important;
          padding-bottom: 0 !important;
          border-bottom: 0 !important;
        }
        .toc-group ol {
          list-style: none !important;
          padding: 0 !important;
          margin: 0 !important;
        }
        .toc-group li {
          list-style: none !important;
        }
        .toc-group li::marker {
          content: "" !important;
        }
        .pdf-block h4,
        .pdf-content-block h4 {
          font-size: 16px;
          line-height: 1.3;
        }
      }
    </style>
  </head>
  <body>
    <div class="toolbar">
      <a href={`/ket-qua-than-so-hoc?name=${encodeURIComponent(input.fullName)}&dob=${encodeURIComponent(input.dobStr)}${input.nickname ? `&nickname=${encodeURIComponent(input.nickname)}` : ''}${input.gender ? `&gender=${encodeURIComponent(input.gender)}` : ''}`}>Quay lại kết quả</a>
      <button class="primary" type="button" onclick="window.print()">In / Lưu PDF</button>
    </div>
    <div class="report pdf-report">
      <section class="page cover">
        <img src="/images/logo-l.png" class="brand-logo" alt="Phở Gõ Tarot" />
        <div class="page-content">
          <h1 class="cover-title">Báo cáo<br />Thần Số Học</h1>
          <div class="cover-name">{input.fullName}</div>
          <div class="cover-meta">
            <div class="meta-box"><span class="meta-label">Ngày sinh</span><span class="meta-value">{input.formattedDob}</span></div>
            <div class="meta-box"><span class="meta-label">Ngày xuất</span><span class="meta-value">{generatedAt}</span></div>
          </div>
        </div>
        <p class="cover-note">Copyright 2026 - phogotarot.com.</p>
      </section>
    </div>

    <table id="print-layout-table">
      <thead>
        <tr><td><div class="print-header-space"></div></td></tr>
      </thead>
      <tbody>
        <tr><td>
          <article class="report pdf-report">
      <section class="page toc-page">
        <div class="page-content">
          <h2>Mục lục báo cáo</h2>
          <div class="toc-groups">
            {tocGroups.map((group) => (
              <section class="toc-group">
                <h3>{group.title}</h3>
                <ol>
                  {group.items.map((item) => (
                    <li><span class="toc-number">{item.number}.</span><span>{item.label}</span></li>
                  ))}
                </ol>
              </section>
            ))}
          </div>
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>01</span></div>
      </section>

      <section class="page section-page">
        <div class="page-content">
          <h2 class="outline-heading section-heading">I. Nền tảng cốt lõi</h2>
          <div class="section-card">
            <h2 class="outline-heading">1. Số chủ đạo của bạn: Số {numbers.lifePath}</h2>
            <p class="definition-text">{numerologyDefinitions.lifePath}</p>
            <PdfContentBlock blocks={content.lifePath?.blocks} content={content.lifePath?.content} />
          </div>
          {coreContent.map(([label, value, data, definition, locked], index) => (
            <div class="section-card">
              <h2 class="outline-heading">{index + 2}. {label} của bạn: Số {value}</h2>
              <p class="definition-text">{definition}</p>
              {locked ? <div class="locked-box">Nội dung chi tiết đang được khóa trong bản xem trước. Mở khóa hồ sơ để xuất đầy đủ phần này.</div> : <PdfContentBlock blocks={data?.blocks} content={data?.content} />}
            </div>
          ))}
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>02</span></div>
      </section>

      <section class="page section-page">
        <div class="page-content">
          <h2 class="outline-heading section-heading">II. Biểu đồ & cấu trúc</h2>
          <div class="chart-row">
            <div>
              <h3 class="outline-heading">8. Biểu Đồ Ngày Sinh</h3>
              <div class="numerology-grid">
                {[3,6,9,2,5,8,1,4,7].map(num => <div class="grid-cell">{renderCell(num, chartData.strengthData)}</div>)}
              </div>
            </div>
            <div>
              <h3>Luận giải biểu đồ ngày sinh</h3>
              {isLocked ? <div class="locked-box">Phần luận giải chi tiết đang được khóa.</div> : (
                <table class="mini-table">
                  <tbody>
                    {chartData.strengthArrows.map((arrow: any) => <tr><th>Mũi tên {arrow.type === 'present' ? 'hiện diện' : 'thiếu'}</th><td>{arrow.name}</td></tr>)}
                    {chartData.strengthMissingNums.map((num: number) => <tr><th>Số thiếu</th><td>{num}</td></tr>)}
                  </tbody>
                </table>
              )}
            </div>
          </div>

          <div class="chart-row">
            <div>
              <h3 class="outline-heading">9. Biểu Đồ Tên & Tổng Hợp</h3>
              <div class="numerology-grid">
                {[3,6,9,2,5,8,1,4,7].map(num => <div class="grid-cell">{renderCell(num, chartData.nameData)}</div>)}
              </div>
            </div>
            <div>
              <h3>Biểu đồ tổng hợp</h3>
              <div class="numerology-grid">
                {[3,6,9,2,5,8,1,4,7].map(num => <div class="grid-cell">{renderCell(num, chartData.synthesisData)}</div>)}
              </div>
            </div>
          </div>
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>03</span></div>
      </section>

      <section class="page">
        <div class="page-content">
          <h2 class="outline-heading">10. Kim Tự Tháp Thần Số</h2>
          <p class="definition-text">{numerologyDefinitions.pyramid}</p>
          <div class="pyramid-visual" aria-label="Kim tự tháp thần số học">
            <svg viewBox="0 0 600 720" role="img">
              <line x1="105" y1="360" x2="495" y2="360" class="pyramid-line soft" />
              <line x1="130" y1="360" x2="300" y2="70" class="pyramid-line" />
              <line x1="470" y1="360" x2="300" y2="70" class="pyramid-line" />
              <line x1="130" y1="360" x2="300" y2="650" class="pyramid-line soft" />
              <line x1="470" y1="360" x2="300" y2="650" class="pyramid-line soft" />
              <line x1="130" y1="360" x2="240" y2="270" class="pyramid-line" />
              <line x1="470" y1="360" x2="360" y2="270" class="pyramid-line" />
              <line x1="240" y1="270" x2="300" y2="165" class="pyramid-line" />
              <line x1="360" y1="270" x2="300" y2="165" class="pyramid-line" />
              <line x1="300" y1="165" x2="300" y2="70" class="pyramid-line" />
              <line x1="130" y1="360" x2="240" y2="450" class="pyramid-line soft" />
              <line x1="470" y1="360" x2="360" y2="450" class="pyramid-line soft" />
              <line x1="240" y1="450" x2="300" y2="555" class="pyramid-line soft" />
              <line x1="360" y1="450" x2="300" y2="555" class="pyramid-line soft" />
              <line x1="300" y1="555" x2="300" y2="650" class="pyramid-line soft" />

              <circle cx="130" cy="360" r="25" class="pyramid-node base" />
              <text x="130" y="360" class="pyramid-number dark">{pyramid.base.m}</text>
              <text x="130" y="407" class="pyramid-label">Tháng</text>

              <circle cx="300" cy="360" r="27" class="pyramid-node base" />
              <text x="300" y="360" class="pyramid-number dark">{pyramid.base.d}</text>
              <text x="300" y="407" class="pyramid-label">Ngày</text>

              <circle cx="470" cy="360" r="25" class="pyramid-node base" />
              <text x="470" y="360" class="pyramid-number dark">{pyramid.base.y}</text>
              <text x="470" y="407" class="pyramid-label">Năm</text>

              <circle cx="240" cy="270" r="24" class="pyramid-node" />
              <text x="240" y="270" class="pyramid-number">{pyramid.peaks.p1}</text>
              <text x="170" y="245" class="pyramid-label">Đỉnh 1</text>
              <text x="170" y="263" class="pyramid-age">{pyramid.ages.p1_text}</text>
              <text x="170" y="280" class="pyramid-age">{pyramid.ages.p1_year}</text>

              <circle cx="360" cy="270" r="24" class="pyramid-node" />
              <text x="360" y="270" class="pyramid-number">{pyramid.peaks.p2}</text>
              <text x="430" y="245" class="pyramid-label">Đỉnh 2</text>
              <text x="430" y="263" class="pyramid-age">{pyramid.ages.p2_text}</text>
              <text x="430" y="280" class="pyramid-age">{pyramid.ages.p2_year}</text>

              <circle cx="300" cy="165" r="24" class="pyramid-node" />
              <text x="300" y="165" class="pyramid-number">{pyramid.peaks.p3}</text>
              <text x="405" y="148" class="pyramid-label">Đỉnh 3</text>
              <text x="405" y="166" class="pyramid-age">{pyramid.ages.p3_text}</text>
              <text x="405" y="183" class="pyramid-age">{pyramid.ages.p3_year}</text>

              <circle cx="300" cy="70" r="24" class="pyramid-node" />
              <text x="300" y="70" class="pyramid-number">{pyramid.peaks.p4}</text>
              <text x="405" y="54" class="pyramid-label">Đỉnh 4</text>
              <text x="405" y="72" class="pyramid-age">{pyramid.ages.p4_text}</text>
              <text x="405" y="89" class="pyramid-age">{pyramid.ages.p4_year}</text>

              <circle cx="240" cy="450" r="22" class="pyramid-node challenge" />
              <text x="240" y="450" class="pyramid-number">{pyramid.challenges.c1}</text>
              <text x="170" y="478" class="pyramid-label">Thử thách 1</text>

              <circle cx="360" cy="450" r="22" class="pyramid-node challenge" />
              <text x="360" y="450" class="pyramid-number">{pyramid.challenges.c2}</text>
              <text x="430" y="478" class="pyramid-label">Thử thách 2</text>

              <circle cx="300" cy="555" r="22" class="pyramid-node challenge" />
              <text x="300" y="555" class="pyramid-number">{pyramid.challenges.c3}</text>
              <text x="405" y="580" class="pyramid-label">Thử thách 3</text>

              <circle cx="300" cy="650" r="22" class="pyramid-node challenge" />
              <text x="300" y="650" class="pyramid-number">{pyramid.challenges.c4}</text>
              <text x="405" y="674" class="pyramid-label">Thử thách 4</text>
            </svg>
          </div>

          {isLocked ? <div class="locked-box">Luận giải kim tự tháp, nợ nghiệp và bài học đường đời đang được khóa trong bản xem trước.</div> : (
            <>
              {[pyramid.peaks.p1, pyramid.peaks.p2, pyramid.peaks.p3, pyramid.peaks.p4].map((peak) => (
                <div class="section-card">
                  <h4>Đỉnh cao số {peak}</h4>
                  <PdfContentBlock blocks={content.pyramidDataStore.peaks[peak]?.blocks} content={content.pyramidDataStore.peaks[peak]?.content} />
                </div>
              ))}
              <h3 class="outline-heading">11. Chỉ Số Nợ Nghiệp</h3>
              <p class="definition-text">{numerologyDefinitions.karmicDebt}</p>
              {karmicDebts.length === 0 && <p>Không ghi nhận chỉ số nợ nghiệp nổi bật trong hồ sơ này.</p>}
              {karmicDebts.map((debt) => (
                <div class="section-card">
                  <h4>Nợ nghiệp số {debt}</h4>
                  <PdfContentBlock blocks={content.debtDataStore[debt]?.blocks} content={content.debtDataStore[debt]?.content} />
                </div>
              ))}
              <h3 class="outline-heading">12. Bài Học Đường Đời (Điểm Yếu)</h3>
              <p class="definition-text">{numerologyDefinitions.karmicLessons}</p>
              {karmicLessons.length === 0 && <p>Không ghi nhận bài học thiếu nổi bật trong biểu đồ tên.</p>}
              {karmicLessons.map((lesson) => (
                <div class="section-card">
                  <h4>Bài học thiếu số {lesson}</h4>
                  <PdfContentBlock blocks={content.lessonDataStore[lesson]?.blocks} content={content.lessonDataStore[lesson]?.content} />
                </div>
              ))}
            </>
          )}
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>04</span></div>
      </section>

      <section class="page section-page">
        <div class="page-content">
          <h2 class="outline-heading section-heading">III. Nhóm tính cách & định hướng</h2>
          <h3 class="outline-heading">13. Nhóm Tính Cách Bản Ngã</h3>
          <p class="definition-text">{numerologyDefinitions.personalityGroup}</p>
          <div class="chart-panel">
            <div class="chart-panel-title">Biểu đồ tỉ lệ nhóm tính cách</div>
            <div class="bar-list">
              {personalityStats.map((trait) => (
                <div class="bar-item">
                  <div class="bar-head"><span>{trait.label}</span><span>{isLocked ? 'Đã khóa' : `${trait.percent}%`}</span></div>
                  <div class="percent-track">
                    <div class="percent-fill" style={`width: ${trait.percent}%; background: #c7972f;`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          {!isLocked && (
            <div class="detail-list">
              <h4>Chi tiết luận giải tính cách</h4>
              {topTraits.map((trait) => {
                const meaningData = getPersonalityMeaning(trait.id);
                if (!meaningData) return null;
                return (
                  <div class="section-card">
                    <h4>Tính cách: {trait.label} ({trait.percent}%)</h4>
                    <PdfContentBlock blocks={meaningData.blocks} content={meaningData.content} />
                  </div>
                );
              })}
            </div>
          )}

          <h3 class="outline-heading">14. Tỉ Lệ Nhóm Ngành Phù Hợp</h3>
          <p class="definition-text">{numerologyDefinitions.careerGroup}</p>
          <div class="chart-panel">
            <div class="chart-panel-title">Biểu đồ tỉ lệ nhóm ngành phù hợp</div>
            <div class="bar-list">
              {careerStats.map((career) => (
                <div class="bar-item">
                  <div class="bar-head"><span>{career.label}</span><span>{isLocked ? 'Đã khóa' : `${career.percent}%`}</span></div>
                  <div class="percent-track">
                    <div class="percent-fill" style={`width: ${career.percent}%; background: #274060;`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          {!isLocked && (
            <div class="detail-list">
              <h4>Chi tiết định hướng nghề nghiệp</h4>
              {topCareer.map((career) => {
                const meaningData = getCareerMeaning(career.id);
                if (!meaningData) return null;
                return (
                  <div class="section-card">
                    <h4>Ngành phù hợp: {career.label} ({career.percent}%)</h4>
                    <PdfContentBlock blocks={meaningData.blocks} content={meaningData.content} />
                  </div>
                );
              })}
            </div>
          )}
          {isLocked && <div class="locked-box">Tỷ lệ thật và luận giải chi tiết của nhóm tính cách/nghề nghiệp đang được khóa.</div>}
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>05</span></div>
      </section>

      <section class="page section-page">
          <div class="page-content">
            <h2 class="outline-heading section-heading">IV. Dòng thời gian - chu kỳ vận động</h2>
          <h3 class="outline-heading">15. Chu Kỳ Đường Đời</h3>
          <table class="mini-table">
            <thead><tr><th>Chu kỳ</th><th>Số</th><th>Độ tuổi</th><th>Giai đoạn</th></tr></thead>
            <tbody>
              {cycleList.map((cycle) => <tr><td>{cycle.id} - {cycle.label}</td><td>{cycle.data.number}</td><td>{cycle.data.ageRange}</td><td>{cycle.data.yearRange}</td></tr>)}
            </tbody>
          </table>

          <h3 class="outline-heading">16. Chu Kỳ Vận Số 9 Năm</h3>
          <table class="mini-table">
            <thead><tr><th>Năm</th><th>Vận số</th><th>Vị trí</th></tr></thead>
            <tbody>
              {forecast.years.map((item, index) => <tr><td>{item.year}</td><td>{item.number}</td><td>{yearRelationLabels[index]}</td></tr>)}
            </tbody>
          </table>

          {isLocked ? <div class="locked-box">Dự báo chi tiết theo chu kỳ, năm và tháng đang được khóa trong bản xem trước.</div> : (
            <>
              <h3 class="outline-heading">17. Dự Báo Năm Cá Nhân</h3>
              {forecast.years.map((item, index) => (
                <div class="section-card">
                  <h4>Năm {item.year} - Vận niên số {item.number} ({yearRelationLabels[index]})</h4>
                  <PdfContentBlock blocks={content.yearDataStore[item.number]?.blocks} content={content.yearDataStore[item.number]?.content} />
                </div>
              ))}
              <h3 class="outline-heading">18. Dự Báo Tháng Cá Nhân</h3>
              {forecast.months.map((item) => (
                <div class="section-card">
                  <h4>Tháng {item.month}/{item.year} - Vận số {item.number}</h4>
                  <PdfContentBlock blocks={content.monthDataStore[item.number]?.blocks} content={content.monthDataStore[item.number]?.content} />
                </div>
              ))}
            </>
          )}
        </div>
        <div class="footer"><span>Phở Gõ Tarot</span><span>06</span></div>
      </section>

    </article>
        </td></tr>
      </tbody>
      <tfoot>
        <tr><td>
          <div class="print-footer-space">
            <div class="print-footer" data-name={input.fullName} data-dob={input.formattedDob}></div>
          </div>
        </td></tr>
      </tfoot>
    </table>

    <div class="report pdf-report">
      <section class="page back-cover">
        <img src="/images/logo-l.png" class="brand-logo" alt="Phở Gõ Tarot" />
        <div class="page-content">
          <div class="back-cover-body">
            <h2>Cảm ơn bạn đã lựa chọn Phở Gõ Tarot!</h2>
            <p>Bản báo cáo Thần Số Học này được biên soạn với mong muốn mang đến cho bạn một tấm bản đồ thấu hiểu bản thân và định hướng tương lai. Hy vọng những con số sẽ là kim chỉ nam giúp bạn tự tin bước đi trên hành trình của riêng mình.</p>
            
            <div class="cta-box">
              <h3>Bạn có đang gặp khúc mắc cần giải đáp?</h3>
              <p>Thần số học giúp bạn hiểu bức tranh tổng thể, còn Tarot sẽ soi sáng những câu chuyện hiện tại. Hãy đặt lịch xem bài Tarot chuyên sâu để nhận được lời khuyên chi tiết cho tình yêu, công việc hay bất kỳ vấn đề nào bạn đang đối mặt.</p>
              <a href="https://m.me/phogotarot" class="cta-button" target="_blank">Booking Xem Tarot</a>
            </div>
            
            <div class="social-links">
              <a href="https://phogotarot.com" target="_blank">🌐 phogotarot.com</a>
              <a href="https://facebook.com/phogotarot" target="_blank">📘 fb.com/phogotarot</a>
              <a href="https://instagram.com/phogotarot" target="_blank">📸 @phogotarot</a>
            </div>
          </div>
        </div>
      </section>
    </div>

    <script is:inline>
    (function() {
      if (!new URLSearchParams(window.location.search).has('tune')) return;

      var defaults = {
        footerBottom: 10,
        footerLR: 20
      };
      var saved = localStorage.getItem('pdf-footer-tune-v3');
      var V = saved ? Object.assign({}, defaults, JSON.parse(saved)) : Object.assign({}, defaults);

      /* ── dynamic print CSS ── */
      var dynEl = document.createElement('style');
      dynEl.id = 'tune-dyn';
      document.head.appendChild(dynEl);

      function applyPrint() {
        dynEl.textContent =
          '@page{margin:0}' +
          '@media print{' +
          '.print-footer{position:fixed!important;bottom:' + V.footerBottom + 'mm!important;left:' + V.footerLR + 'mm!important;right:' + V.footerLR + 'mm!important}' +
          '}';
      }
      applyPrint();

      /* ── simulation mode ── */
      var simEl = document.createElement('style');
      simEl.id = 'tune-sim';
      document.head.appendChild(simEl);
      var simActive = false;

      function buildSimCSS() {
        return (
          '.print-footer{display:block!important;position:fixed!important;bottom:' + V.footerBottom + 'mm!important;left:' + V.footerLR + 'mm!important;right:' + V.footerLR + 'mm!important;padding-top:6px!important;border-top:1px solid #d4af37!important;color:#050a1f!important;font:12px Arial,sans-serif!important;z-index:10000!important}' +
          '.print-footer::before{display:block!important}'
        );
      }

      function clearGuides() {
        document.querySelectorAll('.tune-page-guide').forEach(function(el){ el.remove(); });
      }

      function drawGuides() {
        clearGuides();
      }

      /* ── panel ── */
      var sliderDefs = [
        { key: 'footerBottom', label: 'Khoảng cách từ mép dưới', min: 0, max: 50 },
        { key: 'footerLR', label: 'Footer thụt trái/phải', min: 0, max: 40 }
      ];

      var panel = document.createElement('div');
      panel.className = 'tune-panel';
      panel.innerHTML =
          '<style>' +
          '.tune-panel{position:fixed;top:56px;right:10px;z-index:99999;width:320px;max-height:calc(100vh - 70px);overflow-y:auto;' +
            'background:rgba(11,19,43,0.97);color:#f0e6d2;border:1px solid #c7972f;border-radius:10px;padding:14px;' +
            'font:13px/1.4 Arial,sans-serif;box-shadow:0 8px 32px rgba(0,0,0,0.6)}' +
          '.tune-panel h3{margin:0 0 6px;color:#f4d58d;font-size:14px}' +
          '.tune-info{font-size:10.5px;color:#98a2b3;line-height:1.45;margin:0 0 8px;padding:8px 10px;background:rgba(255,255,255,0.04);border-radius:6px;border-left:3px solid #c7972f}' +
          '.tune-row{margin-bottom:7px}' +
          '.tune-row label{display:flex;justify-content:space-between;font-size:11px;color:#d2c5a8;margin-bottom:1px}' +
          '.tune-row input[type=range]{width:100%;accent-color:#c7972f;height:16px}' +
          '.tune-val{color:#f4d58d;font-weight:700}' +
          '.tune-btns{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}' +
          '.tune-btns button{flex:1;min-width:70px;padding:7px 4px;border:1px solid #c7972f;border-radius:6px;' +
            'background:rgba(199,151,47,0.12);color:#f4d58d;font:700 11px Arial,sans-serif;cursor:pointer;transition:all .2s}' +
          '.tune-btns button:hover{background:#c7972f;color:#0b132b}' +
          '.tune-btns button.on{background:#c7972f;color:#0b132b}' +
          '.tune-btns button.danger{border-color:#e74c3c;color:#e74c3c}' +
          '.tune-btns button.danger:hover{background:#e74c3c;color:#fff}' +
          '.tune-sep{border:0;border-top:1px solid rgba(199,151,47,0.2);margin:8px 0}' +
          '.tune-css{margin-top:8px;padding:6px;background:#1a2138;border:1px solid #333;border-radius:5px;' +
            'font:10px/1.4 Consolas,monospace;color:#8ec07c;max-height:130px;overflow-y:auto;white-space:pre-wrap;display:none}' +
        '</style>' +
        '<h3>Footer Tuner</h3>' +
        '<div class="tune-info">' +
          '<b>Quy trình:</b><br>' +
          '1. B\u1EA5m <b>"M\u00F4 ph\u1ECFng"</b> \u2192 hi\u1EC7n v\u1ECB tr\u00ED c\u1EAFt trang + v\u00F9ng footer<br>' +
          '2. K\u00E9o slider \u0111\u1EC3 ch\u1EC9nh cho ch\u1EEF kh\u00F4ng n\u1EB1m trong v\u00F9ng h\u1ED3ng<br>' +
          '3. B\u1EA5m <b>"In th\u1EED"</b> \u2192 ki\u1EC3m tra PDF th\u1EF1c t\u1EBF<br>' +
          '\u26A0\uFE0F Chrome: ch\u1ECDn <b>Margins = Default</b> khi in' +
        '</div>' +
        '<div id="tune-sl"></div>' +
        '<hr class="tune-sep">' +
        '<div class="tune-btns">' +
          '<button id="tune-sim">Xem footer</button>' +
          '<button onclick="window.print()">\u{1F5A8}\uFE0F In th\u1EED</button>' +
        '</div>' +
        '<div class="tune-btns" style="margin-top:6px">' +
          '<button id="tune-css-btn">\u{1F4CB} Xem CSS</button>' +
          '<button id="tune-rst" class="danger">\u21BA Reset</button>' +
        '</div>' +
        '<div id="tune-css" class="tune-css"></div>';
      document.body.appendChild(panel);

      /* ── sliders ── */
      var sc = document.getElementById('tune-sl');
      var inputs = {};
      sliderDefs.forEach(function(s) {
        var r = document.createElement('div');
        r.className = 'tune-row';
        r.innerHTML =
          '<label><span>' + s.label + '</span><span class="tune-val" id="tv-' + s.key + '">' + V[s.key] + 'mm</span></label>' +
          '<input type="range" min="' + s.min + '" max="' + s.max + '" step="1" value="' + V[s.key] + '" id="ti-' + s.key + '">';
        sc.appendChild(r);
        var inp = document.getElementById('ti-' + s.key);
        inputs[s.key] = inp;
        inp.addEventListener('input', function() {
          V[s.key] = parseInt(inp.value);
          document.getElementById('tv-' + s.key).textContent = V[s.key] + 'mm';
          applyPrint();
          localStorage.setItem('pdf-footer-tune-v3', JSON.stringify(V));
          if (simActive) { simEl.textContent = buildSimCSS(); drawGuides(); }
        });
      });

      /* ── floating toggle button (visible when panel is hidden) ── */
      var floatBtn = document.createElement('button');
      floatBtn.id = 'tune-float';
      floatBtn.innerHTML = 'F';
      floatBtn.style.cssText = 'display:none;position:fixed;top:56px;right:10px;z-index:99999;width:42px;height:42px;border-radius:50%;border:2px solid #c7972f;background:rgba(11,19,43,0.95);color:#f4d58d;font-size:20px;cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,0.5);transition:all .2s;';
      floatBtn.addEventListener('click', function() {
        panel.style.display = '';
        floatBtn.style.display = 'none';
      });
      document.body.appendChild(floatBtn);

      /* ── sim toggle ── */
      var simBtn = document.getElementById('tune-sim');
      simBtn.addEventListener('click', function() {
        simActive = !simActive;
        if (simActive) {
          simEl.textContent = buildSimCSS();
          drawGuides();
          simBtn.textContent = 'Tắt xem footer';
          simBtn.classList.add('on');
          /* hide panel, show float button */
          panel.style.display = 'none';
          floatBtn.style.display = '';
        } else {
          simEl.textContent = '';
          clearGuides();
          simBtn.textContent = 'Xem footer';
          simBtn.classList.remove('on');
          /* show panel, hide float button */
          panel.style.display = '';
          floatBtn.style.display = 'none';
        }
      });

      /* ── css output ── */
      var co = document.getElementById('tune-css');
      document.getElementById('tune-css-btn').addEventListener('click', function() {
        var show = co.style.display !== 'block';
        co.style.display = show ? 'block' : 'none';
        if (show) {
          co.textContent =
            '.print-footer { bottom: ' + V.footerBottom + 'mm !important; }';
        }
      });

      /* ── reset ── */
      document.getElementById('tune-rst').addEventListener('click', function() {
        Object.keys(defaults).forEach(function(k) {
          V[k] = defaults[k];
          if (inputs[k]) { inputs[k].value = defaults[k]; document.getElementById('tv-' + k).textContent = defaults[k] + 'mm'; }
        });
        localStorage.removeItem('pdf-footer-tune-v3');
        applyPrint();
        if (simActive) { simEl.textContent = buildSimCSS(); drawGuides(); }
      });
    })();
    </script>
  </body>
</html>
