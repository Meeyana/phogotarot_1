---
import BaseLayout from '../layouts/BaseLayout.astro';

// Bảo vệ route
if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const db = Astro.locals.runtime?.env?.DB;
let historyList: any[] = [];
let yesnoList: any[] = [];
let numerologyList: any[] = [];

if (db) {
  try {
    // Lấy danh sách cuộc hội thoại của user, sắp xếp mới nhất lên đầu
    const query = `
      SELECT id, title, created_at 
      FROM conversations 
      WHERE user_id = ? 
      ORDER BY created_at DESC
    `;
    const result = await db.prepare(query).bind(Astro.locals.user.id).all();
    if (result && result.results) {
      historyList = result.results;
    }

    const qYesNo = `SELECT id, question as title, created_at FROM yes_no_readings WHERE user_id = ? ORDER BY created_at DESC`;
    const resYesNo = await db.prepare(qYesNo).bind(Astro.locals.user.id).all();
    if (resYesNo && resYesNo.results) {
      yesnoList = resYesNo.results;
    }

    const qNum = `SELECT profile_id, unlocked_at as created_at FROM unlocked_numerology_profiles WHERE user_id = ? ORDER BY unlocked_at DESC`;
    try {
      const resNum = await db.prepare(qNum).bind(Astro.locals.user.id).all();
      if (resNum && resNum.results) {
        numerologyList = resNum.results;
      }
    } catch (e) {
      // Bỏ qua nếu bảng chưa tồn tại
      console.log('Chưa có bảng numerology profiles hoặc lỗi lấy data', e);
    }
  } catch (error) {
    console.error("Lỗi lấy danh sách lịch sử:", error);
  }
}

const pageTitle = "Lịch Sử Trải Bài | Phở Gõ Tarot";
const pageDesc = "Xem lại những thông điệp và lời khuyên từ vũ trụ mà bạn đã nhận được.";
---

<BaseLayout title={pageTitle} description={pageDesc} showChatbot={false}>
    <main class="history-page-container">
        <div class="history-header">
            <h1 class="title">Lịch Sử Của Lữ Khách</h1>
            <p class="subtitle">Những thông điệp vũ trụ đã trao gửi cho bạn được lưu giữ an toàn tại đây.</p>
        </div>

        <div class="tabs-container flex-wrap">
            <button class="tab-btn active" data-target="tab-tarot">Bói bài Tarot</button>
            <button class="tab-btn" data-target="tab-yesno">Tarot Yes/No</button>
            <button class="tab-btn" data-target="tab-numerology">Thần số học</button>
        </div>

        <div class="history-content">
            <div id="tab-tarot" class="tab-content active">
            {historyList.length === 0 ? (
                <div class="empty-state">
                    <div class="empty-icon">🌙</div>
                    <h3>Chưa có ghi chép nào</h3>
                    <p>Bạn chưa thực hiện trải bài nào. Hãy bắt đầu kết nối với vũ trụ ngay hôm nay.</p>
                    <a href="/xem-tarot" class="btn-primary">Trải bài Tarot ngay</a>
                </div>
            ) : (
                <div class="history-list">
                    {historyList.map(item => {
                        const dateStr = item.created_at.replace(' ', 'T') + 'Z'; // Ép kiểu về UTC chuẩn
                        const dateObj = new Date(dateStr);
                        const formattedDate = dateObj.toLocaleDateString('vi-VN', {
                            timeZone: 'Asia/Ho_Chi_Minh',
                            year: 'numeric', month: '2-digit', day: '2-digit',
                            hour: '2-digit', minute: '2-digit'
                        });
                        return (
                            <a href={`/history/${item.id}`} class="history-card">
                                <div class="card-icon">
                                    <i class="fa-solid fa-wand-magic-sparkles" style="font-size: 1.5rem;"></i>
                                </div>
                                <div class="card-info">
                                    <h3 class="card-title">{item.title}</h3>
                                    <div class="card-meta">
                                        <span class="date">{formattedDate}</span>
                                    </div>
                                </div>
                                <div class="card-arrow">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                                </div>
                            </a>
                        );
                    })}
                </div>
            )}
            </div>

            <div id="tab-yesno" class="tab-content">
            {yesnoList.length === 0 ? (
                <div class="empty-state">
                    <div class="empty-icon">🌙</div>
                    <h3>Chưa có ghi chép nào</h3>
                    <p>Bạn chưa thực hiện trải bài Yes/No nào. Hãy thử hỏi vũ trụ một câu hỏi dứt khoát.</p>
                    <a href="/yes-no-reading" class="btn-primary">Trải bài Yes/No ngay</a>
                </div>
            ) : (
                <div class="history-list">
                    {yesnoList.map(item => {
                        const dateStr = item.created_at.replace(' ', 'T') + 'Z'; 
                        const dateObj = new Date(dateStr);
                        const formattedDate = dateObj.toLocaleDateString('vi-VN', {
                            timeZone: 'Asia/Ho_Chi_Minh',
                            year: 'numeric', month: '2-digit', day: '2-digit',
                            hour: '2-digit', minute: '2-digit'
                        });
                        return (
                            <a href={`/history/yesno/${item.id}`} class="history-card">
                                <div class="card-icon">
                                    <i class="fa-solid fa-scale-balanced" style="font-size: 1.5rem;"></i>
                                </div>
                                <div class="card-info">
                                    <h3 class="card-title">{item.title}</h3>
                                    <div class="card-meta">
                                        <span class="date">{formattedDate}</span>
                                    </div>
                                </div>
                                <div class="card-arrow">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                                </div>
                            </a>
                        );
                    })}
                </div>
            )}
            </div>

            <div id="tab-numerology" class="tab-content">
            {numerologyList.length === 0 ? (
                <div class="empty-state">
                    <div class="empty-icon">🔢</div>
                    <h3>Chưa có hồ sơ nào</h3>
                    <p>Bạn chưa mở khóa bất kỳ hồ sơ thần số học nào.</p>
                    <a href="/than-so-hoc" class="btn-primary">Tra cứu ngay</a>
                </div>
            ) : (
                <div class="history-list">
                    {numerologyList.map(item => {
                        let dateObj;
                        if (typeof item.created_at === 'number') {
                            dateObj = new Date(item.created_at);
                        } else if (typeof item.created_at === 'string') {
                            const dateStr = item.created_at.replace(' ', 'T') + 'Z';
                            dateObj = new Date(dateStr);
                        } else {
                            dateObj = new Date(); // fallback
                        }
                        
                        const formattedDate = dateObj.toLocaleDateString('vi-VN', {
                            timeZone: 'Asia/Ho_Chi_Minh',
                            year: 'numeric', month: '2-digit', day: '2-digit',
                            hour: '2-digit', minute: '2-digit'
                        });
                        
                        const parts = item.profile_id.split('|');
                        const rawName = parts[0] || 'Bạn Mình';
                        const name = rawName.charAt(0).toUpperCase() + rawName.slice(1);
                        const dob = parts[1] || '';
                        
                        // Định dạng ngày sinh hiển thị
                        const dobParts = dob.split('-');
                        const displayDob = dobParts.length === 3 ? `${dobParts[2]}/${dobParts[1]}/${dobParts[0]}` : dob;

                        return (
                            <a href={`/ket-qua-than-so-hoc?name=${encodeURIComponent(name)}&dob=${encodeURIComponent(dob)}`} class="history-card">
                                <div class="card-icon" style="color: #4ade80;">
                                    <i class="fa-solid fa-infinity" style="font-size: 1.5rem;"></i>
                                </div>
                                <div class="card-info">
                                    <h3 class="card-title">Hồ sơ: {name}</h3>
                                    <div class="card-meta">
                                        <span class="date">Sinh ngày: {displayDob}</span>
                                        <span class="date">• Mở khóa: {formattedDate}</span>
                                    </div>
                                </div>
                                <div class="card-arrow">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                                </div>
                            </a>
                        );
                    })}
                </div>
            )}
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btns = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.tab-content');

            const urlParams = new URLSearchParams(window.location.search);
            const activeTabParam = urlParams.get('tab');

            function activateTab(targetId: string) {
                btns.forEach(b => b.classList.remove('active'));
                contents.forEach(c => c.classList.remove('active'));

                const btn = document.querySelector(`.tab-btn[data-target="${targetId}"]`);
                if (btn) btn.classList.add('active');
                
                const content = document.getElementById(targetId);
                if (content) content.classList.add('active');
            }

            if (activeTabParam === 'yesno') {
                activateTab('tab-yesno');
            } else if (activeTabParam === 'numerology') {
                activateTab('tab-numerology');
            }

            btns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const target = btn.getAttribute('data-target');
                    if (target) {
                        activateTab(target);
                        // Cập nhật URL mà không reload
                        const newUrl = new URL(window.location.href);
                        let tabVal = 'tarot';
                        if (target === 'tab-yesno') tabVal = 'yesno';
                        if (target === 'tab-numerology') tabVal = 'numerology';
                        newUrl.searchParams.set('tab', tabVal);
                        window.history.pushState({}, '', newUrl);
                    }
                });
            });
        });
    </script>

    <style>
        .history-page-container {
            min-height: calc(100vh - 80px);
            padding: 3rem 1rem 5rem 1rem;
            max-width: 900px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }

        .history-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .tabs-container {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .tab-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.7);
            padding: 10px 24px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 1rem;
            font-family: var(--font-body);
            transition: all 0.3s;
        }

        .tab-btn:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .tab-btn.active {
            background: linear-gradient(135deg, #D4AF37 0%, #F2C94C 100%);
            border-color: transparent;
            color: #0b132b;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(242, 201, 76, 0.4);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .title {
            font-family: var(--font-title);
            color: var(--gold-color);
            font-size: clamp(2rem, 5vw, 3rem);
            margin-bottom: 1rem;
            text-shadow: 0 0 15px rgba(242, 201, 76, 0.4);
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1.1rem;
        }

        .empty-state {
            background: rgba(11, 19, 43, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(242, 201, 76, 0.3);
            border-radius: 16px;
            padding: 4rem 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1.5rem;
            opacity: 0.8;
        }

        .empty-state h3 {
            color: var(--gold-color);
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .empty-state p {
            color: #ddd;
            margin-bottom: 2rem;
        }

        .btn-primary {
            display: inline-block;
            background: linear-gradient(135deg, #D4AF37 0%, #F2C94C 100%);
            color: #0b132b;
            padding: 12px 30px;
            border-radius: 8px;
            font-weight: bold;
            text-decoration: none;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(242, 201, 76, 0.4);
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
        }

        .history-card {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1.5rem;
            text-decoration: none;
            transition: all 0.3s;
        }

        .history-card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(242, 201, 76, 0.5);
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .card-icon {
            width: 50px;
            height: 50px;
            background: rgba(242, 201, 76, 0.1);
            color: var(--gold-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1.5rem;
            flex-shrink: 0;
        }

        .card-info {
            flex-grow: 1;
            overflow: hidden;
        }

        .card-title {
            color: #fff;
            font-size: 1.1rem;
            margin: 0 0 0.5rem 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .card-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
        }

        .card-arrow {
            color: rgba(255, 255, 255, 0.3);
            margin-left: 1rem;
            transition: color 0.3s, transform 0.3s;
        }

        .history-card:hover .card-arrow {
            color: var(--gold-color);
            transform: translateX(3px);
        }

        @media (max-width: 600px) {
            .history-card {
                padding: 1rem;
            }
            .card-icon {
                width: 40px;
                height: 40px;
                margin-right: 1rem;
            }
            .card-title {
                font-size: 1rem;
            }
            .title {
                font-size: 2rem;
            }
        }
    </style>
</BaseLayout>
