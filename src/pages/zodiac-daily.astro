---
// 1. IMPORT
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/zodiac-daily.css';

// 2. TẠO METADATA VÀ SCHEMA
const pageTitle = "Zodiac Tarot Hàng Ngày - Lá Bài Cung Hoàng Đạo | Phở Gõ Tarot";
const pageDesc = "Khám phá lá bài Tarot hàng ngày cho 12 cung hoàng đạo. Nhận thông điệp và lời khuyên từ vũ trụ cho Bạch Dương, Kim Ngưu, Song Tử, v.v.";
const pageUrl = new URL('/zodiac-daily', Astro.site).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDesc,
  "url": pageUrl,
  "isPartOf": {
    "@type": "WebSite",
    "url": Astro.site ? Astro.site.href : "https://phogotarot.com/"
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
>

    <main id="zodiac-page-content">
        <div class="zodiac-container">
            
            <div class="page-header-center">
                 <h1 class="title">Thông Điệp Zodiac Hàng Ngày</h1>
                 <p class="subtitle">Chọn cung hoàng đạo của bạn để nhận lời khuyên từ vũ trụ</p>
            </div>

            <div class="zodiac-main-content">

                <!-- HEADER CUNG -->
                <div class="zodiac-header">
                    <div class="zodiac-title-group">
                        <h2 id="main-zodiac-name" class="zodiac-title">Bạch Dương</h2>
                    </div>
                    <span id="main-zodiac-date" class="zodiac-date"></span>
                </div>

                <!-- GRID DESKTOP -->
                <div id="zodiac-selector" class="zodiac-grid">
                    <button class="zodiac-btn active" data-zodiac="Bạch Dương"><span class="zodiac-icon">♈</span> Bạch Dương</button>
                    <button class="zodiac-btn" data-zodiac="Kim Ngưu"><span class="zodiac-icon">♉</span> Kim Ngưu</button>
                    <button class="zodiac-btn" data-zodiac="Song Tử"><span class="zodiac-icon">♊</span> Song Tử</button>
                    <button class="zodiac-btn" data-zodiac="Cự Giải"><span class="zodiac-icon">♋</span> Cự Giải</button>
                    <button class="zodiac-btn" data-zodiac="Sư Tử"><span class="zodiac-icon">♌</span> Sư Tử</button>
                    <button class="zodiac-btn" data-zodiac="Xử Nữ"><span class="zodiac-icon">♍</span> Xử Nữ</button>
                    <button class="zodiac-btn" data-zodiac="Thiên Bình"><span class="zodiac-icon">♎</span> Thiên Bình</button>
                    <button class="zodiac-btn" data-zodiac="Bọ Cạp"><span class="zodiac-icon">♏</span> Bọ Cạp</button>
                    <button class="zodiac-btn" data-zodiac="Nhân Mã"><span class="zodiac-icon">♐</span> Nhân Mã</button>
                    <button class="zodiac-btn" data-zodiac="Ma Kết"><span class="zodiac-icon">♑</span> Ma Kết</button>
                    <button class="zodiac-btn" data-zodiac="Bảo Bình"><span class="zodiac-icon">♒</span> Bảo Bình</button>
                    <button class="zodiac-btn" data-zodiac="Song Ngư"><span class="zodiac-icon">♓</span> Song Ngư</button>
                </div>
                
                <!-- DROPDOWN MOBILE -->
                <div class="zodiac-dropdown-container">
                    <button id="zodiac-dropdown-toggle" class="zodiac-dropdown-toggle">
                        <span id="zodiac-dropdown-label">
                            <span class="zodiac-icon">♈</span> Bạch Dương
                        </span>
                        <svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.06z" clip-rule="evenodd"></path>
                        </svg>
                    </button>
                    <div id="zodiac-dropdown-list" class="zodiac-dropdown-menu">
                        <button class="zodiac-btn-dropdown active" data-zodiac="Bạch Dương"><span class="zodiac-icon">♈</span> Bạch Dương</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Kim Ngưu"><span class="zodiac-icon">♉</span> Kim Ngưu</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Song Tử"><span class="zodiac-icon">♊</span> Song Tử</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Cự Giải"><span class="zodiac-icon">♋</span> Cự Giải</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Sư Tử"><span class="zodiac-icon">♌</span> Sư Tử</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Xử Nữ"><span class="zodiac-icon">♍</span> Xử Nữ</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Thiên Bình"><span class="zodiac-icon">♎</span> Thiên Bình</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Bọ Cạp"><span class="zodiac-icon">♏</span> Bọ Cạp</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Nhân Mã"><span class="zodiac-icon">♐</span> Nhân Mã</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Ma Kết"><span class="zodiac-icon">♑</span> Ma Kết</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Bảo Bình"><span class="zodiac-icon">♒</span> Bảo Bình</button>
                        <button class="zodiac-btn-dropdown" data-zodiac="Song Ngư"><span class="zodiac-icon">♓</span> Song Ngư</button>
                    </div>
                </div>

                <!-- KHU VỰC HIỂN THỊ LÁ BÀI -->
                <div id="card-display" class="zodiac-card-display">
                    
                    <div class="zodiac-card-layout">
                        <!-- Ảnh lá bài -->
                        <div class="zodiac-card-image-wrapper">
                            <div class="zodiac-card-image-aspect">
                                <img id="card-image" 
                                     src="https://placehold.co/300x500/142850/f0f0ff?text=Loading" 
                                     alt="Hình ảnh lá bài Tarot" 
                                     class="zodiac-card-image">
                            </div>
                        </div>

                        <!-- Thông tin chính -->
                        <div class="zodiac-card-details">
                            <div class="zodiac-card-header">
                                <h3 id="card-prefix" class="card-prefix"></h3>
                                <h2 id="card-name" class="card-name"></h2>
                            </div>
                            
                            <div class="card-advice-group">
                                <span class="card-advice-label"><i class="fa-solid fa-key"></i> Từ khóa:</span>
                                <p id="card-advice" class="card-advice"></p>
                            </div>

                            <div id="card-summary" class="card-summary" style="display: none;"><p></p></div>
                            
                            <!-- (ĐÃ SỬA) Chi tiết may mắn - Danh sách dọc -->
                            <div id="card-lucky-details" class="card-lucky-details">
                                <h4 class="lucky-title">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i> Tín hiệu may mắn
                                </h4>
                                <ul class="lucky-items-list">
                                    <li>
                                        <span class="lucky-label">Màu sắc:</span> 
                                        <span id="lucky-color" class="lucky-value"></span>
                                    </li>
                                    <li>
                                        <span class="lucky-label">Đồ vật:</span> 
                                        <span id="lucky-item" class="lucky-value"></span>
                                    </li>
                                    <li>
                                        <span class="lucky-label">Địa điểm:</span> 
                                        <span id="lucky-place" class="lucky-value"></span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- PHÂN TÍCH CHI TIẾT -->
                    <div class="zodiac-card-analysis">
                        <div id="card-love" class="analysis-item">
                            <h4 class="analysis-title" style="color: #ff8a8a;">
                                <i class="fa-solid fa-heart"></i> Tình cảm
                            </h4>
                            <p></p>
                        </div>
                        <div id="card-work" class="analysis-item">
                            <h4 class="analysis-title" style="color: #82aaff;">
                                <i class="fa-solid fa-briefcase"></i> Công việc
                            </h4>
                            <p></p>
                        </div>
                        <div id="card-finance" class="analysis-item">
                            <h4 class="analysis-title" style="color: #a5d6a7;">
                                <i class="fa-solid fa-money-bill-wave"></i> Tài chính
                            </h4>
                            <p></p>
                        </div>
                    </div>

                    <!-- Lời khuyên -->
                    <div id="card-advice-box" class="zodiac-advice-box">
                        <h4 class="analysis-title" style="color: var(--gold-color, #F2C94C);">
                            <i class="fa-solid fa-lightbulb"></i> Lời khuyên vũ trụ
                        </h4>
                        <div id="card-advice-content" class="advice-content-simple">
                            <p></p>
                        </div>
                    </div>

                    <!-- (ĐÃ SỬA) Nút chia sẻ -->
                    <div style="text-align: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
                        <button id="zodiac-share-btn" class="zodiac-share-btn">
                            <i class="fa-solid fa-share-nodes"></i>
                            Chia sẻ thông điệp này
                        </button>
                    </div>
                    
                </div>

                <!-- SECTION NỘI DUNG TĨNH TỐI ƯU SEO -->
                <section class="zodiac-seo-guide">
                    <div class="seo-divider"></div>
                    
                    <h2 class="seo-main-title">
                        <i class="fa-solid fa-star-and-crescent"></i> 
                        Bí Quyết Kết Nối Năng Lượng 12 Cung Hoàng Đạo & Lá Bài Tarot Hàng Ngày
                    </h2>
                    
                    <p class="seo-lead-text">
                        Chiêm tinh học (Astrology) và Tarot là hai bộ môn huyền học cổ xưa có mối liên kết vô cùng chặt chẽ. Trong khi các cung hoàng đạo vạch ra bản đồ năng lượng bẩm sinh của bạn dưới sự ảnh hưởng của các hành tinh, thì những lá bài Tarot đóng vai trò như một tấm gương phản chiếu trực giác, giúp bạn cụ thể hóa các thông điệp đó thành lời khuyên hành động thực tế mỗi ngày.
                    </p>

                    <div class="seo-grid">
                        <div class="seo-card">
                            <h3 class="seo-card-title">
                                <i class="fa-solid fa-infinity"></i> Cung Hoàng Đạo & Bộ Ẩn Chính (Major Arcana)
                            </h3>
                            <p>
                                Mỗi cung hoàng đạo trong số 12 chòm sao đều được bảo trợ trực tiếp bởi một lá bài đại diện tương ứng trong bộ Ẩn Chính của Tarot. Mối liên kết thiên định này mang lại chiều sâu luận giải vượt trội:
                            </p>
                            <ul class="seo-zodiac-list">
                                <li><strong>Bạch Dương (Aries) — The Emperor (Hoàng Đế):</strong> Đại diện cho ý chí sắt đá, quyền lực, tinh thần tiên phong và khả năng dẫn đầu.</li>
                                <li><strong>Kim Ngưu (Taurus) — The Hierophant (Giáo Hoàng):</strong> Tượng trưng cho sự bền vững, các giá trị truyền thống, kiên nhẫn và tích lũy tri thức.</li>
                                <li><strong>Song Tử (Gemini) — The Lovers (Tình Nhân):</strong> Phản chiếu tư duy nhị nguyên, các mối quan hệ, sự lựa chọn và khả năng giao tiếp linh hoạt.</li>
                                <li><strong>Cự Giải (Cancer) — The Chariot (Chiến Xa):</strong> Thể hiện ý chí kiên cường, sự kiên định vượt qua thử thách cảm xúc để đạt mục tiêu.</li>
                                <li><strong>Sư Tử (Leo) — Strength (Sức Mạnh):</strong> Minh chứng cho sức mạnh tinh thần, lòng dũng cảm, thuần hóa cái tôi hoang dã bằng sự thấu thấu cảm dịu dàng.</li>
                                <li><strong>Xử Nữ (Virgo) — The Hermit (Ẩn Sĩ):</strong> Đại diện cho sự chiêm nghiệm sâu sắc, phân tích kỹ lưỡng và hành trình tìm kiếm chân lý nội tâm.</li>
                                <li><strong>Thiên Bình (Libra) — Justice (Công Lý):</strong> Biểu trưng cho sự cân bằng, công bằng, sự thật và khả năng đưa ra những quyết định khách quan.</li>
                                <li><strong>Bọ Cạp (Scorpio) — Death (Cái Chết):</strong> Tượng trưng cho sự tái sinh, chuyển hóa mạnh mẽ, buông bỏ cái cũ để chào đón năng lượng mới.</li>
                                <li><strong>Nhân Mã (Sagittarius) — Temperance (Tiết Chế):</strong> Phản ánh tinh thần tự do, sự cân bằng giữa lý trí và đam mê, hành trình tìm kiếm ý nghĩa cuộc sống.</li>
                                <li><strong>Ma Kết (Capricorn) — The Devil (Ác Quỷ):</strong> Đối mặt với thế giới vật chất, các ràng buộc, cám dỗ và sự kiên trì vượt qua giới hạn của bản thân.</li>
                                <li><strong>Bảo Bình (Aquarius) — The Star (Ngôi Sao):</strong> Mang đến hy vọng, lý tưởng cao đẹp, tư duy đổi mới sáng tạo và năng lượng chữa lành từ vũ trụ.</li>
                                <li><strong>Song Ngư (Pisces) — The Moon (Mặt Trăng):</strong> Đại diện cho thế giới trực giác nhạy bén, các giấc mơ, tiềm thức và thế giới cảm xúc huyền bí.</li>
                            </ul>
                        </div>

                        <div class="seo-card">
                            <h3 class="seo-card-title">
                                <i class="fa-solid fa-fire-flame-curved"></i> 4 Nhóm Nguyên Tố & 4 Bộ Ẩn Phụ (Minor Arcana)
                            </h3>
                            <p>
                                Để thấu hiểu sâu sắc hơn thông điệp Zodiac Tarot hàng ngày, bạn cần nắm rõ mối quan hệ giữa 4 nhóm nguyên tố tự nhiên trong Chiêm tinh học với 4 bộ ẩn phụ tương ứng của Tarot:
                            </p>
                            <div class="element-grid">
                                <div class="element-box fire">
                                    <h4><i class="fa-solid fa-fire"></i> Nhóm Lửa</h4>
                                    <p class="element-signs">Bạch Dương, Sư Tử, Nhân Mã</p>
                                    <p class="element-suit"><strong>Bộ Gậy (Wands):</strong> Năng lượng rực cháy, hành động mạnh mẽ, sáng tạo đột phá, nhiệt huyết và khát khao chinh phục.</p>
                                </div>
                                <div class="element-box earth">
                                    <h4><i class="fa-solid fa-mountain"></i> Nhóm Đất</h4>
                                    <p class="element-signs">Kim Ngưu, Xử Nữ, Ma Kết</p>
                                    <p class="element-suit"><strong>Bộ Tiền (Pentacles):</strong> Khía cạnh tài chính, sự nghiệp bền vững, các giá trị vật chất thực tế, ổn định và nền móng vững chắc.</p>
                                </div>
                                <div class="element-box air">
                                    <h4><i class="fa-solid fa-wind"></i> Nhóm Khí</h4>
                                    <p class="element-signs">Song Tử, Thiên Bình, Bảo Bình</p>
                                    <p class="element-suit"><strong>Bộ Kiếm (Swords):</strong> Trí tuệ vượt trội, giao tiếp hiệu quả, tư duy logic, quyết đoán và các bài học về mặt tinh thần.</p>
                                </div>
                                <div class="element-box water">
                                    <h4><i class="fa-solid fa-droplet"></i> Nhóm Nước</h4>
                                    <p class="element-signs">Cự Giải, Bọ Cạp, Song Ngư</p>
                                    <p class="element-suit"><strong>Bộ Cúp (Cups):</strong> Kết nối trực tiếp với thế giới cảm xúc, trực giác nhạy bén, các mối quan hệ và sự chữa lành tâm hồn.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="seo-card tips-card">
                        <h3 class="seo-card-title">
                            <i class="fa-solid fa-wand-magic-sparkles"></i> Đón Nhận Thông Điệp Tarot Ngày Mới Đúng Cách
                        </h3>
                        <p>
                            Mỗi ngày mới mang lại một tần số năng lượng khác nhau. Để tận dụng tối đa thông điệp lá bài Tarot hàng ngày theo cung hoàng đạo của mình, hãy áp dụng phương pháp sau:
                        </p>
                        <ol class="seo-steps-list">
                            <li>
                                <strong>Thiết lập không gian yên tĩnh:</strong> Dành ra 1 - 2 phút vào buổi sáng, thở sâu giải phóng những suy nghĩ hỗn loạn để chuẩn bị tâm thế cởi mở đón nhận thông điệp.
                            </li>
                            <li>
                                <strong>Đối chiếu từ khóa với thực tế:</strong> Chú ý đến phần từ khóa và lời khuyên vũ trụ. Xem xét xem có sự kiện hoặc cảm xúc nào trong ngày trùng khớp với thông điệp đó.
                            </li>
                            <li>
                                <strong>Lưu tâm các chỉ dẫn may mắn:</strong> Chỉ dẫn về màu sắc, đồ vật hay địa điểm may mắn là những gợi ý trực giác rất thú vị. Hãy quan sát xung quanh xem chúng xuất hiện như thế nào trong ngày của bạn nhé.
                            </li>
                            <li>
                                <strong>Giữ tâm thế tích cực trước những lá bài thử thách:</strong> Tarot không dự đoán tương lai cố định mà chỉ ra xu hướng năng lượng. Gặp lá bài khó khăn là cơ hội để bạn chủ động chuẩn bị tinh thần và đưa ra quyết định khôn ngoan hơn.
                            </li>
                        </ol>
                    </div>

                    <div class="seo-cta-banner">
                        <div class="seo-cta-text">
                            <h4>🔮 Bạn Cần Câu Trả Lời Sâu Sắc Hơn Cho Vấn Đề Của Mình?</h4>
                            <p>Bên cạnh thông điệp cung hoàng đạo tổng quan hàng ngày, bạn có thể tự mình kết nối năng lượng trực tiếp với Reader AI của Phở Gõ Tarot để khám phá chi tiết các khía cạnh tình cảm, công việc hoặc giải đáp các thắc mắc cụ thể.</p>
                        </div>
                        <div class="seo-cta-links">
                            <a href="/xem-tarot" class="cta-link-btn primary">
                                <i class="fa-solid fa-comments"></i> Trò Chuyện Với AI Reader
                            </a>
                            <a href="/yes-no-reading" class="cta-link-btn secondary">
                                <i class="fa-solid fa-circle-question"></i> Hỏi Đáp Yes/No Nhanh
                            </a>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />



    <script>
        // LOGIC JS
        let tarotData = {};
        const SHEET_ID = '1Bqu2RBPRH-YeCOiX_5SjmQP8GETpKkqBZhMPZwqm_ig';
        const SHEET_NAME = 'Zodiac';

        async function fetchZodiacData() {
            const gvizUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;
            setLoadingState(true);
            try {
                const response = await fetch(gvizUrl);
                if (!response.ok) throw new Error(`Lỗi HTTP! ${response.status}`);
                let text = await response.text();
                const jsonpData = text.match(/google\.visualization\.Query\.setResponse\((.*)\)/s);
                if (!jsonpData || !jsonpData[1]) throw new Error("Lỗi parse JSONP");
                const data = JSON.parse(jsonpData[1]);
                const rows = data.table.rows;
                const processedData = {};
                for (let i = 1; i < rows.length; i++) {
                    const row = rows[i].c;
                    const zodiacSign = row[0]?.v;
                    if (!zodiacSign) continue;
                    processedData[zodiacSign] = {
                        cardname: row[1]?.v || "N/A",
                        url: row[2]?.v || "https://placehold.co/300x500/142850/f0f0ff?text=No+Image",
                        keyword: row[3]?.v || "",
                        love: row[4]?.v || "<p>Chưa có thông tin.</p>",
                        job: row[5]?.v || "<p>Chưa có thông tin.</p>",
                        finance: row[6]?.v || "<p>Chưa có thông tin.</p>",
                        color: row[7]?.v || "N/A",
                        objects: row[8]?.v || "N/A",
                        locations: row[9]?.v || "N/A",
                        advice: row[10]?.v || "<p>Chưa có thông tin.</p>",
                    };
                }
                tarotData = processedData;
                setLoadingState(false);
                return true;
            } catch (error) {
                console.error(error);
                setLoadingState(false, true);
                return false;
            }
        }

        function setLoadingState(isLoading, isError = false) {
            const gridButtons = document.querySelectorAll('.zodiac-btn');
            const dropdownButtons = document.querySelectorAll('.zodiac-btn-dropdown');
            const dropdownToggle = document.getElementById('zodiac-dropdown-toggle');
            const mainZodiacName = document.getElementById('main-zodiac-name');
            const cardDisplay = document.getElementById('card-display');

            if (isLoading) {
                mainZodiacName.textContent = 'Đang tải...';
                cardDisplay.style.opacity = '0.5';
                gridButtons.forEach(btn => btn.disabled = true);
                dropdownButtons.forEach(btn => btn.disabled = true);
                if (dropdownToggle) dropdownToggle.disabled = true;
            } else {
                cardDisplay.style.opacity = '1';
                gridButtons.forEach(btn => btn.disabled = false);
                dropdownButtons.forEach(btn => btn.disabled = false);
                if (dropdownToggle) dropdownToggle.disabled = false;
                if (isError) {
                    mainZodiacName.textContent = 'Lỗi Tải Dữ Liệu';
                    cardDisplay.innerHTML = `<p style="text-align: center; color: #ff8a8a;">Không thể tải dữ liệu.</p>`;
                } else {
                    mainZodiacName.textContent = 'Bạch Dương'; 
                }
            }
        }

        // (ĐÃ SỬA) HÀM CHIA SẺ HOẠT ĐỘNG THỰC SỰ
        async function handleShare() {
            const zodiacName = document.getElementById('main-zodiac-name').textContent;
            const cardName = document.getElementById('card-name').textContent;
            const adviceContent = document.getElementById('card-advice-content').innerText.trim();
            
            const shareData = {
                title: `Thông điệp Tarot cho ${zodiacName}`,
                text: `🔮 Hôm nay ${zodiacName} nhận được lá bài: ${cardName}.\n\n💡 Lời khuyên: ${adviceContent.substring(0, 100)}...\n\nXem chi tiết tại:`,
                url: window.location.href
            };

            try {
                if (navigator.share) {
                    await navigator.share(shareData);
                } else {
                    // Fallback: Copy vào clipboard
                    const copyText = `${shareData.title}\n${shareData.text}\n${shareData.url}`;
                    await navigator.clipboard.writeText(copyText);
                    
                    // Hiệu ứng nút bấm để báo đã copy
                    const shareBtn = document.getElementById('zodiac-share-btn');
                    const originalText = shareBtn.innerHTML;
                    shareBtn.innerHTML = '<i class="fa-solid fa-check"></i> Đã sao chép!';
                    setTimeout(() => {
                        shareBtn.innerHTML = originalText;
                    }, 2000);
                }
            } catch (err) {
                console.error('Lỗi chia sẻ:', err);
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            const zodiacSelector = document.getElementById('zodiac-selector');
            if (!zodiacSelector) return;

            const zodiacDropdownToggle = document.getElementById('zodiac-dropdown-toggle');
            const zodiacDropdownLabel = document.getElementById('zodiac-dropdown-label');
            const zodiacDropdownList = document.getElementById('zodiac-dropdown-list');
            const dropdownButtons = document.querySelectorAll('.zodiac-btn-dropdown');
            const gridButtons = document.querySelectorAll('.zodiac-btn');
            const mainZodiacName = document.getElementById('main-zodiac-name');
            const mainZodiacDate = document.getElementById('main-zodiac-date');
            
            const cardImage = document.getElementById('card-image');
            const cardPrefix = document.getElementById('card-prefix');
            const cardName = document.getElementById('card-name');
            const cardAdvice = document.getElementById('card-advice');
            const cardLove = document.getElementById('card-love').querySelector('p');
            const cardWork = document.getElementById('card-work').querySelector('p');
            const cardFinance = document.getElementById('card-finance').querySelector('p');
            const luckyColor = document.getElementById('lucky-color');
            const luckyItem = document.getElementById('lucky-item');
            const luckyPlace = document.getElementById('lucky-place');
            const cardAdviceContent = document.getElementById('card-advice-content');
            const shareBtn = document.getElementById('zodiac-share-btn'); 

            mainZodiacDate.textContent = new Date().toLocaleDateString('vi-VN');
            const success = await fetchZodiacData();
            if (!success) return;

            function updateZodiacContent(zodiacName) {
                const data = tarotData[zodiacName];
                mainZodiacName.textContent = zodiacName;
                if (data) {
                    const parts = (data.cardname || "").split(' ');
                    let prefix = '';
                    let name = data.cardname || "N/A";
                    if (parts.length > 1 && parts[0].toLowerCase() === 'the') {
                        prefix = parts[0];
                        name = parts.slice(1).join(' ');
                    }
                    cardImage.src = data.url;
                    cardImage.alt = `Hình ảnh lá bài ${data.cardname}`;
                    cardPrefix.textContent = prefix;
                    cardName.textContent = name;
                    cardAdvice.textContent = data.keyword;
                    cardLove.innerHTML = data.love;
                    cardWork.innerHTML = data.job;
                    cardFinance.innerHTML = data.finance;
                    luckyColor.textContent = data.color;
                    luckyItem.textContent = data.objects;
                    luckyPlace.textContent = data.locations;
                    cardAdviceContent.innerHTML = data.advice;
                }
            }
            
            function setActiveZodiac(zodiacName) {
                gridButtons.forEach(btn => btn.classList.remove('active'));
                dropdownButtons.forEach(btn => btn.classList.remove('active'));
                const matchingGridBtn = document.querySelector(`.zodiac-btn[data-zodiac="${zodiacName}"]`);
                if (matchingGridBtn) matchingGridBtn.classList.add('active');
                const matchingDropdownBtn = document.querySelector(`.zodiac-btn-dropdown[data-zodiac="${zodiacName}"]`);
                if (matchingDropdownBtn) {
                    matchingDropdownBtn.classList.add('active');
                    if (zodiacDropdownLabel) zodiacDropdownLabel.innerHTML = matchingDropdownBtn.innerHTML;
                }
            }

            gridButtons.forEach(button => {
                button.addEventListener('click', () => {
                    const zodiacName = button.dataset.zodiac;
                    setActiveZodiac(zodiacName);
                    updateZodiacContent(zodiacName);
                });
            });

            if (zodiacDropdownToggle) {
                zodiacDropdownToggle.addEventListener('click', () => {
                    zodiacDropdownList.classList.toggle('open');
                    zodiacDropdownToggle.classList.toggle('open');
                });
                dropdownButtons.forEach(button => {
                    button.addEventListener('click', () => {
                        const zodiacName = button.dataset.zodiac;
                        setActiveZodiac(zodiacName);
                        updateZodiacContent(zodiacName);
                        zodiacDropdownList.classList.remove('open');
                        zodiacDropdownToggle.classList.remove('open');
                    });
                });
                document.addEventListener('click', (e) => {
                    if (document.querySelector('.zodiac-dropdown-container') && !document.querySelector('.zodiac-dropdown-container').contains(e.target)) {
                        zodiacDropdownList.classList.remove('open');
                        zodiacDropdownToggle.classList.remove('open');
                    }
                });
            }

            if (shareBtn) {
                shareBtn.addEventListener('click', handleShare);
            }

            updateZodiacContent('Bạch Dương');
            setActiveZodiac('Bạch Dương');
        });
    </script>
</BaseLayout>