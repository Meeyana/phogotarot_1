---
// 1. IMPORT
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbListSchema, graphSchema, webPageSchema } from '../lib/schema';

// 2. TẠO METADATA VÀ SCHEMA
const pageTitle = "Chính Sách Quyền Riêng Tư | Phở Gõ Tarot";
const pageDesc = "Tìm hiểu cách Phở Gõ Tarot thu thập, sử dụng và bảo vệ thông tin cá nhân của bạn khi bạn sử dụng dịch vụ xem Tarot online.";
const pageUrl = new URL('/privacy-policy', Astro.site).href;

const schema = graphSchema([
  webPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc, type: 'WebPage' }),
  breadcrumbListSchema(pageUrl, [
    { name: 'Trang chủ', url: '/' },
    { name: pageTitle.replace(' | Phở Gõ Tarot', ''), url: '/privacy-policy' }
  ])
]);
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
>
    <main id="privacy-policy-content">
        <section class="homepage-section" style="padding-top: 3rem; min-height: 80vh;">
            <div class="container text-content-container">
                
                <h2 class="section-title" style="text-align: left; margin-bottom: 2rem;">
                    Chính Sách Quyền Riêng Tư
                </h2>

                <p class="section-text"><em>Cập nhật lần cuối: 30/05/2026</em></p>

                <!-- MỤC LỤC -->
                <div class="toc-box">
                    <h3 class="toc-title">Mục lục</h3>
                    <ul class="toc-list">
                        <li><a href="#muc-1">1. Giới thiệu</a></li>
                        <li><a href="#muc-2">2. Thông tin chúng tôi thu thập</a></li>
                        <li><a href="#muc-3">3. Chúng tôi sử dụng thông tin của bạn như thế nào</a></li>
                        <li><a href="#muc-4">4. Dịch vụ bên thứ ba & Xử lý thanh toán</a></li>
                        <li><a href="#muc-5">5. Cookies và Công nghệ theo dõi</a></li>
                        <li><a href="#muc-6">6. An toàn dữ liệu & Miễn trừ rủi ro bảo mật</a></li>
                        <li><a href="#muc-7">7. Quyền của bạn & Quyền tự xóa vĩnh viễn dữ liệu lịch sử</a></li>
                        <li><a href="#muc-8">8. Quyền riêng tư của trẻ em</a></li>
                        <li><a href="#muc-9">9. Thay đổi chính sách</a></li>
                        <li><a href="#muc-10">10. Liên hệ với chúng tôi</a></li>
                    </ul>
                </div>

                <!-- NỘI DUNG CHÍNH SÁCH -->
                
                <h3 class="section-subtitle" id="muc-1">1. Giới thiệu</h3>
                <p class="section-text">Chào mừng bạn đến với Phở Gõ Tarot ("chúng tôi"). Chúng tôi cam kết bảo vệ tối đa quyền riêng tư của khách truy cập và người dùng ("bạn") khi trải nghiệm dịch vụ bói bài Tarot trực tuyến, xem thần số học và các tính năng giải trí trên website. Chính sách Quyền riêng tư này giải thích rõ ràng và minh bạch cách chúng tôi thu thập, sử dụng, lưu trữ và bảo vệ thông tin của bạn. Bằng việc truy cập hoặc tạo tài khoản trên Phở Gõ Tarot, bạn xác nhận đồng ý với toàn bộ nội dung của Chính sách này.</p>

                <h3 class="section-subtitle" id="muc-2">2. Thông tin chúng tôi thu thập</h3>
                <p class="section-text">Để duy trì và vận hành các dịch vụ cá nhân hóa chất lượng cao, chúng tôi thu thập các nhóm thông tin sau:</p>
                <ul class="section-list">
                    <li><strong>Thông tin hồ sơ tài khoản:</strong> Khi bạn đăng ký hoặc đăng nhập thông qua bên thứ ba (như Google), chúng tôi có thể nhận được tên hiển thị, địa chỉ email và ảnh đại diện (avatar) của bạn để thiết lập tài khoản.</li>
                    <li><strong>Thông tin đầu vào để trải bài & Phân tích thần số học:</strong> Bao gồm tên đầy đủ của bạn, ngày giờ sinh (phục vụ lập biểu đồ Thần số học) và câu hỏi/chủ đề bạn gửi cho AI Oracle Chatbot hoặc AI Tarot Reader.</li>
                    <li><strong>Lịch sử hội thoại & Trải bài:</strong> Kết quả các lá bài bạn rút được, câu hỏi và nội dung phân tích của AI sẽ được lưu trữ trong cơ sở dữ liệu để bạn có thể xem lại trong mục "Lịch sử" khi đăng nhập.</li>
                    <li><strong>Thông tin giao dịch thanh toán:</strong> Khi bạn thực hiện nạp Credit hoặc nâng cấp gói dịch vụ, chúng tôi thu thập thông tin về giao dịch bao gồm số tiền, thời gian, gói dịch vụ và mã tham chiếu giao dịch. Chúng tôi tuyệt đối không trực tiếp thu thập, lưu trữ thông tin số thẻ tín dụng hoặc thông tin đăng nhập ngân hàng của bạn.</li>
                    <li><strong>Thông tin thu thập tự động:</strong> Khi bạn truy cập website, chúng tôi tự động ghi nhận một số siêu dữ liệu hệ thống như địa chỉ IP, loại trình duyệt, hệ điều hành, đường dẫn URL giới thiệu, thời gian truy cập và các trang bạn tương tác nhằm mục đích bảo mật và cải thiện kỹ thuật.</li>
                </ul>

                <h3 class="section-subtitle" id="muc-3">3. Chúng tôi sử dụng thông tin của bạn như thế nào</h3>
                <p class="section-text">Chúng tôi sử dụng dữ liệu thu thập được cho các mục đích hợp pháp và có giới hạn sau đây:</p>
                <ul class="section-list">
                    <li><strong>Vận hành dịch vụ:</strong> Nhận dạng người dùng, quản lý số dư Credit, hiển thị lịch sử trải bài và đưa ra câu trả lời Tarot/Thần số học cá nhân hóa.</li>
                    <li><strong>Cải tiến kỹ thuật & Trí tuệ nhân tạo:</strong> Phân tích hành vi chung của người dùng để cải thiện độ mượt mà của giao diện, tối ưu hóa các prompt gửi đến mô hình AI để phản hồi thông minh hơn.</li>
                    <li><strong>Bảo mật hệ thống:</strong> Giám sát ngăn chặn các hành vi gian lận, cố tình hack hệ thống, lạm dụng rút bài vô hạn hoặc spam tài nguyên máy chủ.</li>
                    <li><strong>Gửi thông tin quan trọng:</strong> Thông báo về các cập nhật hệ thống quan trọng, thay đổi điều khoản dịch vụ hoặc các chính sách kỹ thuật cần thiết.</li>
                </ul>

                <h3 class="section-subtitle" id="muc-4">4. Dịch vụ bên thứ ba & Xử lý thanh toán</h3>
                <p class="section-text">Chúng tôi cộng tác với một số nhà cung cấp dịch vụ bên thứ ba đáng tin cậy để vận hành website:</p>
                <ul class="section-list">
                    <li><strong>Công nghệ AI:</strong> Dữ liệu câu hỏi của bạn được gửi qua API bảo mật đến các mô hình ngôn ngữ lớn của bên thứ ba (như OpenAI, Google Gemini). Các API này được cấu hình ở chế độ bảo mật nghiêm ngặt và không sử dụng dữ liệu của bạn để huấn luyện mô hình công cộng.</li>
                    <li><strong>Cổng thanh toán:</strong> Mọi giao dịch nạp Credit được thực hiện thông qua các cổng thanh toán hoặc ngân hàng thương mại uy tín. Quá trình xử lý thanh toán hoàn toàn tuân thủ các tiêu chuẩn bảo mật tài chính quốc tế và nằm ngoài phạm vi lưu trữ dữ liệu trực tiếp của Phở Gõ Tarot.</li>
                    <li><strong>Google Analytics:</strong> Được sử dụng để phân tích ẩn danh hành vi truy cập nhằm cải thiện trải nghiệm tổng thể của trang web.</li>
                </ul>

                <h3 class="section-subtitle" id="muc-5">5. Cookies và Công nghệ theo dõi</h3>
                <p class="section-text">Chúng tôi sử dụng cookie và các công nghệ theo dõi tương tự (như LocalStorage) để duy trì phiên đăng nhập của bạn, ghi nhớ cấu hình giao diện cá nhân (như các lá bài Tarot bạn đang rút dở) và tối ưu hóa tốc độ tải trang. Bạn hoàn toàn có quyền cấu hình trình duyệt để từ chối hoặc xóa cookie bất cứ lúc nào, tuy nhiên điều này có thể khiến một số tính năng đăng nhập tự động hoặc lưu trạng thái trải bài không thể hoạt động chính xác.</p>

                <h3 class="section-subtitle" id="muc-6">6. An toàn dữ liệu & Miễn trừ rủi ro bảo mật</h3>
                <p class="section-text">Phở Gõ Tarot cam kết áp dụng các biện pháp bảo mật công nghệ, mã hóa dữ liệu truyền tải (SSL/HTTPS) và phân quyền quản trị nội bộ chặt chẽ để bảo vệ thông tin cá nhân của bạn khỏi các hành vi truy cập trái phép. 
                Tuy nhiên, do đặc thù truyền tải thông tin trên môi trường Internet toàn cầu, không có phương thức bảo mật nào là an toàn 100%. Bằng cách sử dụng website, bạn xác nhận hiểu rõ và đồng ý chấp nhận các rủi ro bảo mật tiềm ẩn này, đồng thời miễn trừ trách nhiệm pháp lý cho Phở Gõ Tarot trong trường hợp xảy ra các sự cố rò rỉ dữ liệu do các cuộc tấn công mạng có chủ đích, phần mềm độc hại hoặc các lỗ hổng kỹ thuật nằm ngoài khả năng phòng vệ hợp lý của chúng tôi.</p>

                <h3 class="section-subtitle" id="muc-7">7. Quyền của bạn & Quyền tự xóa vĩnh viễn dữ liệu lịch sử</h3>
                <p class="section-text">Chúng tôi tôn trọng tuyệt đối quyền kiểm soát dữ liệu cá nhân của bạn. Bạn được đảm bảo các quyền hạn tối cao sau đây:</p>
                <ul class="section-list">
                    <li><strong>Quyền tự tra cứu và chỉnh sửa:</strong> Bạn có thể dễ dàng truy cập trang "Hồ sơ" để kiểm tra và cập nhật các thông tin tài khoản cơ bản bất kỳ lúc nào.</li>
                    <li><strong>Quyền tự xóa vĩnh viễn lịch sử trải bài:</strong> Để bảo vệ quyền riêng tư tuyệt đối, chúng tôi cung cấp tính năng tự phục vụ (Self-service). Bạn có thể truy cập trực tiếp vào trang <strong><a href="/history" style="color: var(--gold-color, #F2C94C); text-decoration: underline;">Lịch sử</a></strong> (hoặc mở bảng lịch sử rút bài) và bấm vào nút <strong>"Xóa tất cả" / "Xóa lịch sử"</strong>. Hành động này sẽ gửi lệnh trực tiếp xóa vĩnh viễn toàn bộ dữ liệu câu hỏi và diễn giải Tarot của bạn khỏi cơ sở dữ liệu hoạt động của hệ thống ngay lập tức và không thể khôi phục lại.</li>
                    <li><strong>Quyền yêu cầu xóa tài khoản:</strong> Bạn có quyền gửi yêu cầu bằng văn bản đến địa chỉ email hỗ trợ của chúng tôi để yêu cầu xóa vĩnh viễn toàn bộ tài khoản và các thông tin hồ sơ liên quan khỏi hệ thống của Phở Gõ Tarot.</li>
                </ul>

                <h3 class="section-subtitle" id="muc-8">8. Quyền riêng tư của trẻ em</h3>
                <p class="section-text">Trang web này tuyệt đối không hướng tới đối tượng người dùng dưới 18 tuổi. Chúng tôi không cố ý thu thập thông tin nhận dạng cá nhân từ trẻ em dưới 18 tuổi. Nếu bạn là cha mẹ hoặc người giám hộ và phát hiện trẻ em dưới 18 tuổi do bạn quản lý đã tự ý tạo tài khoản và cung cấp thông tin cá nhân trên Phở Gõ Tarot, vui lòng liên hệ ngay với chúng tôi để chúng tôi tiến hành xóa vĩnh viễn tài khoản đó khỏi hệ thống.</p>

                <h3 class="section-subtitle" id="muc-9">9. Thay đổi chính sách</h3>
                <p class="section-text">Chúng tôi có toàn quyền sửa đổi, bổ sung hoặc cập nhật Chính sách Quyền riêng tư này vào bất kỳ lúc nào để phù hợp với sự phát triển của công nghệ và các quy định pháp luật mới. Phiên bản thay đổi sẽ có hiệu lực ngay sau khi được đăng tải công khai trên trang này. Việc bạn tiếp tục sử dụng website sau thời điểm chính sách cập nhật được đăng tải cấu thành sự đồng ý hoàn toàn và vô điều kiện của bạn đối với các nội dung thay đổi đó.</p>

                <h3 class="section-subtitle" id="muc-10">10. Liên hệ với chúng tôi</h3>
                <p class="section-text">Nếu bạn có câu hỏi hoặc nhận xét về Chính sách Quyền riêng tư này, vui lòng liên hệ với chúng tôi qua email: <strong>contact@phogotarot.com</strong> hoặc qua trang Liên hệ của chúng tôi.</p>

            </div>
        </section>
    </main>
    
    <script 
      type="application/ld+json" 
      slot="head"
      set:html={JSON.stringify(schema)}
    />

    <style>
        /* Lấy style từ disclaimer.astro */
        .homepage-section { 
            padding: 4rem 1rem; 
            position: relative;
        }
        .container { 
            max-width: 1400px; 
            margin: auto; 
            padding: 0;
        }
        
        .section-title { 
            font-family: var(--font-title); 
            color: var(--title-color); 
            font-size: 3rem; 
            margin-bottom: 3rem; 
            text-align: center;
        }

        .section-subtitle { 
            font-family: var(--font-title); 
            color: var(--title-color); 
            font-size: 1.75rem;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            /* (MỚI) Thêm lề trên để anchor link không bị che */
            scroll-margin-top: 5rem;
        }
        
        .section-text { 
            font-size: 1rem;
            opacity: 0.9; 
            margin-bottom: 1.5rem; 
            text-shadow: none; 
            line-height: 1.8;
        }

        .text-content-container {
            max-width: 900px;
            padding: 0 1rem;
            text-align: left;
        }

        .section-list {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.8;
            margin-bottom: 1.5rem;
            padding-left: 2rem;
        }
        .section-list li {
            margin-bottom: 0.75rem;
        }

        /* (MỚI) Style cho Mục Lục (TOC) */
        .toc-box {
            background-color: var(--button-bg);
            border: 1px solid var(--card-back-border);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin-bottom: 3rem;
        }
        .toc-title {
            font-family: var(--font-title);
            color: var(--title-color);
            font-size: 1.5rem;
            margin-top: 0;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--card-back-border);
            padding-bottom: 1rem;
        }
        .toc-list {
            list-style-type: none;
            padding-left: 0;
            margin: 0;
            columns: 2; /* Hiển thị 2 cột trên desktop */
        }
        .toc-list li {
            margin-bottom: 1rem;
        }
        .toc-list a {
            text-decoration: none;
            color: var(--text-color);
            font-weight: 600;
            font-size: 0.95rem;
            opacity: 0.9;
        }
        .toc-list a:hover {
            color: var(--title-color);
            opacity: 1;
        }

        /* Responsive cho TOC trên mobile */
        @media (max-width: 600px) {
            .toc-list {
                columns: 1; /* 1 cột trên mobile */
            }
            .section-title {
                font-size: 2.5rem; /* Giảm cỡ chữ tiêu đề trên mobile */
            }
        }
    </style>
</BaseLayout>