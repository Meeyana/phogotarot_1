---
import BaseLayout from '../layouts/BaseLayout.astro';

// Biến cấu hình Ngân Hàng
const BANK_ID = "VPB"; // VP Bank
const ACCOUNT_NO = "0943524970"; // Số tài khoản
const ACCOUNT_NAME = "PHAN DINH TUAN"; // Tên chủ tài khoản (bạn có thể đổi lại tên thật)

const title = "Nạp Credit - Phở Gõ Tarot";
const description = "Nạp Credit để tiếp tục trải nghiệm luận giải Tarot sâu sắc và cá nhân hóa từ Phở Gõ Tarot.";

// Yêu cầu đăng nhập để hiển thị email trong mã QR
const user = Astro.locals.user;
---

<BaseLayout title={title} description={description}>
    <main class="pricing-page">
        <div class="pricing-header">
            <h1 class="pricing-title">Bảng Giá Dịch Vụ</h1>
            <p class="pricing-subtitle">Chọn một gói Credit phù hợp để khám phá thông điệp sâu sắc từ vũ trụ</p>
        </div>

        <div class="pricing-cards">
            <!-- Gói 1: Cơ Bản (với Credit Toggle) -->
            <div class="pricing-card">
                <div class="card-header">
                    <h3>Cơ Bản</h3>
                    
                    <!-- Dynamic Price hiển thị trước -->
                    <div class="price-wrapper">
                        <div class="original-price" id="basic-original-display">₫69.000</div>
                        <div class="price" id="basic-price-display">
                            <span class="currency">₫</span><span id="basic-amount-display">49.000</span>
                        </div>
                    </div>

                    <p class="desc">Dành cho lữ khách bắt đầu hành trình tự khám phá bản thân</p>

                    <!-- Credit Toggle Switch -->
                    <div class="billing-toggle-container">
                        <button class="basic-toggle-btn active" data-credits="3">3 Credit</button>
                        <button class="basic-toggle-btn" data-credits="10">10 Credit</button>
                    </div>

                    <!-- Subtext tiết kiệm cho gói cơ bản -->
                    <p class="basic-desc-sub" id="basic-price-subtext" style="display: none;"></p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-check"></i> <span>Dùng cho trải bài Tarot, Hỏi đáp Yes/No hoặc Thần số học</span></li>
                        <li><i class="fa-solid fa-check"></i> <span>Mở khóa bản đồ Thần số học chuyên sâu chi tiết</span></li>
                        <li><i class="fa-solid fa-check"></i> <span><strong>Sử dụng vĩnh viễn</strong>, không giới hạn thời gian</span></li>
                        <li><i class="fa-solid fa-check"></i> <span>Luận giải chi tiết chuẩn xác cùng Reader AI</span></li>
                    </ul>
                </div>
                <button class="select-plan-btn premium-btn" id="basic-buy-btn" data-amount="49000" data-package="Khởi Đầu (3 lượt)">Chọn Gói Này</button>
            </div>

            <!-- Gói 2: Nâng Cao (Premium với Billing Toggle) -->
            <div class="pricing-card premium-tier">
                <div class="card-header">
                    <h3><i class="fa-solid fa-crown"></i> Nâng Cao</h3>

                    <!-- Price hiển thị trước -->
                    <div class="price-wrapper">
                        <div class="original-price" id="premium-original-display">₫399.000/tháng</div>
                        <div class="price" id="premium-price-display">
                            <span class="currency">₫</span><span id="premium-amount-display">199.000</span><span class="period" id="premium-period-display">/tháng</span>
                        </div>
                    </div>

                    <p class="desc">Trải nghiệm tâm linh tối thượng không giới hạn tính năng</p>

                    <!-- Billing Toggle Switch — Hàng Tháng / Hàng Năm -->
                    <div class="billing-toggle-container">
                        <button class="billing-toggle-btn active" data-billing="monthly">Hàng Tháng</button>
                        <button class="billing-toggle-btn" data-billing="yearly">Hàng Năm</button>
                    </div>

                    <!-- Subtext tiết kiệm -->
                    <p class="premium-desc-sub" id="premium-price-subtext" style="display: none;"></p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-infinity"></i> <span><strong>Vô hạn</strong> bốc bài Tarot và Hỏi đáp Yes/No</span></li>
                        <li><i class="fa-solid fa-infinity"></i> <span><strong>Vô hạn</strong> giải mã Thần số học chuyên sâu</span></li>
                        <li><i class="fa-solid fa-star"></i> <span>Mở khóa toàn bộ trải bài nâng cao & độc quyền</span></li>
                        <li><i class="fa-solid fa-clock-rotate-left"></i> <span>Lưu trữ lịch sử trải bài vĩnh viễn trong tài khoản</span></li>
                        <li><i class="fa-solid fa-wand-magic-sparkles"></i> <span><strong>Ưu tiên trải nghiệm</strong> các tính năng mới sớm nhất</span></li>
                    </ul>
                </div>
                <button class="select-plan-btn premium-btn" id="premium-buy-btn" data-amount="199000" data-package="Vương Giả (Gói Tháng)">Trở Thành VIP</button>
            </div>
        </div>

        <div class="faq-section">
            <h2 class="faq-title">Câu Hỏi Thường Gặp</h2>
            <div class="faq-container">
                <details class="faq-item">
                    <summary class="faq-question">Lượt Free mỗi ngày là gì?</summary>
                    <div class="faq-answer">
                        <p>Mỗi tài khoản được hệ thống tặng 1 lượt xem bài hoàn toàn miễn phí vào 0:00 hàng ngày. Lượt Free không được cộng dồn sang ngày hôm sau.</p>
                    </div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Lượt mua lẻ có bị mất đi không?</summary>
                    <div class="faq-answer">
                        <p>Không. Tất cả các gói mua lẻ (Cơ Bản) đều có giá trị vĩnh viễn cho đến khi bạn sử dụng hết.</p>
                    </div>
                </details>
                <details class="faq-item">
                    <summary class="faq-question">Credit dùng được cho những tính năng nào?</summary>
                    <div class="faq-answer">
                        <p>Bạn có thể sử dụng Credit cho mọi hoạt động trải bài trên Phở Gõ Tarot, bao gồm Trò Chuyện & Trải Bài (1, 3, hoặc 5 lá bốc bài kèm luận giải chi tiết) và Hỏi Đáp Yes/No tức thì.</p>
                    </div>
                </details>
            </div>
        </div>
    </main>

    <!-- Payment Modal -->
    <div id="payment-modal" class="payment-modal-backdrop">
        <div class="payment-modal-content">
            <button class="close-modal-btn" aria-label="Close"><i class="fa-solid fa-times"></i></button>
            <div class="payment-modal-header">
                <h2>Thanh Toán Chuyển Khoản</h2>
                <p>Bạn đang chọn: <strong id="selected-package-name" style="color: var(--gold-color);"></strong></p>
            </div>
            
            <div class="payment-modal-body">
                <div class="qr-code-wrapper">
                    <img id="vietqr-image" src="" alt="Mã QR Thanh Toán" />
                    <div class="qr-loading">Đang tạo mã QR...</div>
                </div>
                
                <div class="transfer-info">
                    <div class="info-row">
                        <span>Ngân hàng:</span>
                        <strong>TMCP Việt Nam Thịnh Vượng - VPBank</strong>
                    </div>
                    <div class="info-row">
                        <span>Số tài khoản:</span>
                        <strong class="copyable" data-copy="{ACCOUNT_NO}">{ACCOUNT_NO} <i class="fa-regular fa-copy"></i></strong>
                    </div>
                    <div class="info-row">
                        <span>Chủ tài khoản:</span>
                        <strong>{ACCOUNT_NAME}</strong>
                    </div>
                    <div class="info-row">
                        <span>Số tiền:</span>
                        <strong class="amount-highlight" id="modal-amount">...</strong>
                    </div>
                    <div class="info-row content-row">
                        <span>Nội dung chuyển khoản:</span>
                        <div class="transfer-content copyable" id="transfer-content-text" data-copy="">
                            <span id="transfer-content-display">...</span> <i class="fa-regular fa-copy"></i>
                        </div>
                    </div>
                    <p class="transfer-warning"><i class="fa-solid fa-triangle-exclamation"></i> Bắt buộc nhập ĐÚNG NỘI DUNG chuyển khoản để hệ thống tự động cộng Credit.</p>
                </div>
            </div>
            
            <div class="payment-modal-footer">
                <button class="confirm-paid-btn">Tôi đã chuyển khoản</button>
            </div>
        </div>
    </div>

    <!-- Toast Snackbar (error/info) -->
    <div id="toast-container"></div>

    <!-- Success Popup -->
    <div id="success-popup">
        <div class="success-popup-card">
            <div class="success-icon-ring">
                <i class="fa-solid fa-check"></i>
            </div>
            <div class="success-popup-title">Thanh toán thành công!</div>
            <div class="success-popup-message">Credit đã được cộng vào tài khoản của bạn.<br>Chúc bạn trải nghiệm vui vẻ! 🌟</div>
            <button class="success-popup-btn" id="success-popup-close">Tuyệt vời!</button>
        </div>
    </div>
    <!-- Confetti Script -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
</BaseLayout>

<style>
    /* CSS Setup */
    .pricing-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 20px;
        min-height: 80vh;
    }

    .pricing-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .pricing-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        color: var(--gold-color, #F2C94C);
        margin-bottom: 15px;
        text-shadow: 0 0 15px rgba(242, 201, 76, 0.3);
    }

    .pricing-subtitle {
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.1rem;
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 35px;
        margin-bottom: 80px;
        align-items: stretch;
        max-width: 860px;
        margin-left: auto;
        margin-right: auto;
    }

    .pricing-card {
        background: linear-gradient(135deg, rgba(20, 25, 45, 0.75) 0%, rgba(10, 15, 30, 0.9) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 45px 30px;
        width: 100%;
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .pricing-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0) 100%);
        opacity: 0.8;
        pointer-events: none;
        transition: opacity 0.3s;
    }

    .pricing-card:hover {
        transform: translateY(-8px) scale(1.01);
        border-color: rgba(242, 201, 76, 0.35);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(242, 201, 76, 0.12);
    }

    .pricing-card:hover::before {
        opacity: 1;
    }

    .pricing-card.premium-tier {
        background: linear-gradient(135deg, rgba(32, 25, 48, 0.85) 0%, rgba(15, 12, 28, 0.95) 100%);
        border: 1px solid rgba(255, 215, 0, 0.45);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.65), 0 0 35px rgba(255, 215, 0, 0.08);
    }

    .pricing-card.premium-tier::before {
        background: linear-gradient(135deg, rgba(255, 215, 0, 0.08) 0%, rgba(255, 215, 0, 0) 100%);
    }

    .pricing-card.premium-tier::after {
        content: '';
        position: absolute;
        top: -20%;
        left: -20%;
        width: 140%;
        height: 140%;
        background: radial-gradient(circle, rgba(255, 215, 0, 0.06) 0%, transparent 60%);
        z-index: -1;
        pointer-events: none;
        border-radius: 40px;
    }

    .pricing-card.premium-tier:hover {
        border-color: rgba(255, 215, 0, 0.85);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.7), 0 0 45px rgba(255, 215, 0, 0.25);
    }

    /* Billing Toggle Switch CSS */
    .billing-toggle-container {
        display: inline-flex;
        background: rgba(0, 0, 0, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        padding: 4px;
        margin: 20px auto;
        position: relative;
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.5);
    }

    .billing-toggle-btn {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.55);
        padding: 8px 18px;
        font-size: 0.85rem;
        font-weight: 700;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: 'Quicksand', sans-serif;
    }

    .basic-toggle-btn {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.55);
        padding: 8px 18px;
        font-size: 0.85rem;
        font-weight: 700;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: 'Quicksand', sans-serif;
    }

    .billing-toggle-btn:hover:not(.active) {
        color: #fff;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
    }

    .basic-toggle-btn:hover:not(.active) {
        color: #fff;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
    }

    .billing-toggle-btn.active {
        background: linear-gradient(135deg, #FFE066 0%, #F2C94C 100%);
        color: #000;
        box-shadow: 0 4px 15px rgba(242, 201, 76, 0.45);
        font-weight: 800;
    }

    .basic-toggle-btn.active {
        background: linear-gradient(135deg, #FFE066 0%, #F2C94C 100%);
        color: #000;
        box-shadow: 0 4px 15px rgba(242, 201, 76, 0.45);
        font-weight: 800;
    }

    .discount-badge-basic {
        background: linear-gradient(135deg, #2ec4b6 0%, #209f92 100%);
        color: #fff;
        font-size: 0.65rem;
        padding: 2px 7px;
        border-radius: 20px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 8px rgba(46, 196, 182, 0.4);
        display: inline-block;
    }

    .premium-desc-sub, .basic-desc-sub {
        color: #2ec4b6;
        font-size: 0.82rem;
        margin: 12px auto 0 auto;
        background: rgba(46, 196, 182, 0.08);
        border: 1px solid rgba(46, 196, 182, 0.25);
        padding: 8px 14px;
        border-radius: 12px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 4px;
        font-weight: 600;
        line-height: 1.5;
        text-align: center;
        animation: pulseGlowSub 2.5s infinite ease-in-out;
        box-shadow: 0 2px 10px rgba(46, 196, 182, 0.05);
        width: fit-content;
    }

    @keyframes pulseGlowSub {
        0%, 100% { 
            box-shadow: 0 0 0 0 rgba(46, 196, 182, 0.15); 
            transform: scale(1);
        }
        50% { 
            box-shadow: 0 0 12px 3px rgba(46, 196, 182, 0.25); 
            transform: scale(1.02);
        }
    }

    .card-header {
        text-align: center;
        margin-bottom: 10px;
        padding-bottom: 25px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        position: relative;
    }

    .premium-tier .card-header {
        border-bottom-color: rgba(255, 215, 0, 0.15);
    }

    .card-header h3 {
        font-family: 'Quicksand', sans-serif;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .card-header h3 i {
        color: #FFD700;
        margin-right: 6px;
        filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.5));
    }

    .premium-tier .card-header h3 {
        color: #FFD700;
        text-shadow: 0 0 15px rgba(255, 215, 0, 0.35);
    }

    .price-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 85px;
        margin: 5px 0;
    }

    .original-price {
        font-family: 'Quicksand', sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.38);
        text-decoration: line-through;
        margin-bottom: 2px;
        letter-spacing: 0.5px;
    }

    .premium-tier .original-price {
        color: rgba(255, 215, 0, 0.4);
        text-shadow: 0 0 10px rgba(255, 215, 0, 0.15);
    }

    .price {
        font-family: 'Quicksand', sans-serif;
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: #F2C94C;
        text-shadow: 0 0 20px rgba(242, 201, 76, 0.3);
        display: flex;
        justify-content: center;
        align-items: flex-start;
        line-height: 1.1;
        margin: 0;
    }

    .premium-tier .price {
        color: #FFD700;
        text-shadow: 0 0 25px rgba(255, 215, 0, 0.4);
    }

    .currency {
        font-size: 1.3rem;
        font-weight: 700;
        margin-top: 7px;
        margin-right: 3px;
        color: inherit;
        opacity: 0.85;
    }

    .period {
        font-size: 0.9rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.5);
        margin-top: auto;
        margin-left: 4px;
        margin-bottom: 8px;
        letter-spacing: 0.3px;
    }

    .desc {
        color: rgba(255, 255, 255, 0.55);
        font-size: 0.88rem;
        margin-top: 15px;
        line-height: 1.5;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-features {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        margin: 30px 0;
    }

    .card-features ul {
        list-style: none;
        padding: 0;
        margin: 0;
        width: 100%;
    }

    .card-features li {
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 18px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 0.95rem;
        line-height: 1.5;
        text-align: left;
    }

    .card-features li:last-child {
        margin-bottom: 0;
    }

    .card-features li i {
        font-size: 0.9rem;
        margin-top: 3px;
        flex-shrink: 0;
    }

    /* Custom glowing colors for special icons on Vương Giả */
    .card-features li i.fa-check {
        color: #F2C94C;
        filter: drop-shadow(0 0 5px rgba(242, 201, 76, 0.5));
    }

    .card-features li i.fa-infinity {
        color: #2ec4b6;
        filter: drop-shadow(0 0 6px rgba(46, 196, 182, 0.6));
    }

    .card-features li i.fa-star {
        color: #FFE066;
        filter: drop-shadow(0 0 6px rgba(255, 224, 102, 0.6));
    }

    .card-features li i.fa-clock-rotate-left {
        color: #ff9f43;
        filter: drop-shadow(0 0 6px rgba(255, 159, 67, 0.6));
    }

    .card-features li i.fa-bolt {
        color: #ff5252;
        filter: drop-shadow(0 0 6px rgba(255, 82, 82, 0.6));
    }

    .select-plan-btn {
        width: 100%;
        padding: 16px 20px;
        border-radius: 14px;
        border: 1px solid rgba(242, 201, 76, 0.25);
        background: rgba(242, 201, 76, 0.03);
        color: #F2C94C;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        font-family: 'Quicksand', sans-serif;
        text-shadow: 0 0 8px rgba(242, 201, 76, 0.25);
        box-shadow: inset 0 0 10px rgba(242, 201, 76, 0.02);
    }

    .select-plan-btn:hover {
        background: linear-gradient(135deg, #F2C94C 0%, #F2994A 100%);
        color: #000;
        text-shadow: none;
        box-shadow: 0 8px 25px rgba(242, 201, 76, 0.35);
        border-color: transparent;
        transform: translateY(-4px);
    }
    
    .premium-btn {
        background: linear-gradient(135deg, #FFE066 0%, #F2C94C 50%, #F2994A 100%);
        color: #000;
        border: none;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 0 20px rgba(242, 201, 76, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.3);
        text-shadow: none;
    }
    
    .premium-btn:hover {
        background: linear-gradient(135deg, #FFF099 0%, #F2C94C 35%, #F27A1A 100%);
        box-shadow: 0 12px 30px rgba(242, 201, 76, 0.5);
        transform: translateY(-5px) scale(1.015);
    }

    /* FAQ Section */
    .faq-section {
        max-width: 860px;
        margin: 80px auto 0 auto;
        padding: 0 20px;
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
    }

    .faq-title {
        text-align: center;
        color: var(--gold-color, #F2C94C);
        margin-bottom: 40px;
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        text-shadow: 0 0 15px rgba(242, 201, 76, 0.2);
