<script is:inline define:vars={{ userEmail: user?.email, bankId: BANK_ID, accountNo: ACCOUNT_NO, accountName: ACCOUNT_NAME }}>
    // ===== Snackbar (error/info/success) =====
    function showToast(message, type = 'info', duration = 4000) {
        const container = document.getElementById('toast-container');
        const icons = {
            error: '<i class="fa-solid fa-circle-xmark"></i>',
            info: '<i class="fa-solid fa-triangle-exclamation"></i>',
            success: '<i class="fa-solid fa-circle-check"></i>'
        };
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.innerHTML = `
            ${icons[type] || icons.info}
            <span>${message}</span>
            <button class="toast-close" onclick="this.closest('.toast').remove()">&times;</button>
        `;
        container.appendChild(toast);
        requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('show')));
        setTimeout(() => {
            toast.classList.add('hide');
            setTimeout(() => toast.remove(), 300);
        }, duration);
    }

    // ===== Success Popup =====
    function showSuccessPopup(isPremium = false) {
        const popup = document.getElementById('success-popup');
        const iconRing = document.querySelector('.success-icon-ring');
        const title = document.querySelector('.success-popup-title');
        const message = document.querySelector('.success-popup-message');
        const btn = document.querySelector('.success-popup-btn');

        if (isPremium) {
            iconRing.innerHTML = '<i class="fa-solid fa-crown"></i>';
            iconRing.style.color = '#FFD700';
            iconRing.style.borderColor = 'rgba(255, 215, 0, 0.6)';
            iconRing.style.background = 'radial-gradient(circle, rgba(255, 215, 0, 0.2) 0%, transparent 70%)';
            iconRing.style.animation = 'premiumPulse 2s ease infinite';
            
            title.innerHTML = 'Nâng Cấp Thành Công!';
            title.style.color = '#FFD700';
            title.style.textShadow = '0 0 15px rgba(255, 215, 0, 0.4)';
            
            message.innerHTML = 'Chúc mừng bạn đã trở thành VIP.<br>Tất cả tính năng Premium đã được mở khóa! 👑';
            
            btn.style.background = 'linear-gradient(135deg, #FFD700, #F2994A)';
            btn.style.color = '#000';
            btn.style.boxShadow = '0 0 20px rgba(242, 201, 76, 0.4)';
            
            // Pháo bông bay
            if (window.confetti) {
                var duration = 3500;
                var end = Date.now() + duration;

                (function frame() {
                    window.confetti({
                        particleCount: 6,
                        angle: 60,
                        spread: 60,
                        origin: { x: 0 },
                        colors: ['#FFD700', '#F2994A', '#FFFFFF', '#ff6b6b']
                    });
                    window.confetti({
                        particleCount: 6,
                        angle: 120,
                        spread: 60,
                        origin: { x: 1 },
                        colors: ['#FFD700', '#F2994A', '#FFFFFF', '#ff6b6b']
                    });

                    if (Date.now() < end) {
                        requestAnimationFrame(frame);
                    }
                }());
            }
        } else {
            // Reset to default
            iconRing.innerHTML = '<i class="fa-solid fa-check"></i>';
            iconRing.style.cssText = '';
            title.innerHTML = 'Thanh toán thành công!';
            title.style.cssText = '';
            message.innerHTML = 'Credit đã được cộng vào tài khoản của bạn.<br>Chúc bạn trải nghiệm vui vẻ! 🌟';
            btn.style.cssText = '';
        }

        popup.classList.add('show');
    }

    function hideSuccessPopup() {
        const popup = document.getElementById('success-popup');
        popup.classList.remove('show');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('payment-modal');
        const closeBtn = document.querySelector('.close-modal-btn');
        const confirmBtn = document.querySelector('.confirm-paid-btn');
        
        const qrImage = document.getElementById('vietqr-image');
        const qrLoading = document.querySelector('.qr-loading');
        
        const packageNameEl = document.getElementById('selected-package-name');
        const amountEl = document.getElementById('modal-amount');
        const contentDisplay = document.getElementById('transfer-content-display');
        const contentBox = document.getElementById('transfer-content-text');
        
        let currentTransactionId = null;
        let checkInterval = null;
        let isPremiumPurchase = false;

        // ===== Billing Toggle logic for VIP Premium =====
        const toggleBtns = document.querySelectorAll('.billing-toggle-btn');
        const premiumPriceDisplay = document.getElementById('premium-price-display');
        const premiumPriceSubtext = document.getElementById('premium-price-subtext');
        const premiumBuyBtn = document.getElementById('premium-buy-btn');

        if (toggleBtns.length > 0 && premiumBuyBtn) {
            // Get individual elements to update (NOT replace innerHTML)
            const amountDisplay = document.getElementById('premium-amount-display');
            const periodDisplay = document.getElementById('premium-period-display');
            const originalDisplay = document.getElementById('premium-original-display');

            toggleBtns.forEach(tBtn => {
                tBtn.addEventListener('click', () => {
                    toggleBtns.forEach(b => b.classList.remove('active'));
                    tBtn.classList.add('active');

                    const mode = tBtn.getAttribute('data-billing');

                    // --- GTM Tracking ---
                    window.dataLayer = window.dataLayer || [];
                    window.dataLayer.push({
                        'event': 'feature_usage',
                        'feature_name': 'pricing',
                        'action': 'switch_premium_billing',
                        'package': mode
                    });
                    // --------------------

                    if (mode === 'yearly') {
                        // Update only text nodes — no innerHTML replacement
                        if (amountDisplay) amountDisplay.textContent = '599.000';
                        if (periodDisplay) periodDisplay.textContent = '/năm';
                        if (originalDisplay) originalDisplay.textContent = '₫2.388.000/năm';
                        if (premiumPriceSubtext) {
                            premiumPriceSubtext.style.display = 'flex';
                            premiumPriceSubtext.innerHTML = '<i class="fa-solid fa-fire" style="color: #ff6b6b; margin-right: 5px;"></i> Tương đương chỉ <strong>49.000₫/tháng</strong> — Tiết kiệm ngay <strong>75%</strong>!';
                        }
                        premiumBuyBtn.setAttribute('data-amount', '599000');
                        premiumBuyBtn.setAttribute('data-package', 'Chuyên Gia (Gói Năm)');
                        premiumBuyBtn.innerText = 'Trở Thành VIP (Gói Năm)';
                    } else {
                        // Monthly values
                        if (amountDisplay) amountDisplay.textContent = '199.000';
                        if (periodDisplay) periodDisplay.textContent = '/tháng';
                        if (originalDisplay) originalDisplay.textContent = '₫399.000/tháng';
                        if (premiumPriceSubtext) {
                            premiumPriceSubtext.style.display = 'none';
                            premiumPriceSubtext.innerText = '';
                        }
                        premiumBuyBtn.setAttribute('data-amount', '199000');
                        premiumBuyBtn.setAttribute('data-package', 'Vương Giả (Gói Tháng)');
                        premiumBuyBtn.innerText = 'Trở Thành VIP';
                    }
                });
            });
        }

        // ===== Basic Toggle logic =====
        const basicToggleBtns = document.querySelectorAll('.basic-toggle-btn');
        const basicPriceSubtext = document.getElementById('basic-price-subtext');
        const basicBuyBtn = document.getElementById('basic-buy-btn');

        if (basicToggleBtns.length > 0 && basicBuyBtn) {
            const basicAmountDisplay = document.getElementById('basic-amount-display');
            const basicOriginalDisplay = document.getElementById('basic-original-display');

            basicToggleBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    basicToggleBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    const credits = btn.getAttribute('data-credits');

                    // --- GTM Tracking ---
                    window.dataLayer = window.dataLayer || [];
                    window.dataLayer.push({
                        'event': 'feature_usage',
                        'feature_name': 'pricing',
                        'action': 'switch_basic_package',
                        'package': credits + '_credits'
