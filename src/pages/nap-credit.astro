        // Đọc lại danh sách nút mua hàng (vì Premium có thể thay đổi thuộc tính)
        const planBtns = document.querySelectorAll('.select-plan-btn');

        // Success popup close
        const successPopupCloseBtn = document.getElementById('success-popup-close');
        const successPopup = document.getElementById('success-popup');
        if (successPopupCloseBtn) {
            successPopupCloseBtn.addEventListener('click', hideSuccessPopup);
        }
        if (successPopup) {
            successPopup.addEventListener('click', (e) => {
                if (e.target === successPopup) hideSuccessPopup();
            });
        }

        
        // Mở modal và tạo/lấy lại mã QR
        planBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!userEmail) {
                    window.location.href = '/login?redirect=/nap-credit';
                    return;
                }
                
                const amount = btn.getAttribute('data-amount');
                const pkgName = btn.getAttribute('data-package');
                isPremiumPurchase = pkgName.includes('Vương Giả') || pkgName.includes('Chuyên Gia') || pkgName.includes('Nâng Cao');
                
                // --- GTM Tracking ---
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'feature_usage',
                    'feature_name': 'pricing',
                    'action': 'click_select_package',
                    'package': pkgName,
                    'amount': amount
                });
                // --------------------
                
                // Bản đồ tên gói hiển thị thân thiện (Cơ Bản / Nâng Cao)
                const friendlyNames = {
                    'Khởi Đầu (3 lượt)': 'Cơ Bản (3 Credit)',
                    'Đồng Hành (10 lượt)': 'Cơ Bản (10 Credit)',
                    'Vương Giả (Gói Tháng)': 'Nâng Cao (Gói Tháng)',
                    'Chuyên Gia (Gói Năm)': 'Nâng Cao (Gói Năm)'
                };
                
                packageNameEl.innerText = friendlyNames[pkgName] || pkgName;
                amountEl.innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
                
                qrLoading.style.display = 'block';
                qrImage.style.display = 'none';
                modal.classList.add('show');

                try {
                    // Gọi API lấy/tạo mã đơn hàng (reuse trong 20 phút)
                    const res = await fetch('/api/payment/create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount, package_id: pkgName })
                    });
                    
                    const data = await res.json();
                    if (!data.success) {
                        showToast('Lỗi tạo đơn hàng', data.error, 'error');
                        modal.classList.remove('show');
                        return;
                    }

                    currentTransactionId = data.transaction_id;
                    const transferContent = currentTransactionId;
                    
                    // Gắn nội dung vào HTML
                    contentDisplay.innerText = transferContent;
                    contentBox.setAttribute('data-copy', transferContent);
                    
                    // Tạo link VietQR
                    const qrUrl = `https://img.vietqr.io/image/${bankId}-${accountNo}-compact2.png?amount=${amount}&addInfo=${encodeURIComponent(transferContent)}&accountName=${encodeURIComponent(accountName)}`;
                    
                    // Reset hoàn toàn trước khi load ảnh mới
                    qrImage.src = '';
                    qrImage.style.display = 'none';
                    qrLoading.style.display = 'block';
                    qrLoading.innerText = 'Đang tạo mã QR...';

                    // Gắn handler TRƯỚC khi set src (tránh race condition với cache)
                    qrImage.onload = () => {
                        qrLoading.style.display = 'none';
                        qrImage.style.display = 'block';
                    };
                    qrImage.onerror = () => {
                        qrLoading.innerText = '⚠️ Không tải được mã QR. Vui lòng dùng thông tin bên cạnh để chuyển khoản.';
                    };

                    // Set src sau cùng để trigger load
                    qrImage.src = qrUrl;
                } catch (err) {
                    showToast('Lỗi kết nối', 'Không thể kết nối đến máy chủ. Vui lòng thử lại.', 'error');
                    modal.classList.remove('show');
                }
            });
        });
        
        // Đóng modal
        const closeModal = () => {
            modal.classList.remove('show');
            currentTransactionId = null;
            if (checkInterval) {
                clearInterval(checkInterval);
                checkInterval = null;
            }
            confirmBtn.innerHTML = 'Tôi đã chuyển khoản';
            confirmBtn.style.background = '';
            confirmBtn.style.color = '';
            confirmBtn.disabled = false;
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
        
        // Copy text
        document.querySelectorAll('.copyable').forEach(el => {
            el.addEventListener('click', () => {
                const text = el.getAttribute('data-copy');
                if(!text) return;
                navigator.clipboard.writeText(text).then(() => {
                    showToast('Đã copy: ' + text, 'success', 2000);
                });
            });
        });
        
        // Hàm gọi API kiểm tra
        const checkPaymentStatus = async () => {
            if (!currentTransactionId) return;
            try {
                const res = await fetch('/api/payment/check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ transaction_id: currentTransactionId })
                });
                const data = await res.json();
                if (data.success && data.status === 'paid') {
                    // Thành công
                    if (checkInterval) clearInterval(checkInterval);
                    confirmBtn.innerHTML = '<i class="fa-solid fa-circle-check"></i> Thanh toán thành công!';
                    confirmBtn.style.background = '#4CAF50';
                    confirmBtn.style.color = '#fff';
                    
                    // Cập nhật ví hiển thị
                    if (window.fetchBalance) window.fetchBalance(true);
                    
                    setTimeout(() => {
                        closeModal();
                        showSuccessPopup(isPremiumPurchase);
                    }, 800);
                } else if (data.success && data.status === 'insufficient') {
                    // Nạp thiếu tiền
                    if (checkInterval) clearInterval(checkInterval);
                    confirmBtn.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Nạp thiếu tiền';
                    confirmBtn.style.background = '#ff5252';
                    confirmBtn.style.color = '#fff';
                    
                    showToast('Bạn đã chuyển không đủ số tiền của gói này. Vui lòng liên hệ Admin để được hỗ trợ thủ công.', 'error', 15000);
                    
                    setTimeout(() => {
                        closeModal();
                    }, 5000);
                }
            } catch (err) {
                console.error('Check payment error', err);
            }
        };

        // Nút xác nhận
        confirmBtn.addEventListener('click', () => {
            if (!currentTransactionId) return;

            confirmBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Đang chờ ngân hàng...';
            confirmBtn.style.background = '#555';
            confirmBtn.style.color = '#fff';
            confirmBtn.disabled = true;
            
            // Bắt đầu polling mỗi 3 giây
            checkPaymentStatus();
            if (checkInterval) clearInterval(checkInterval);
            checkInterval = setInterval(checkPaymentStatus, 3000);
            
            // Tự động dừng sau 5 phút nếu không có kết quả
            setTimeout(() => {
                if (checkInterval) {
                    clearInterval(checkInterval);
                    checkInterval = null;
                    confirmBtn.innerHTML = 'Thử lại lần nữa';
                    confirmBtn.style.background = '';
                    confirmBtn.style.color = '';
                    confirmBtn.disabled = false;
                    showToast('Hệ thống chưa nhận được thông báo từ ngân hàng. Nếu đã chuyển thành công, Credit sẽ cộng trong ít phút. Liên hệ Admin nếu cần.', 'error', 10000);
                }
            }, 5 * 60 * 1000);
        });
    });
</script>
