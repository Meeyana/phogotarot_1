---
import BaseLayout from '../layouts/BaseLayout.astro';

// Biến cấu hình Ngân Hàng
const BANK_ID = "VPB"; // VP Bank
const ACCOUNT_NO = "0943524970"; // Số tài khoản
const ACCOUNT_NAME = "PHAN DINH TUAN"; // Tên chủ tài khoản (bạn có thể đổi lại tên thật)

const title = "Nạp Credit - Phở Gõ Tarot";
const description = "Nạp Credit để tiếp tục trải nghiệm luận giải Tarot sâu sắc và cá nhân hóa từ Phở Gõ Tarot.";

// Yêu cầu đăng nhập để hiển thị email trong mã QR
const user = Astro.locals.user;
---

<BaseLayout title={title} description={description}>
    <main class="pricing-page">
        <div class="pricing-header">
            <h1 class="pricing-title">Bảng Giá Dịch Vụ</h1>
            <p class="pricing-subtitle">Chọn một gói Credit phù hợp để khám phá thông điệp sâu sắc từ vũ trụ</p>
        </div>

        <div class="pricing-cards">
            <!-- Gói 1 -->
            <div class="pricing-card">
                <div class="card-header">
                    <h3>Khởi Đầu</h3>
                    <div class="price">
                        <span class="currency">₫</span>49.000
                    </div>
                    <p class="desc">Dành cho người mới trải nghiệm</p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-check"></i> <strong>3 lượt</strong> xem Tarot 3 lá</li>
                        <li><i class="fa-solid fa-check"></i> <strong>Sử dụng vĩnh viễn</strong></li>
                        <li><i class="fa-solid fa-check"></i> Xem bài Yes/No miễn phí</li>
                    </ul>
                </div>
                <button class="select-plan-btn" data-amount="49000" data-package="Khởi Đầu (3 lượt)">Chọn Gói Này</button>
            </div>

            <!-- Gói 2 -->
            <div class="pricing-card popular">
                <div class="popular-badge">Phổ Biến Nhất</div>
                <div class="card-header">
                    <h3>Đồng Hành</h3>
                    <div class="price">
                        <span class="currency">₫</span>129.000
                    </div>
                    <p class="desc">Tiết kiệm hơn, nhiều thông điệp hơn</p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-check"></i> <strong>10 lượt</strong> xem Tarot 3 lá</li>
                        <li><i class="fa-solid fa-check"></i> <strong>Sử dụng vĩnh viễn</strong></li>
                        <li><i class="fa-solid fa-check"></i> Phân tích lá bài chi tiết</li>
                        <li><i class="fa-solid fa-check"></i> Ưu tiên phản hồi tốc độ cao</li>
                    </ul>
                </div>
                <button class="select-plan-btn popular-btn" data-amount="129000" data-package="Đồng Hành (10 lượt)">Chọn Gói Này</button>
            </div>

            <!-- Gói 3 -->
            <div class="pricing-card premium-tier">
                <div class="card-header">
                    <h3><i class="fa-solid fa-crown" style="color: #FFD700;"></i> Vương Giả</h3>
                    <div class="price">
                        <span class="currency">₫</span>199.000<span class="period">/tháng</span>
                    </div>
                    <p class="desc">Trải nghiệm tâm linh trọn vẹn nhất</p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-infinity"></i> <strong>Không giới hạn</strong> (1 tháng)</li>
                        <li><i class="fa-solid fa-star"></i> Mở khóa các trải bài chuyên sâu</li>
                        <li><i class="fa-solid fa-clock-rotate-left"></i> Lưu trữ lịch sử vĩnh viễn</li>
                        <li><i class="fa-solid fa-wand-magic-sparkles"></i> AI thấu hiểu phong cách của bạn</li>
                        <li><i class="fa-solid fa-infinity"></i> Xem thần số học không giới hạn</li>
                    </ul>
                </div>
                <button class="select-plan-btn premium-btn" data-amount="199000" data-package="Vương Giả (Gói Tháng)">Trở Thành VIP</button>
                </div>

            <!-- Gói 4 -->
            <div class="pricing-card premium-tier yearly-tier">
                <div class="card-header">
                    <h3><i class="fa-solid fa-gem" style="color: #4CAF50;"></i> Chuyên Gia</h3>
                    <div class="price">
                        <span class="currency">₫</span>599.000<span class="period">/năm</span>
                    </div>
                    <p class="desc">Dành cho người yêu Tarot thực thụ</p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-infinity"></i> <strong>Không giới hạn</strong> (1 năm)</li>
                        <li><i class="fa-solid fa-star"></i> Mở khóa toàn bộ trải bài</li>
                        <li><i class="fa-solid fa-wand-magic-sparkles"></i> Phân tích chuẩn xác cao cấp</li>
                        <li><i class="fa-solid fa-infinity"></i> Xem thần số học không giới hạn</li>
                    </ul>
                </div>
                <button class="select-plan-btn yearly-btn" data-amount="599000" data-package="Chuyên Gia (Gói Năm)">Mua Gói Năm</button>
            </div>

            <!-- Gói 5 (Đang tạm ẩn) -->
            <!--
            <div class="pricing-card premium-tier lifetime-tier">
                <div class="card-header">
                    <h3><i class="fa-solid fa-diamond" style="color: #b19cd9;"></i> Khai Sáng</h3>
                    <div class="price">
                        <span class="currency">₫</span>799.000<span class="period">/trọn đời</span>
                    </div>
                    <p class="desc">Mua 1 lần, dùng mãi mãi</p>
                </div>
                <div class="card-features">
                    <ul>
                        <li><i class="fa-solid fa-infinity"></i> <strong>Không giới hạn</strong> (Trọn đời)</li>
                        <li><i class="fa-solid fa-bolt"></i> Ưu tiên nâng cấp tính năng mới</li>
                        <li><i class="fa-solid fa-user-shield"></i> Danh hiệu VIP trọn đời</li>
                    </ul>
                </div>
                <button class="select-plan-btn lifetime-btn" data-amount="799000" data-package="Khai Sáng (Trọn Đời)">Mua Trọn Đời</button>
            </div>
            -->
        </div>
        </div>

        <div class="faq-section">
            <h2 class="faq-title">Câu Hỏi Thường Gặp</h2>
            <div class="faq-grid">
                <div class="faq-item">
                    <h4>Lượt Free mỗi ngày là gì?</h4>
                    <p>Mỗi tài khoản được hệ thống tặng 1 lượt xem bài hoàn toàn miễn phí vào 0:00 hàng ngày. Lượt Free không được cộng dồn sang ngày hôm sau.</p>
                </div>
                <div class="faq-item">
                    <h4>Lượt mua lẻ có bị mất đi không?</h4>
                    <p>Không. Tất cả các gói mua lẻ (Khởi Đầu, Đồng Hành) đều có giá trị vĩnh viễn cho đến khi bạn sử dụng hết.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Payment Modal -->
    <div id="payment-modal" class="payment-modal-backdrop">
        <div class="payment-modal-content">
            <button class="close-modal-btn" aria-label="Close"><i class="fa-solid fa-times"></i></button>
            <div class="payment-modal-header">
                <h2>Thanh Toán Chuyển Khoản</h2>
                <p>Bạn đang chọn: <strong id="selected-package-name" style="color: var(--gold-color);"></strong></p>
            </div>
            
            <div class="payment-modal-body">
                <div class="qr-code-wrapper">
                    <img id="vietqr-image" src="" alt="Mã QR Thanh Toán" />
                    <div class="qr-loading">Đang tạo mã QR...</div>
                </div>
                
                <div class="transfer-info">
                    <div class="info-row">
                        <span>Ngân hàng:</span>
                        <strong>{BANK_ID}</strong>
                    </div>
                    <div class="info-row">
                        <span>Số tài khoản:</span>
                        <strong class="copyable" data-copy="{ACCOUNT_NO}">{ACCOUNT_NO} <i class="fa-regular fa-copy"></i></strong>
                    </div>
                    <div class="info-row">
                        <span>Chủ tài khoản:</span>
                        <strong>{ACCOUNT_NAME}</strong>
                    </div>
                    <div class="info-row">
                        <span>Số tiền:</span>
                        <strong class="amount-highlight" id="modal-amount">...</strong>
                    </div>
                    <div class="info-row content-row">
                        <span>Nội dung chuyển khoản:</span>
                        <div class="transfer-content copyable" id="transfer-content-text" data-copy="">
                            <span id="transfer-content-display">...</span> <i class="fa-regular fa-copy"></i>
                        </div>
                    </div>
                    <p class="transfer-warning"><i class="fa-solid fa-triangle-exclamation"></i> Bắt buộc nhập ĐÚNG NỘI DUNG chuyển khoản để hệ thống tự động cộng Credit.</p>
                </div>
            </div>
            
            <div class="payment-modal-footer">
                <button class="confirm-paid-btn">Tôi đã chuyển khoản</button>
            </div>
        </div>
    </div>

    <!-- Toast Snackbar (error/info) -->
    <div id="toast-container"></div>

    <!-- Success Popup -->
    <div id="success-popup">
        <div class="success-popup-card">
            <div class="success-icon-ring">
                <i class="fa-solid fa-check"></i>
            </div>
            <div class="success-popup-title">Thanh toán thành công!</div>
            <div class="success-popup-message">Credit đã được cộng vào tài khoản của bạn.<br>Chúc bạn trải nghiệm vui vẻ! 🌟</div>
            <button class="success-popup-btn" id="success-popup-close">Tuyệt vời!</button>
        </div>
    </div>
</BaseLayout>

<style>
    /* CSS Setup */
    .pricing-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 20px;
        min-height: 80vh;
    }

    .pricing-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .pricing-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        color: var(--gold-color, #F2C94C);
        margin-bottom: 15px;
        text-shadow: 0 0 15px rgba(242, 201, 76, 0.3);
    }

    .pricing-subtitle {
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.1rem;
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 80px;
    }

    .pricing-card {
        background: rgba(20, 25, 40, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 40px 20px;
        width: 100%;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .pricing-card:hover {
        transform: translateY(-10px);
        border-color: rgba(242, 201, 76, 0.3);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5), 0 0 20px rgba(242, 201, 76, 0.1);
    }

    .pricing-card.popular {
        border-color: var(--gold-color, #F2C94C);
        background: linear-gradient(180deg, rgba(30, 35, 55, 0.9) 0%, rgba(20, 25, 40, 0.9) 100%);
        box-shadow: 0 0 30px rgba(242, 201, 76, 0.15);
        transform: scale(1.05);
    }

    .pricing-card.popular:hover {
        transform: scale(1.05) translateY(-10px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5), 0 0 30px rgba(242, 201, 76, 0.3);
    }

    .pricing-card.premium-tier {
        background: linear-gradient(135deg, rgba(40, 30, 20, 0.8) 0%, rgba(20, 25, 40, 0.9) 100%);
        border: 1px solid rgba(255, 215, 0, 0.5);
    }

    .popular-badge {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(90deg, #F2C94C, #F2994A);
        color: #000;
        font-weight: bold;
        padding: 5px 20px;
        border-radius: 20px;
        font-size: 0.85rem;
        box-shadow: 0 4px 10px rgba(242, 201, 76, 0.3);
    }

    .card-header {
        text-align: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .card-header h3 {
        color: #fff;
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .price {
        font-size: 2.5rem;
        font-weight: bold;
        color: var(--gold-color, #F2C94C);
        display: flex;
        justify-content: center;
        align-items: flex-start;
        line-height: 1;
    }

    .currency {
        font-size: 1.2rem;
        margin-top: 5px;
        margin-right: 5px;
    }

    .period {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.5);
        margin-top: auto;
        margin-left: 5px;
        margin-bottom: 5px;
    }

    .desc {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.9rem;
        margin-top: 15px;
    }

    .card-features {
        flex-grow: 1;
        margin-bottom: 30px;
    }

    .card-features ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .card-features li {
        color: #ddd;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.95rem;
    }

    .card-features li i {
        color: var(--gold-color, #F2C94C);
        font-size: 0.8rem;
    }

    .select-plan-btn {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Quicksand', sans-serif;
    }

    .select-plan-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.4);
    }

    .popular-btn {
        background: var(--gold-color, #F2C94C);
        color: #000;
        border: none;
    }

    .popular-btn:hover {
        background: #F2994A;
        box-shadow: 0 5px 15px rgba(242, 201, 76, 0.4);
    }
    
    .premium-btn {
        background: linear-gradient(90deg, #FFD700, #FFA500);
        color: #000;
        border: none;
    }
    
    .premium-btn:hover {
        background: linear-gradient(90deg, #FFA500, #FFD700);
        box-shadow: 0 5px 15px rgba(255, 215, 0, 0.4);
    }
    
    .yearly-tier {
        border-color: #4CAF50;
    }
    
    .yearly-btn {
        background: linear-gradient(90deg, #4CAF50, #45a049);
        color: #fff;
        border: none;
    }
    
    .yearly-btn:hover {
        background: linear-gradient(90deg, #45a049, #4CAF50);
        box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);
    }
    
    .lifetime-tier {
        border-color: #b19cd9;
    }
    
    .lifetime-btn {
        background: linear-gradient(90deg, #b19cd9, #9370db);
        color: #fff;
        border: none;
    }
    
    .lifetime-btn:hover {
        background: linear-gradient(90deg, #9370db, #b19cd9);
        box-shadow: 0 5px 15px rgba(177, 156, 217, 0.4);
    }

    /* FAQ Section */
    .faq-section {
        background: rgba(20, 25, 40, 0.5);
        border-radius: 20px;
        padding: 40px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .faq-title {
        text-align: center;
        color: var(--gold-color, #F2C94C);
        margin-bottom: 30px;
        font-size: 2rem;
    }

    .faq-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
    }

    .faq-item h4 {
        color: #fff;
        font-size: 1.1rem;
        margin-bottom: 10px;
    }

    .faq-item p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* Modal Styles */
    .payment-modal-backdrop {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(10, 12, 20, 0.85);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .payment-modal-backdrop.show {
        display: flex;
        opacity: 1;
    }

    .payment-modal-content {
        background: #1a1e2d;
        border-radius: 20px;
        border: 1px solid rgba(242, 201, 76, 0.3);
        width: 95%;
        max-width: 800px;
        padding: 20px 30px;
        position: relative;
        transform: translateY(20px);
        transition: transform 0.3s ease;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        max-height: 88vh;
        overflow-y: auto;
    }
    
    /* Tùy chỉnh thanh cuộn cho modal */
    .payment-modal-content::-webkit-scrollbar {
        width: 6px;
    }
    .payment-modal-content::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.1);
        border-radius: 10px;
    }
    .payment-modal-content::-webkit-scrollbar-thumb {
        background: rgba(242, 201, 76, 0.5);
        border-radius: 10px;
    }
    
    .payment-modal-backdrop.show .payment-modal-content {
        transform: translateY(0);
    }

    .close-modal-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(255, 255, 255, 0.05);
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.2s;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }
    
    .close-modal-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        color: var(--gold-color);
        transform: scale(1.1);
    }

    .payment-modal-header {
        text-align: center;
        margin-bottom: 15px;
    }

    .payment-modal-header h2 {
        color: #fff;
        margin-bottom: 5px;
        font-size: 1.5rem;
    }
    
    .payment-modal-body {
        display: flex;
        gap: 25px;
        align-items: stretch;
        margin-bottom: 20px;
    }

    .qr-code-wrapper {
        flex: 0 0 40%; /* Chiếm 40% chiều rộng trên desktop */
        background: #fff;
        padding: 15px;
        border-radius: 12px;
        text-align: center;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    #vietqr-image {
        max-width: 100%;
        max-height: 300px;
        height: auto;
        display: none;
        border-radius: 8px;
    }

    .qr-loading {
        color: #666;
        font-weight: 500;
    }

    .transfer-info {
        flex: 1; /* Chiếm phần còn lại */
        background: rgba(0, 0, 0, 0.3);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .info-row:last-child {
        border-bottom: none;
    }
    
    .info-row.content-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
        border-bottom: none;
    }

    .info-row span {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.9rem;
    }

    .info-row strong {
        color: #fff;
        font-size: 1rem;
    }
    
    .amount-highlight {
        color: #ff6b6b !important;
        font-size: 1.2rem !important;
    }
    
    .copyable {
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: color 0.2s;
    }
    
    .copyable:hover {
        color: var(--gold-color, #F2C94C);
    }
    
    .transfer-content {
        background: rgba(242, 201, 76, 0.1);
        border: 1px dashed var(--gold-color, #F2C94C);
        padding: 10px;
        border-radius: 8px;
        width: 100%;
        text-align: center;
        font-size: 1.1rem;
        font-weight: bold;
        color: var(--gold-color, #F2C94C);
        letter-spacing: 1px;
    }

    .transfer-warning {
        color: #ffcc00;
        font-size: 0.85rem;
        margin-top: 15px;
        line-height: 1.5;
        background: rgba(255, 204, 0, 0.1);
        padding: 10px;
        border-radius: 6px;
    }

    .payment-modal-footer {
        text-align: center;
    }

    .confirm-paid-btn {
        background: var(--gold-color, #F2C94C);
        color: #000;
        border: none;
        padding: 15px 30px;
        border-radius: 10px;
        font-weight: bold;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
    }

    .confirm-paid-btn:hover {
        background: #F2994A;
        transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
        .pricing-cards {
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }
    }

    @media (max-width: 768px) {
        .pricing-card.popular {
            transform: scale(1);
        }
        .pricing-card.popular:hover {
            transform: translateY(-10px);
        }
        
        .payment-modal-content {
            padding: 12px;
            width: 98%;
            max-height: 92vh;
        }
        
        .close-modal-btn {
            top: 10px;
            right: 10px;
            width: 30px;
            height: 30px;
            font-size: 1.2rem;
            background: rgba(255,255,255,0.1);
        }

        .payment-modal-body {
            flex-direction: column;
            gap: 12px;
            margin-bottom: 12px;
        }
        
        .qr-code-wrapper {
            flex: auto;
            padding: 8px;
            border-radius: 12px;
        }

        #vietqr-image {
            max-width: 220px; /* Giới hạn kích thước mã QR trên mobile */
        }
        
        .transfer-info {
            padding: 12px;
            border-radius: 12px;
        }
        
        .info-row {
            padding: 6px 0;
        }
        
        .info-row:not(.content-row) {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }
        
        .transfer-content {
            padding: 8px 10px;
            font-size: 1.05rem;
        }
        
        .payment-modal-header h2 {
            font-size: 1.2rem;
            margin-bottom: 2px;
        }

        .payment-modal-header p {
            font-size: 0.85rem;
        }
        
        .transfer-warning {
            font-size: 0.8rem;
            margin-top: 10px;
        }
    }
    @media (max-width: 600px) {
        .pricing-cards {
            grid-template-columns: 1fr;
        }
    }

    /* ===== Snackbar (error/info) ===== */
    #toast-container {
        position: fixed;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 999999;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        pointer-events: none;
        width: max-content;
        max-width: calc(100vw - 32px);
    }

    .toast {
        display: flex;
        align-items: center;
        gap: 12px;
        background: #1e2235;
        border-radius: 50px;
        padding: 12px 20px 12px 16px;
        font-size: 0.9rem;
        font-weight: 500;
        color: #fff;
        box-shadow: 0 4px 24px rgba(0,0,0,0.6);
        pointer-events: all;
        white-space: nowrap;
        opacity: 0;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        border: 1px solid rgba(255,255,255,0.08);
        max-width: calc(100vw - 32px);
        white-space: normal;
    }

    .toast.show {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    .toast.hide {
        opacity: 0;
        transform: translateY(10px) scale(0.97);
        transition: all 0.25s ease;
    }

    .toast i { font-size: 1rem; flex-shrink: 0; }

    .toast-close {
        background: none;
        border: none;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        font-size: 1.1rem;
        padding: 0 0 0 8px;
        line-height: 1;
        flex-shrink: 0;
        transition: color 0.2s;
    }
    .toast-close:hover { color: #fff; }

    .toast.toast-error { border-color: rgba(255,82,82,0.3); }
    .toast.toast-error i { color: #ff5252; }
    .toast.toast-info { border-color: rgba(242,201,76,0.25); }
    .toast.toast-info i { color: #F2C94C; }
    .toast.toast-success { border-color: rgba(76,175,80,0.3); }
    .toast.toast-success i { color: #4CAF50; }

    /* ===== Success Popup (centered) ===== */
    #success-popup {
        position: fixed;
        inset: 0;
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.65);
        backdrop-filter: blur(6px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    #success-popup.show {
        opacity: 1;
        pointer-events: all;
    }

    .success-popup-card {
        background: linear-gradient(145deg, #1a1f35, #141826);
        border: 1px solid rgba(76,175,80,0.35);
        border-radius: 24px;
        padding: 48px 40px;
        text-align: center;
        max-width: 380px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(76,175,80,0.1);
        transform: scale(0.85) translateY(20px);
        transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }

    #success-popup.show .success-popup-card {
        transform: scale(1) translateY(0);
    }

    .success-icon-ring {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(76,175,80,0.2) 0%, transparent 70%);
        border: 2px solid rgba(76,175,80,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 2rem;
        color: #4CAF50;
        animation: successPulse 2s ease infinite;
    }

    @keyframes successPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(76,175,80,0.3); }
        50% { box-shadow: 0 0 0 12px rgba(76,175,80,0); }
    }

    .success-popup-title {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .success-popup-message {
        color: rgba(255,255,255,0.6);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .success-popup-btn {
        background: linear-gradient(135deg, #4CAF50, #45a049);
        color: #fff;
        border: none;
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
        font-family: inherit;
    }

    .success-popup-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(76,175,80,0.4);
    }
</style>

<script is:inline define:vars={{ userEmail: user?.email, bankId: BANK_ID, accountNo: ACCOUNT_NO, accountName: ACCOUNT_NAME }}>
    // ===== Snackbar (error/info/success) =====
    function showToast(message, type = 'info', duration = 4000) {
        const container = document.getElementById('toast-container');
        const icons = {
            error: '<i class="fa-solid fa-circle-xmark"></i>',
            info: '<i class="fa-solid fa-triangle-exclamation"></i>',
            success: '<i class="fa-solid fa-circle-check"></i>'
        };
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.innerHTML = `
            ${icons[type] || icons.info}
            <span>${message}</span>
            <button class="toast-close" onclick="this.closest('.toast').remove()">&times;</button>
        `;
        container.appendChild(toast);
        requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('show')));
        setTimeout(() => {
            toast.classList.add('hide');
            setTimeout(() => toast.remove(), 300);
        }, duration);
    }

    // ===== Success Popup =====
    function showSuccessPopup() {
        const popup = document.getElementById('success-popup');
        popup.classList.add('show');
    }

    function hideSuccessPopup() {
        const popup = document.getElementById('success-popup');
        popup.classList.remove('show');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('payment-modal');
        const closeBtn = document.querySelector('.close-modal-btn');
        const confirmBtn = document.querySelector('.confirm-paid-btn');
        const planBtns = document.querySelectorAll('.select-plan-btn');
        
        const qrImage = document.getElementById('vietqr-image');
        const qrLoading = document.querySelector('.qr-loading');
        
        const packageNameEl = document.getElementById('selected-package-name');
        const amountEl = document.getElementById('modal-amount');
        const contentDisplay = document.getElementById('transfer-content-display');
        const contentBox = document.getElementById('transfer-content-text');
        
        let currentTransactionId = null;
        let checkInterval = null;

        // Success popup close
        const successPopupCloseBtn = document.getElementById('success-popup-close');
        const successPopup = document.getElementById('success-popup');
        if (successPopupCloseBtn) {
            successPopupCloseBtn.addEventListener('click', hideSuccessPopup);
        }
        if (successPopup) {
            successPopup.addEventListener('click', (e) => {
                if (e.target === successPopup) hideSuccessPopup();
            });
        }

        
        // Mở modal và tạo/lấy lại mã QR
        planBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!userEmail) {
                    window.location.href = '/login?redirect=/nap-credit';
                    return;
                }
                
                const amount = btn.getAttribute('data-amount');
                const pkgName = btn.getAttribute('data-package');
                
                packageNameEl.innerText = pkgName;
                amountEl.innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
                
                qrLoading.style.display = 'block';
                qrImage.style.display = 'none';
                modal.classList.add('show');

                try {
                    // Gọi API lấy/tạo mã đơn hàng (reuse trong 20 phút)
                    const res = await fetch('/api/payment/create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount, package_id: pkgName })
                    });
                    
                    const data = await res.json();
                    if (!data.success) {
                        showToast('Lỗi tạo đơn hàng', data.error, 'error');
                        modal.classList.remove('show');
                        return;
                    }

                    currentTransactionId = data.transaction_id;
                    const transferContent = currentTransactionId;
                    
                    // Gắn nội dung vào HTML
                    contentDisplay.innerText = transferContent;
                    contentBox.setAttribute('data-copy', transferContent);
                    
                    // Tạo link VietQR
                    const qrUrl = `https://img.vietqr.io/image/${bankId}-${accountNo}-compact2.png?amount=${amount}&addInfo=${encodeURIComponent(transferContent)}&accountName=${encodeURIComponent(accountName)}`;
                    
                    // Reset hoàn toàn trước khi load ảnh mới
                    qrImage.src = '';
                    qrImage.style.display = 'none';
                    qrLoading.style.display = 'block';
                    qrLoading.innerText = 'Đang tạo mã QR...';

                    // Gắn handler TRƯỚC khi set src (tránh race condition với cache)
                    qrImage.onload = () => {
                        qrLoading.style.display = 'none';
                        qrImage.style.display = 'block';
                    };
                    qrImage.onerror = () => {
                        qrLoading.innerText = '⚠️ Không tải được mã QR. Vui lòng dùng thông tin bên cạnh để chuyển khoản.';
                    };

                    // Set src sau cùng để trigger load
                    qrImage.src = qrUrl;
                } catch (err) {
                    showToast('Lỗi kết nối', 'Không thể kết nối đến máy chủ. Vui lòng thử lại.', 'error');
                    modal.classList.remove('show');
                }
            });
        });
        
        // Đóng modal
        const closeModal = () => {
            modal.classList.remove('show');
            currentTransactionId = null;
            if (checkInterval) {
                clearInterval(checkInterval);
                checkInterval = null;
            }
            confirmBtn.innerHTML = 'Tôi đã chuyển khoản';
            confirmBtn.style.background = '';
            confirmBtn.style.color = '';
            confirmBtn.disabled = false;
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
        
        // Copy text
        document.querySelectorAll('.copyable').forEach(el => {
            el.addEventListener('click', () => {
                const text = el.getAttribute('data-copy');
                if(!text) return;
                navigator.clipboard.writeText(text).then(() => {
                    showToast('Đã copy: ' + text, 'success', 2000);
                });
            });
        });
        
        // Hàm gọi API kiểm tra
        const checkPaymentStatus = async () => {
            if (!currentTransactionId) return;
            try {
                const res = await fetch('/api/payment/check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ transaction_id: currentTransactionId })
                });
                const data = await res.json();
                if (data.success && data.status === 'paid') {
                    // Thành công
                    if (checkInterval) clearInterval(checkInterval);
                    confirmBtn.innerHTML = '<i class="fa-solid fa-circle-check"></i> Thanh toán thành công!';
                    confirmBtn.style.background = '#4CAF50';
                    confirmBtn.style.color = '#fff';
                    
                    // Cập nhật ví hiển thị
                    if (window.fetchBalance) window.fetchBalance(true);
                    
                    setTimeout(() => {
                        closeModal();
                        showSuccessPopup();
                    }, 800);
                } else if (data.success && data.status === 'insufficient') {
                    // Nạp thiếu tiền
                    if (checkInterval) clearInterval(checkInterval);
                    confirmBtn.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Nạp thiếu tiền';
                    confirmBtn.style.background = '#ff5252';
                    confirmBtn.style.color = '#fff';
                    
                    showToast('Bạn đã chuyển không đủ số tiền của gói này. Vui lòng liên hệ Admin để được hỗ trợ thủ công.', 'error', 15000);
                    
                    setTimeout(() => {
                        closeModal();
                    }, 5000);
                }
            } catch (err) {
                console.error('Check payment error', err);
            }
        };

        // Nút xác nhận
        confirmBtn.addEventListener('click', () => {
            if (!currentTransactionId) return;

            confirmBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Đang chờ ngân hàng...';
            confirmBtn.style.background = '#555';
            confirmBtn.style.color = '#fff';
            confirmBtn.disabled = true;
            
            // Bắt đầu polling mỗi 3 giây
            checkPaymentStatus();
            if (checkInterval) clearInterval(checkInterval);
            checkInterval = setInterval(checkPaymentStatus, 3000);
            
            // Tự động dừng sau 5 phút nếu không có kết quả
            setTimeout(() => {
                if (checkInterval) {
                    clearInterval(checkInterval);
                    checkInterval = null;
                    confirmBtn.innerHTML = 'Thử lại lần nữa';
                    confirmBtn.style.background = '';
                    confirmBtn.style.color = '';
                    confirmBtn.disabled = false;
                    showToast('Hệ thống chưa nhận được thông báo từ ngân hàng. Nếu đã chuyển thành công, Credit sẽ cộng trong ít phút. Liên hệ Admin nếu cần.', 'error', 10000);
                }
            }, 5 * 60 * 1000);
        });
    });
</script>
