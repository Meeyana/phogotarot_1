        /* === SCROLL REVEAL === */
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(50px);
            transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
            will-change: opacity, transform;
        }
        .reveal-on-scroll.is-visible {
            opacity: 1; transform: translateY(0);
        }
    </style>
    <script>
      // Hàm khởi tạo hiệu ứng
      const initScrollReveal = () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.15 // Khi thấy 15% của section thì bắt đầu hiện
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Thêm class để kích hoạt CSS animation
              entry.target.classList.add('is-visible');
              // Sau khi hiện rồi thì thôi không theo dõi nữa (để không bị ẩn đi hiện lại)
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        // Tự động chọn tất cả các section có class .homepage-section
        const sections = document.querySelectorAll('.homepage-section');
        sections.forEach(section => {
          section.classList.add('reveal-on-scroll'); // Thêm class ẩn mặc định
          observer.observe(section); // Bắt đầu theo dõi
        });
      };
      // GTM Tracking Logic
      const initGTMTracking = () => {
        // Hero CTA
        const heroCta = document.querySelector('#home .btn-primary');
        if (heroCta) {
          heroCta.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_hero_cta'
            });
          });
        }

        // About CTA
        const aboutCta = document.querySelector('#about .btn-outline');
        if (aboutCta) {
          aboutCta.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_about_cta'
            });
          });
        }

        // Services Cards
        const magicCards = document.querySelectorAll('.magic-card');
        magicCards.forEach(card => {
          card.addEventListener('click', () => {
            const href = card.getAttribute('href');
            let serviceName = 'unknown';
            if (href === '/xem-tarot') serviceName = 'ai_reader';
            else if (href === '/yes-no-reading') serviceName = 'yes_no';
            else if (href === '/zodiac-daily') serviceName = 'zodiac';

            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_service_card',
              'service_name': serviceName
            });
          });
        });

        // Zodiac Selector
        const zodiacItems = document.querySelectorAll('.zodiac-item-standalone');
        zodiacItems.forEach(item => {
          item.addEventListener('click', () => {
            const href = item.getAttribute('href') || '';
            const signMatch = href.match(/sign=([^&]+)/);
            const sign = signMatch ? signMatch[1] : 'unknown';

            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_zodiac_quick_select',
              'zodiac_sign': sign
            });
          });
        });

        // Blog Clicks
        const blogLinks = document.querySelectorAll('#blog a');
        blogLinks.forEach(link => {
          link.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_blog_link'
            });
          });
        });

        // Oracle CTA
        const oracleCta = document.querySelector('#oracle .btn-primary');
        if (oracleCta) {
          oracleCta.addEventListener('click', () => {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              'event': 'feature_usage',
              'feature_name': 'homepage',
              'action': 'click_footer_contact_cta'
            });
          });
        }
      };

      // Chạy hàm khi trang load xong
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
        initGTMTracking();
      });
      
      // (Dành cho Astro View Transitions)
      document.addEventListener('astro:page-load', () => {
        initScrollReveal();
        initGTMTracking();
      });
    </script>
</BaseLayout>
