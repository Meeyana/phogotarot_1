---
// 1. IMPORT (Thêm BaseLayout)
import BaseLayout from '../layouts/BaseLayout.astro'; // (Giả sử đường dẫn layout)

import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import wheelImg from '../assets/wheel.png';
import img1 from '../assets/img-1.jpg';
import img2 from '../assets/img-2.jpg';

// Lấy tất cả bài viết trong collection 'blog'
const allPosts = await getCollection("blog");

// Sắp xếp bài viết: Mới nhất lên đầu
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Chỉ lấy 3 bài đầu tiên
const recentPosts = sortedPosts.slice(0, 3);

// 2. (SỬA LẠI) TẠO CÁC BIẾN VÀ SCHEMA
const pageTitle = "Phở Gõ Tarot | Xem Bói Bài Tarot Online Miễn Phí";
const pageDesc = "Trải nghiệm bói Tarot online miễn phí, nhanh chóng và chính xác. Khám phá các thông điệp vũ trụ về tình yêu, công việc, tương lai và chữa lành tâm hồn.Vũ Trụ cùng Phở Gõ Tarot.";

---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
>    
    
    <main id="homepage-content">

        <section id="home" class="homepage-section" style="padding-top: 3rem; min-height: 80vh; display: flex; align-items: center;">
            <div class="container">
                <div class="grid-2">
                    <div class="text-center" style="md:text-align: left;">
                        <div class="promo-badge">🌟 Tặng 1 Credit miễn phí mỗi ngày</div>
                        <h2 class="hero-title">Phở Gõ Tarot</h2>
                        <p class="section-text" style="font-size: 1.25rem; margin-bottom: 2rem;">
                            Chào mừng bạn đến với Phở Gõ Tarot, không gian dành riêng cho những ai tìm kiếm sự khai sáng qua lăng kính Tarot huyền bí. Với mong muốn mang lại sự thấu cảm mộc mạc như một tô phở gõ vỗ về tâm hồn, mỗi ngày bạn sẽ được tặng 1 Credit trải bài hoàn toàn miễn phí để giải đáp các khúc mắc về tình cảm, công việc và cuộc sống. Hãy tập trung năng lượng, nhận thông điệp hôm nay từ vũ trụ và để Phở Gõ Tarot đồng hành cùng bạn.
                        </p>
                        <a href="/xem-tarot" class="btn-primary">Xem Tarot Ngay</a>
                    </div>
                    <div style="display:flex;">
                        <div class="spinning-wheel-container">
                            <Image src={wheelImg} alt="Vòng tròn Zodiac" class="section-image spinning-wheel" width={700} fetchpriority="high" decoding="async" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="container"><div class="divider"></div></div>

        <section id="about" class="homepage-section">
            <div class="container">
                <div class="grid-2">
                    <div>
                        <Image src={img1} alt="Tarot Reader" class="section-image" width={700} loading="lazy" decoding="async" />
                    </div>
                    <div class="text-center" style="md:text-align: left;">
                        <h2 class="section-subtitle">Tarot là gì?</h2>
                        <p class="section-text text-left">
                            Tarot là một bộ 78 lá bài, mỗi lá mang một ý nghĩa biểu tượng riêng. Nó không phải để dự đoán tương lai một cách chính xác, mà là một công cụ để tự suy ngẫm, khám phá bản thân và cung cấp một góc nhìn mới về các tình huống trong cuộc sống.
                        </p>
                        <p class="section-text text-left">
                            Một buổi đọc bài tarot có thể giúp bạn hiểu rõ hơn về những thách thức, cơ hội và tiềm năng ẩn giấu bên trong bạn.
                        </p>
                        <a href="contact" class="btn-outline">Đặt Lịch Đọc Bài</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="services" class="homepage-section bg-alt">
            <div class="container">
                <h2 class="section-title">Các Tính Năng Trải Bài</h2>
                <div class="grid-3">
                    <a href="/xem-tarot" class="magic-card">
                        <div class="icon-glow">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="6" y="2" width="12" height="20" rx="2" transform="rotate(-5 12 12)"></rect>
                                <rect x="6" y="2" width="12" height="20" rx="2" transform="rotate(5 12 12)"></rect>
                                <path d="M12 8v8"></path> <path d="M8 12h8"></path>
                            </svg>
                        </div>
                        <h3 class="magic-title">Trò Chuyện & Trải Bài</h3>
                        <p class="magic-desc">Trò chuyện tương tác để nhận trải bài sâu sắc (1, 3, hoặc 5 lá) giải mã mọi thắc mắc của bạn.</p>
                        <span class="magic-link">Trò chuyện ngay &rarr;</span>
                    </a>
                    
                    <a href="/yes-no-reading" class="magic-card">
                        <div class="icon-glow">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                <line x1="12" y1="17" x2="12.01" y2="17"></line>
                            </svg>
                        </div>
                        <h3 class="magic-title">Hỏi Đáp Yes/No</h3>
                        <p class="magic-desc">Câu trả lời dứt khoát "Có" hoặc "Không" cho những băn khoăn tức thời.</p>
                        <span class="magic-link">Lật bài ngay &rarr;</span>
                    </a>
                    
                    <a href="/zodiac-daily" class="magic-card">
                        <div class="icon-glow">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                            </svg>
                        </div>
                        <h3 class="magic-title">Zodiac Tarot</h3>
                        <p class="magic-desc">Thông điệp vũ trụ dành riêng cho cung hoàng đạo của bạn hôm nay.</p>
                        <span class="magic-link">Xem thông điệp &rarr;</span>
                    </a>
                </div>
            </div>
        </section>

        <section id="zodiac-selector" class="homepage-section bg-alt">
            <div class="container text-center">
                <h2 class="section-title">Thông Điệp Vũ Trụ Hôm Nay</h2>
                <p class="section-text" style="max-width: 800px; margin: -1.5rem auto 3rem auto; font-size: 1.15rem; opacity: 0.85;">
                    Mỗi ngày, các chòm sao lại mang một tần số năng lượng khác nhau gửi đến bạn. Hãy chọn Cung hoàng đạo của mình dưới đây để đón nhận nhanh thông điệp chỉ dẫn từ Vũ trụ.
                </p>
                <div class="zodiac-grid-standalone">
                    <a href="/zodiac-daily?sign=aries" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♈</span>
                        <h4 class="zodiac-name">Bạch Dương</h4>
                        <span class="zodiac-slug">Aries</span>
                    </a>
                    <a href="/zodiac-daily?sign=taurus" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♉</span>
                        <h4 class="zodiac-name">Kim Ngưu</h4>
                        <span class="zodiac-slug">Taurus</span>
                    </a>
                    <a href="/zodiac-daily?sign=gemini" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♊</span>
                        <h4 class="zodiac-name">Song Tử</h4>
                        <span class="zodiac-slug">Gemini</span>
                    </a>
                    <a href="/zodiac-daily?sign=cancer" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♋</span>
                        <h4 class="zodiac-name">Cự Giải</h4>
                        <span class="zodiac-slug">Cancer</span>
                    </a>
                    <a href="/zodiac-daily?sign=leo" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♌</span>
                        <h4 class="zodiac-name">Sư Tử</h4>
                        <span class="zodiac-slug">Leo</span>
                    </a>
                    <a href="/zodiac-daily?sign=virgo" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♍</span>
                        <h4 class="zodiac-name">Xử Nữ</h4>
                        <span class="zodiac-slug">Virgo</span>
                    </a>
                    <a href="/zodiac-daily?sign=libra" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♎</span>
                        <h4 class="zodiac-name">Thiên Bình</h4>
                        <span class="zodiac-slug">Libra</span>
                    </a>
                    <a href="/zodiac-daily?sign=scorpio" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♏</span>
                        <h4 class="zodiac-name">Bọ Cạp</h4>
                        <span class="zodiac-slug">Scorpio</span>
                    </a>
                    <a href="/zodiac-daily?sign=sagittarius" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♐</span>
                        <h4 class="zodiac-name">Nhân Mã</h4>
                        <span class="zodiac-slug">Sagittarius</span>
                    </a>
                    <a href="/zodiac-daily?sign=capricorn" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♑</span>
                        <h4 class="zodiac-name">Ma Kết</h4>
                        <span class="zodiac-slug">Capricorn</span>
                    </a>
                    <a href="/zodiac-daily?sign=aquarius" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♒</span>
                        <h4 class="zodiac-name">Bảo Bình</h4>
                        <span class="zodiac-slug">Aquarius</span>
                    </a>
                    <a href="/zodiac-daily?sign=pisces" class="zodiac-item-standalone">
                        <span class="zodiac-icon">♓</span>
                        <h4 class="zodiac-name">Song Ngư</h4>
                        <span class="zodiac-slug">Pisces</span>
                    </a>
                </div>
            </div>
        </section>

        <section id="blog" class="homepage-section">
            <div class="container">
                <h2 class="section-title">Bài Viết Mới</h2>
                
                <div class="grid-3">
                    {/* Bắt đầu vòng lặp lấy 3 bài viết */}
                    {recentPosts.map((post) => (
                        <div class="blog-card mdf-blog">
                            {/* LINK ẢNH */}
                            <a href={`/blog/${post.slug}`} class="image-link-wrapper">
                                <div class="image-wrapper-4-3">
                                    <Image 
                                        src={post.data.image} 
                                        alt={post.data.title} 
                                        width={400} /* Định kích thước cố định để tối ưu */
                                        height={300}
                                        class="section-image"
                                    />
                                </div>
                            </a>
                            
                            {/* LINK TIÊU ĐỀ */}
                            <a href={`/blog/${post.slug}`} class="title-link">
                                <h3 class="section-subtitle home-blog-title">
                                    {post.data.title}
                                </h3>
                            </a>
                            
                            {/* ĐOẠN TRÍCH DẪN */}
                            <p class="section-text" style="font-size: 0.9rem; text-align: left; opacity: 0.8; padding: 0 1rem;">
                                {post.data.excerpt}
                            </p>
                            
                            {/* NÚT ĐỌC TIẾP */}
                            <a href={`/blog/${post.slug}`} class="btn-outline home-blog-btn">
                                Đọc tiếp &rarr;
                            </a>
                        </div>
                    ))}
                </div>

                <div class="text-center" style="md:text-align: left; margin-top: 2rem;">
                        
                        <a href="/blog" class="btn-primary">Xem thêm</a>
                </div>

                
            </div>

        </section>

        <section id="testimonials" class="homepage-section bg-alt">
            <div class="container">
                <h2 class="section-title">Lời Cảm Ơn Từ Lữ Khách</h2>
                <div class="grid-3">
                    <div class="testimonial-card">
                        <div class="testimonial-rating">⭐⭐⭐⭐⭐</div>
                        <p class="testimonial-text">"Trải bài Tarot trên Phở Gõ thực sự rất kỳ diệu. AI luận giải vô cùng sâu sắc và chạm đúng vấn đề khúc mắc của mình trong công việc. 1 credit free mỗi ngày quá đủ để mình định hướng năng lượng."</p>
                        <div class="testimonial-user">
                            <img src="https://ui-avatars.com/api/?name=Minh+Anh&background=F2C94C&color=0b132b" alt="Lữ khách Minh Anh" class="user-avatar" />
                            <div class="user-info">
                                <h4 class="user-name">Minh Anh</h4>
                                <span class="user-role">Lữ khách Cự Giải</span>
                            </div>
                        </div>
                    </div>

                    <div class="testimonial-card">
                        <div class="testimonial-rating">⭐⭐⭐⭐⭐</div>
                        <p class="testimonial-text">"Giao diện trò chuyện tương tác với Oracle cực kỳ cuốn luôn. Câu trả lời của Reader AI có độ thấu cảm cao, giống như một người bạn thực sự đang lắng nghe mình. Đã nạp Gói 3 Credit để tiếp tục bốc bài."</p>
                        <div class="testimonial-user">
                            <img src="https://ui-avatars.com/api/?name=Quoc+Bao&background=F2C94C&color=0b132b" alt="Lữ khách Quốc Bảo" class="user-avatar" />
                            <div class="user-info">
                                <h4 class="user-name">Quốc Bảo</h4>
                                <span class="user-role">Lữ khách Sư Tử</span>
                            </div>
                        </div>
                    </div>

                    <div class="testimonial-card">
                        <div class="testimonial-rating">⭐⭐⭐⭐⭐</div>
                        <p class="testimonial-text">"Mình băn khoăn chuyện tình cảm và đã dùng tính năng Yes/No. Câu trả lời dứt khoát kèm lời khuyên chân thành giúp mình gỡ rối hoàn toàn. Hệ thống bảo mật cực tốt, có cả nút xóa lịch sử vĩnh viễn rất an tâm."</p>
                        <div class="testimonial-user">
                            <img src="https://ui-avatars.com/api/?name=Thu+Thao&background=F2C94C&color=0b132b" alt="Lữ khách Thu Thảo" class="user-avatar" />
                            <div class="user-info">
                                <h4 class="user-name">Thu Thảo</h4>
                                <span class="user-role">Lữ khách Song Ngư</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="faq" class="homepage-section">
            <div class="container">
                <h2 class="section-title">Câu Hỏi Thường Gặp</h2>
                
                <div class="faq-container">
                    <details class="faq-item">
                        <summary class="faq-question">Xem Tarot tại Phở Gõ có tốn phí không?</summary>
                        <div class="faq-answer">
                            <p>Không hề bắt buộc nhé! Mỗi tài khoản tại Phở Gõ Tarot đều được tặng sẵn <strong>1 Credit miễn phí vào lúc 0:00 hàng ngày</strong> để bạn thoải mái rút bài định hướng năng lượng cho ngày mới. Lượt miễn phí này không cộng dồn. Nếu bạn muốn xem thêm các câu hỏi khác trong ngày, bạn có thể <a href="/nap-credit" style="color: var(--gold-color); text-decoration: underline; font-weight: 600;">nạp thêm Credit</a> với chi phí vô cùng "hạt dẻ".</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary class="faq-question">Credit là gì và hoạt động như thế nào?</summary>
                        <div class="faq-answer">
                            <p>Credit là lượt dùng để thực hiện các trải bài Tarot hoặc đặt câu hỏi chuyên sâu cho Oracle tại Phở Gõ. Mỗi lượt bốc bài (1 lá Yes/No hoặc trải bài nhiều lá) sẽ tiêu tốn 1 Credit. Bạn có thể tích lũy Credit từ gói nạp của mình và sử dụng bất cứ lúc nào bạn cần.</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary class="faq-question">Xem Tarot online có chính xác không?</summary>
                        <div class="faq-answer">
                            <p>Tarot kết nối dựa trên năng lượng và trực giác, những yếu tố này không bị giới hạn bởi khoảng cách vật lý hay màn hình điện thoại. Tuy nhiên, khi xem Tarot online bạn cần tập trung hơn để thông điệp gửi đến bạn một cách trọn vẹn nhất.</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary class="faq-question">Nếu mình cần xem chi tiết hơn thì thế nào?</summary>
                        <div class="faq-answer">
                            <p>Chúng mình sẵn sàng lắng nghe bạn qua <a href="/contact" style="color: var(--gold-color); text-decoration: underline; font-weight: 600;">Đặt lịch tư vấn</a>. Hãy gửi mình lá bài bạn nhận được và câu hỏi của bạn để chúng mình giải đáp kỹ hơn nhé.</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary class="faq-question">Thông tin câu chuyện của mình có được bảo mật không?</summary>
                        <div class="faq-answer">
                            <p><strong>Tuyệt đối bảo mật và riêng tư!</strong> Mọi câu hỏi, chia sẻ và thông điệp trải bài của bạn tại Phở Gõ Tarot đều được giữ kín hoàn toàn. Hệ thống mã hóa thông tin và không chia sẻ cho bên thứ ba dưới bất kỳ hình thức nào.</p>
                            <p style="margin-top: 8px;">Đặc biệt, để bảo vệ quyền riêng tư cá nhân một cách tối đa, <strong>bạn có toàn quyền chủ động quản lý và xóa vĩnh viễn lịch sử trải bài của mình</strong>. Bạn chỉ cần truy cập vào trang <a href="/history" style="color: var(--gold-color); text-decoration: underline; font-weight: 600;">Lịch sử trải bài (/history)</a> trong tài khoản cá nhân của mình để tự tay xóa sạch các phiên trò chuyện hoặc trải bài cũ bất kỳ lúc nào. Hãy an tâm chia sẻ cùng Phở Gõ nhé!</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary class="faq-question">Mình chưa biết nên hỏi gì có xem được không?</summary>
                        <div class="faq-answer">
                            <p>Đừng lo nhé! Nếu bạn đang rối bời, Reader của Phở Gõ sẽ giúp bạn gỡ rối và định hình câu hỏi. Chúng mình cũng có những trải bài tổng quan để bạn nắm bắt tình hình chung mà không cần câu hỏi cụ thể.</p>
                        </div>
                    </details>
                    
                     <details class="faq-item">
                        <summary class="faq-question">Làm sao để đặt lịch xem bài?</summary>
                        <div class="faq-answer">
                            <p>Bạn chỉ cần bấm vào nút "Đặt lịch tư vấn" hoặc nhắn tin trực tiếp qua Fanpage. Tụi mình sẽ phản hồi và sắp xếp khung giờ phù hợp nhất cho bạn ngay.</p>
                        </div>
                    </details>
                </div>

            </div>
        </section>

        <section id="oracle" class="homepage-section bg-alt">
            <div class="container">
                <div class="grid-2">
                    <div class="text-center" style="md:text-align: left;">
                        <h2 class="section-subtitle">Cần tư vấn từ chuyên gia?</h2>
                        <p class="section-text text-left">
                            Nếu trong quá trình đọc bài bạn vẫn còn điều gì băn khoăn hoặc muốn được giải thích chi tiết hơn, cứ thoải mái liên hệ với Phở Gõ nhé. Chúng mình luôn sẵn sàng hỗ trợ để bạn hiểu rõ vấn đề một cách nhanh chóng và chính xác nhất.
                        </p>
                        <a href="/contact" class="btn-primary">Đặt lịch tư vấn</a>
                    </div>
                    <div>
                        <Image src={img2} alt="Oracle Cards" class="section-image" width={700} loading="lazy" decoding="async" />
                    </div>
                </div>
            </div>
        </section>
    </main>

    <style>
