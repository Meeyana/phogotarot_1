---
// 1. IMPORT
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';
import { breadcrumbListSchema, faqPageSchema, graphSchema, webApplicationSchema, webPageSchema } from '../lib/schema';

// 2. Tạo metadata và schema
const pageTitle = "Tarot Yes/No Online Miễn Phí - Rút 1 Lá Có Hoặc Không | Phở Gõ Tarot";
const pageDesc = "Rút 1 lá Tarot Yes/No online để nhận câu trả lời Có, Không hoặc Chưa rõ cho tình yêu, công việc và quyết định nhanh. Có 1 lượt miễn phí mỗi ngày.";
const pageUrl = new URL('/yes-no-reading', Astro.site).href;
const deepReadingUrl = new URL('/xem-tarot', Astro.site).href;

const faqItems = [
  {
    question: "Tarot Yes/No là gì?",
    answer: "Tarot Yes/No là trải bài một lá dành cho câu hỏi cụ thể cần hướng trả lời Có, Không hoặc Chưa rõ. Kết quả nên được xem như một tín hiệu tham khảo để bạn cân nhắc quyết định."
  },
  {
    question: "Nên hỏi Yes/No khi nào?",
    answer: "Bạn nên dùng Yes/No khi câu hỏi đã rõ, chỉ xoay quanh một vấn đề và cần hướng đi nhanh. Ví dụ: 'Tôi có nên chủ động nhắn tin trong tuần này không?' hoặc 'Offer này có phù hợp với mục tiêu hiện tại không?'."
  },
  {
    question: "Khi nào không nên hỏi Yes/No?",
    answer: "Không nên dùng Yes/No cho câu hỏi quá rộng, nhiều lựa chọn cùng lúc hoặc cần phân tích nguyên nhân sâu. Khi vấn đề có nhiều lớp cảm xúc và bối cảnh, trải bài hội thoại sẽ phù hợp hơn."
  },
  {
    question: "Nếu cần phân tích sâu hơn thì làm gì?",
    answer: "Nếu câu trả lời Yes/No khiến bạn muốn hiểu nguyên nhân, lời khuyên hoặc bước tiếp theo, hãy chuyển sang trang xem tarot online dạng hội thoại để đặt câu hỏi mở và chọn trải bài nhiều lá hơn."
  }
];

const schema = graphSchema([
  webPageSchema({ url: pageUrl, name: pageTitle, description: pageDesc }),
  webApplicationSchema({ url: pageUrl, name: "Tarot Yes/No Online - Phở Gõ Tarot", description: pageDesc }),
  breadcrumbListSchema(pageUrl, [
    { name: "Trang chủ", url: "/" },
    { name: "Tarot Yes/No Online", url: "/yes-no-reading" }
  ]),
  faqPageSchema(pageUrl, faqItems)
]);

import fallbackTarotCards from '../data/tarot-cards.json';
import fallbackYesNoCards from '../data/yesno-meanings.json';

const sourceCardImages = import.meta.glob('/src/assets/uploads/cards/*.jpg', { eager: true, import: 'default' });
const optimizedCardImageEntries = await Promise.all(
    Object.entries(sourceCardImages).map(async ([path, image]) => {
        const optimized = await getImage({ src: image as any, width: 480, format: 'webp', quality: 72 });
        return [path.split('/').pop() || '', optimized.src];
    })
);
const optimizedCardImageMap = Object.fromEntries(optimizedCardImageEntries);

// Đọc gợi ý câu hỏi từ KV, nếu chưa có thì dùng mặc định
let suggestedQuestionsKV = JSON.stringify([
  { "category": "Tình Cảm", "question": "Tôi có nên tiếp tục mối quan hệ này không?" },
  { "category": "Tình Cảm", "question": "Người ấy có còn tình cảm với tôi không?" },
  { "category": "Tình Cảm", "question": "Nếu tôi chủ động nhắn tin, mọi chuyện có tiến triển tốt không?" },
  { "category": "Công Việc", "question": "Tôi có nên nghỉ công việc hiện tại không?" },
  { "category": "Công Việc", "question": "Công việc mới này có mang lại kết quả tích cực không?" },
  { "category": "Công Việc", "question": "Nếu tôi đầu tư thời gian cho dự án này, có đáng không?" },
  { "category": "Tài Chính", "question": "Tôi có nên đầu tư vào cơ hội này không?" },
  { "category": "Tài Chính", "question": "Tình hình tài chính của tôi có cải thiện trong thời gian tới không?" },
  { "category": "Tài Chính", "question": "Nếu tôi mạo hiểm một chút, kết quả có khả quan không?" },
  { "category": "Chung", "question": "Tôi có đang đi đúng hướng cuộc sống không?" },
  { "category": "Chung", "question": "Nếu tôi bắt đầu lại từ đầu bây giờ, có phải là quyết định đúng không?" },
  { "category": "Chung", "question": "Tôi có nên tin vào trực giác của mình trong việc này không?" }
]);
let tarotCardsKV = JSON.stringify(fallbackTarotCards);
let tarotCardsYesNoKV = JSON.stringify(fallbackYesNoCards);
if (Astro.locals.runtime?.env?.SESSION) {
    try {
        const raw = await Astro.locals.runtime.env.SESSION.get('SUGGESTED_YN_QUESTIONS');
        if (raw) suggestedQuestionsKV = raw;
        
        const cardsRaw = await Astro.locals.runtime.env.SESSION.get('TAROT_CARDS');
        if (cardsRaw) tarotCardsKV = cardsRaw;
        
        const ynRaw = await Astro.locals.runtime.env.SESSION.get('TAROT_CARDS_YESNO');
        if (ynRaw) tarotCardsYesNoKV = ynRaw;
    } catch(e) {
        console.error("Lỗi đọc KV trong yes-no-reading.astro:", e);
    }
}
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
>
    <script define:vars={{ isLoggedIn: !!Astro.locals.user, optimizedCardImageMap }}>
        window.IS_LOGGED_IN = isLoggedIn;
        window.TAROT_CARD_IMAGE_MAP = optimizedCardImageMap || {};
    </script>
    <!-- CONFIRM MODAL OVERLAY (Toàn cục) -->
    <div id="credit-confirm-modal" class="confirm-modal hidden">
        <div class="confirm-modal-content">
            <h3>Xác nhận trải bài</h3>
            <p>Câu hỏi này sẽ tiêu tốn <strong>1 Credit</strong>. Bạn có đồng ý bốc bài không?</p>
            <p style="font-size: 0.9em; opacity: 0.8; margin-bottom: 1.5rem;">Số credit hiện tại: <strong id="credit-num" style="color: var(--gold-color);">đang tải...</strong></p>
            <div class="confirm-buttons">
                <button id="confirm-yes-btn" class="btn-yes">Đồng ý</button>
                <button id="confirm-no-btn" class="btn-no">Hủy</button>
            </div>
        </div>
    </div>

    <!-- MÀN HÌNH 1: ĐẶT CÂU HỎI -->
    <div id="question-screen" class="screen active">
        <h1 class="title">Hãy suy nghĩ và tập trung vào câu hỏi của bạn</h1>
        <p class="subtitle">Trải bài này sẽ tự động rút 1 lá bài Yes/No cho bạn. Mỗi ngày bạn được tặng 1 lượt xem bài miễn phí.</p>
        {!Astro.locals.user && (
            <a href="/login?redirect=/yes-no-reading" class="login-badge" style="margin-bottom: 20px; display: inline-block; padding: 6px 16px; background: rgba(242, 201, 76, 0.1); border: 1px solid rgba(242, 201, 76, 0.3); border-radius: 20px; color: #F2C94C; font-size: 0.95rem; text-decoration: none; transition: all 0.2s ease;">
                <i class="fa-solid fa-lock" style="margin-right: 5px;"></i> Bạn cần đăng nhập để sử dụng miễn phí mỗi ngày
            </a>
        )}
        
        <div id="question-input-area" class="question-input-area">
            <textarea id="question-input" class="question-input" placeholder="Viết câu hỏi Yes/No của bạn ở đây..." style="min-height: 56px;"></textarea>
            <button id="submit-question-btn" title="Gửi câu hỏi">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                    <path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" />
                </svg>
            </button>
        </div>
        
        <div id="reading-options-container" style="display: none;">
            <button class="reading-option-btn active" data-value="1">
                Chọn 1 lá
            </button>
        </div>

        <div class="dropdown-container">
            <button id="suggested-questions-toggle" class="dropdown-toggle">
                <span><i class="fa-regular fa-lightbulb"></i> Gợi ý câu hỏi</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" class="arrow-icon">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.23 8.29a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
            </button>
            <div id="suggested-questions-list" class="dropdown-menu">
                <p style="padding: 1rem; opacity: 0.7; text-align: center;">Đang tải gợi ý...</p>
            </div>
        </div>
        
        <p id="question-error-display" class="error-message"></p>


        <!-- --- PHẦN MỚI: BÀI VIẾT SEO / GEO (YES/NO SPECIFIC) --- -->
        <div class="seo-divider"></div>
        
        <article class="seo-guide-container">
            <h2 class="seo-title">Tarot Yes/No phù hợp với câu hỏi nào?</h2>
            <p class="seo-intro">
                Tarot Yes/No online phù hợp khi bạn có một câu hỏi cụ thể và cần hướng trả lời nhanh: Có, Không hoặc Chưa rõ. Với các vấn đề nhiều bối cảnh như tình yêu, công việc hoặc quyết định cá nhân, kết quả nên được xem như tín hiệu tham khảo để bạn cân nhắc bước tiếp theo.
            </p>

            <div class="seo-tips-grid">
                <div class="seo-tip-card">
                    <h3 class="tip-title">Hỏi một vấn đề duy nhất</h3>
                    <p class="tip-content">Tránh gộp hai lựa chọn trong cùng một câu. Thay vì hỏi "Tôi nên chọn A hay B?", hãy tách thành hai câu hỏi riêng để kết quả rõ hơn.</p>
                </div>
                <div class="seo-tip-card">
                    <h3 class="tip-title">Thêm mốc thời gian</h3>
                    <p class="tip-content">Câu hỏi như "trong tuần này", "trong tháng tới" hoặc "ở giai đoạn hiện tại" thường dễ luận giải hơn câu hỏi quá rộng.</p>
                </div>
                <div class="seo-tip-card">
                    <h3 class="tip-title">Không hỏi lại liên tục</h3>
                    <p class="tip-content">Nếu kết quả chưa như ý, hãy để cảm xúc lắng xuống trước khi hỏi lại. Việc rút đi rút lại cùng một câu hỏi dễ khiến bạn phụ thuộc vào kết quả.</p>
                </div>
            </div>

            <div class="seo-examples">
                <h2 class="example-title">Ví dụ câu hỏi Yes/No tốt</h2>
                <ul class="example-list">
                    <li><strong>Tình yêu:</strong> "Tôi có nên chủ động nhắn tin cho người ấy trong tuần này không?"</li>
                    <li><strong>Công việc:</strong> "Offer mới này có phù hợp với mục tiêu nghề nghiệp hiện tại của tôi không?"</li>
                    <li><strong>Quyết định nhanh:</strong> "Tôi có nên tiếp tục theo đuổi kế hoạch này trong tháng tới không?"</li>
                </ul>
            </div>

            <div class="seo-examples">
                <h2 class="example-title">Khi nào nên chuyển sang trải bài hội thoại?</h2>
                <p>Nếu bạn cần hiểu nguyên nhân, lời khuyên hoặc nhiều khả năng xảy ra, Tarot Yes/No có thể hơi ngắn. Khi đó, hãy dùng <a href={deepReadingUrl} style="color: var(--gold-color); text-decoration: underline; font-weight: 600;">trải bài tarot online với Reader AI</a> để đặt câu hỏi mở và phân tích sâu hơn.</p>
            </div>

            <div class="seo-examples" id="faq">
                <h2 class="example-title">Câu hỏi thường gặp</h2>
                {faqItems.map((item) => (
                    <details class="seo-faq-item">
                        <summary>{item.question}</summary>
                        <p>{item.answer}</p>
                    </details>
                ))}
            </div>
        </article>
        <!-- --- HẾT PHẦN BÀI VIẾT SEO --- -->

        <div id="card-lookup-container-start" class="card-lookup-container">
            <h2>Tra cứu nhanh ý nghĩa lá bài Yes/No</h2>
            
            <div id="card-search-wrapper">
                <i class="fa-solid fa-search card-search-icon"></i>
                <input type="text" class="card-search-input" data-target="card-lookup-table-1" placeholder="Tìm kiếm bài Tarot...">
            </div>
            
            <div id="card-lookup-table-1">
                <p style="padding: 1rem; opacity: 0.7; text-align: center;">Đang tải dữ liệu tra cứu...</p>
            </div>
        </div>
    </div>

    <!-- MÀN HÌNH 2: XÁO BÀI -->
    <div id="shuffling-screen" class="screen">
        <div id="shuffling-question-display" class="question-display-header"></div>
        <div class="shuffling-animation-container">
            <div class="energy-ring ring-1"></div>
            <div class="energy-ring ring-2"></div>
            <div class="shuffle-card"></div>
            <div class="shuffle-card"></div>
            <div class="shuffle-card"></div>
        </div>
        <p class="shuffling-instruction">
            Hãy giữ tập trung vào câu hỏi của bạn.
            <br>
            Để có kết quả tốt nhất, bạn không nên làm việc riêng trong lúc này.
        </p>
    </div>

    <!-- MÀN HÌNH 3: CHỌN BÀI & KẾT QUẢ -->
    <div id="drawing-screen" class="screen">
        <div id="drawing-question-display" class="question-display-header"></div>
        
        <h2 class="drawing-subheader">Hãy chọn 3 lá bài</h2>
        
        <div id="chosen-cards-display">
            <div class="chosen-card-placeholder"></div>
            <div class="chosen-card-placeholder"></div>
            <div class="chosen-card-placeholder"></div>
        </div>
        
        <div id="card-spread-container"></div>
        
        <div id="action-button-container">
            <button id="get-interpretation-button" class="action-button btn-gold-glow">Xem ý nghĩa</button>
        </div>
        
        <div is:inline id="interpretation-results-display"></div>
        
        <div id="follow-up-question-container">
            <h3>Bạn có câu hỏi nào khác không?</h3>
            <div id="follow-up-input-area" class="question-input-area">
                <textarea id="follow-up-question-input" class="question-input" placeholder="Đặt câu hỏi tiếp theo..." style="min-height: 56px;"></textarea>
                <button id="submit-follow-up-btn" title="Gửi câu hỏi mới">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                        <path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" />
                    </svg>
                </button>
            </div>
            <p id="follow-up-error-display" class="error-message"></p>
        </div>
        
        <div id="card-lookup-container-results" class="card-lookup-container">
            <h2>Tra cứu nhanh ý nghĩa lá bài</h2>
            
            <div id="card-search-wrapper">
                <i class="fa-solid fa-search card-search-icon"></i>
                <input type="text" class="card-search-input" data-target="card-lookup-table-2" placeholder="Tìm kiếm bài Tarot...">
            </div>
            
            <div id="card-lookup-table-2">
                <p style="padding: 1rem; opacity: 0.7; text-align: center;">Đang tải dữ liệu tra cứu...</p>
            </div>
        </div>
    </div>

    <script 
      type="application/ld+json" 
      slot="head"
      set:html={JSON.stringify(schema)}
    />

    <link rel="preload" href="/card-back.jpg" as="image">

    <style is:inline>
        /* ========================================================== */
        /* === 1. STYLE CHUNG TỪ TAROT.ASTRO (THEME DARK BLUE/GOLD) === */
        /* ========================================================== */

        /* === CẤU TRÚC CHUNG === */
        .screen {
            display: none;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem;
            width: 100%;
            position: relative;
            z-index: 1;
        }
        .screen > * { flex-shrink: 0; }
        .screen.active { display: flex; animation: fadeIn 0.5s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes revealCard {
            from { opacity: 0; transform: translateY(20px) rotateY(-90deg); }
            to { opacity: 1; transform: translateY(0) rotateY(0); }
        }
        @keyframes chosenCardSettle {
            from { opacity: 0.85; transform: scale(.985); }
            to { opacity: 1; transform: scale(1); }
        }
        @keyframes dealCardIn {
            from { opacity: 0; transform: translateY(-38px) scale(0.72) rotate(-8deg); filter: blur(2px); }
            to { opacity: 1; transform: translateY(0) scale(1) rotate(var(--card-tilt, 0deg)); filter: blur(0); }
        }
        @keyframes fanCardIn {
            from { opacity: 0; transform: translateX(-50%) rotate(var(--fan-angle)) translateY(36px) scale(.92); filter: blur(2px); }
            to { opacity: 1; transform: translateX(-50%) rotate(var(--fan-angle)) translateY(0) scale(1); filter: blur(0); }
        }
        @keyframes auraBreath {
            0%, 100% { opacity: .58; transform: scale(.92); }
            50% { opacity: 1; transform: scale(1.06); }
        }
        @keyframes energyOrbitOne {
            from { transform: rotateX(64deg) rotateZ(0deg); }
            to { transform: rotateX(64deg) rotateZ(360deg); }
        }
        @keyframes energyOrbitTwo {
            from { transform: rotateX(72deg) rotateY(48deg) rotateZ(0deg); }
            to { transform: rotateX(72deg) rotateY(48deg) rotateZ(360deg); }
        }
        @keyframes slotSheen {
            0%, 45% { transform: translateX(-140%) rotate(18deg); }
            70%, 100% { transform: translateX(140%) rotate(18deg); }
        }
        @keyframes pickBurst {
            from { opacity: 1; transform: translate(-50%, -50%) scale(.35); }
            to { opacity: 0; transform: translate(-50%, -50%) scale(5.2); }
        }

        @media (prefers-reduced-motion: reduce) {
            .shuffle-card,
            .energy-ring,
            .shuffling-animation-container::before,
            .chosen-card-placeholder::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
            }
            .facedown-card,
            .flying-card-animator,
            .flying-card-inner {
                transition-duration: 0.01ms !important;
            }
        }

        /* === TYPOGRAPHY === */
        .title {
            font-family: var(--font-title);
            color: #ffffff;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 700;
            text-align: center;
            margin-bottom: 0.5rem;
            text-shadow: 0 0 15px rgba(242, 201, 76, 0.6), 0 0 30px rgba(242, 201, 76, 0.3);
        }
        
        .subtitle {
            font-size: 1.1rem;
            color: #ccc; margin-bottom: 2.5rem; text-align: center; text-shadow: none;
        }
        
        .question-display-header {
            font-family: var(--font-title);
            color: var(--gold-color, #F2C94C);
            font-size: 1.5rem; margin-bottom: 1rem; text-align: center;
            text-shadow: 0 0 10px rgba(242, 201, 76, 0.3);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 1rem; width: 100%; max-width: 800px;
        }

        /* === INPUT AREA (GLASSMORPHISM) === */
        #question-screen { padding-top: 6rem; justify-content: flex-start; }
        
        .question-input-area {
            width: 100%;
            max-width: 700px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(242, 201, 76, 0.3);
            border-radius: 16px;
            padding: 0.8rem 1rem;
            display: flex; align-items: center; gap: 0.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); transition: all 0.3s ease;
        }
        .question-input-area:focus-within {
            border-color: var(--gold-color, #F2C94C);
            box-shadow: 0 0 20px rgba(242, 201, 76, 0.15);
            background: rgba(255, 255, 255, 0.08);
        }

        .question-input {
            width: 100%;
            background: transparent; border: none; color: #fff;
            font-family: var(--font-body); font-size: 1.1rem; resize: none;
            text-shadow: none; padding: 0.5rem; flex-grow: 1;
        }
        .question-input:focus { outline: none; }
        .question-input::placeholder { color: rgba(255,255,255,0.3); font-size: 1rem; }

        /* Nút Gửi */
        #submit-question-btn, #submit-follow-up-btn {
            flex-shrink: 0;
            width: 48px; height: 48px; border-radius: 50%; border: none;
            background: linear-gradient(135deg, #D4AF37 0%, #F2C94C 50%, #FFD700 100%);
            color: #050A1F; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.3s; box-shadow: 0 0 10px rgba(242, 201, 76, 0.3);
        }
        #submit-question-btn:hover, #submit-follow-up-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 20px rgba(242, 201, 76, 0.6);
            background: linear-gradient(135deg, #FFF 0%, #FFD700 50%, #F2C94C 100%);
        }
        #submit-question-btn:disabled, #submit-follow-up-btn:disabled {
            opacity: 0.6; cursor: not-allowed; filter: grayscale(1);
        }

        .error-message { color: #ff6b6b; font-weight: 600; margin-top: 1rem; min-height: 1.5em; text-shadow: none; }

        /* === DROPDOWN GỢI Ý (SOLID STYLE) === */
        .dropdown-container { width: 100%; max-width: 700px; margin: 1.5rem 0; position: relative; }
        
        .dropdown-toggle {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15); 
            color: #ddd;
            padding: 0.8rem 1.2rem; border-radius: 12px;
            cursor: pointer;
            display: flex; justify-content: space-between; align-items: center;
            font-family: var(--font-body); font-size: 1rem; transition: all 0.3s;
        }
        .dropdown-toggle:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.3);
        }
        .arrow-icon { transition: transform 0.3s; }
        .dropdown-toggle.open .arrow-icon { transform: rotate(180deg); }
        
        .dropdown-menu {
            display: none;
            position: absolute; top: 110%; left: 0; right: 0;
            background-color: #0b132b;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            max-height: 300px;
            overflow-y: auto; z-index: 100;
            padding: 0.5rem 0;
            box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        }
        .dropdown-menu.open { display: block; animation: slideDown 0.2s ease-out; }
        @keyframes slideDown { from{opacity:0; transform:translateY(-5px)} to{opacity:1; transform:translateY(0)} }

        .dropdown-menu::-webkit-scrollbar { width: 5px; }
        .dropdown-menu::-webkit-scrollbar-track { background: transparent; }
        .dropdown-menu::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.2); border-radius: 10px; }
        .dropdown-menu::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.4); }

        .category-title {
            color: var(--gold-color, #F2C94C);
            font-family: var(--font-title);
            font-size: 0.95rem; font-weight: 700;
            padding: 0.8rem 1rem 0.4rem 1rem; margin: 0; 
            text-transform: uppercase; letter-spacing: 0.5px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        .category-title:first-child { border-top: none; padding-top: 0.5rem; }

        .suggestion-item {
            display: block;
            width: 100%; text-align: left; background: none; border: none;
            color: #cbd5e1;
            padding: 0.6rem 1rem; 
            cursor: pointer;
            font-size: 0.95rem; transition: all 0.2s;
            line-height: 1.5;
        }
        .suggestion-item:hover { 
            background: rgba(255, 255, 255, 0.05);
            color: var(--gold-color, #F2C94C);
        }

        /* === SHUFFLING SCREEN === */
        #shuffling-screen { padding-top: 4rem; justify-content: center; }
        .shuffling-animation-container {
            position: relative;
            width: 190px;
            height: 210px;
            margin: 2.4rem auto 2rem;
            perspective: 900px;
            display: grid;
            place-items: center;
        }
        .shuffling-animation-container::before,
        .shuffling-animation-container::after {
            content: '';
            position: absolute;
            border-radius: 999px;
            pointer-events: none;
        }
        .shuffling-animation-container::before {
            width: 190px;
            height: 190px;
            background: radial-gradient(circle, rgba(242,201,76,0.2), rgba(36,169,225,0.08) 42%, transparent 68%);
            filter: blur(2px);
            animation: auraBreath 2.4s ease-in-out infinite;
        }
        .shuffling-animation-container::after {
            width: 120px;
            height: 24px;
            bottom: 5px;
            background: rgba(0,0,0,0.34);
            filter: blur(12px);
        }
        .energy-ring {
            position: absolute;
            width: 174px;
            height: 174px;
            border-radius: 50%;
            border: 1px solid rgba(242, 201, 76, 0.28);
            box-shadow: 0 0 28px rgba(242, 201, 76, 0.12), inset 0 0 22px rgba(36, 169, 225, 0.08);
            transform-style: preserve-3d;
            pointer-events: none;
        }
        .energy-ring.ring-1 { animation: energyOrbitOne 4.5s linear infinite; }
        .energy-ring.ring-2 {
            width: 132px;
            height: 132px;
            border-color: rgba(143, 209, 255, 0.26);
            animation: energyOrbitTwo 6s linear infinite reverse;
        }
        .shuffle-card {
            position: absolute;
            width: 92px; height: 156.4px;
            background-image: url('/card-back.jpg'); background-size: cover;
            border-radius: 8px; border: 1px solid rgba(255,255,255,0.28);
            box-shadow: 0 18px 36px rgba(0,0,0,0.5), 0 0 24px rgba(242, 201, 76, 0.16);
            animation: shuffle 1.7s cubic-bezier(.55,.08,.26,.99) infinite;
            transform-origin: 50% 90%;
            will-change: transform, filter;
        }
        .shuffle-card:nth-child(3) { animation-delay: 0s; }
        .shuffle-card:nth-child(4) { animation-delay: -0.55s; }
        .shuffle-card:nth-child(5) { animation-delay: -1.1s; }
        @keyframes shuffle {
            0%, 100% { transform: translate3d(-48px, 10px, -20px) rotate(-14deg) rotateY(18deg); z-index: 1; filter: brightness(.86);}
            38% { transform: translate3d(0, -18px, 48px) rotate(2deg) rotateY(0deg); z-index: 4; filter: brightness(1.15);}
            70% { transform: translate3d(52px, 10px, 0) rotate(14deg) rotateY(-18deg); z-index: 3; filter: brightness(.96);}
        }
        .shuffling-instruction {
            font-size: 1.2rem;
            color: #d9e2ef; text-align: center; line-height: 1.6;
            text-shadow: 0 0 18px rgba(242, 201, 76, 0.16);
        }

        /* === DRAWING SCREEN === */
        #drawing-screen {
            padding-top: 0.5rem;
            padding-bottom: 5rem;
            justify-content: flex-start;
            min-height: calc(100vh - 90px);
        }
        .drawing-subheader {
            font-family: var(--font-body);
            color: #fff; font-size: 1.3rem;
            margin-bottom: 1.6rem; text-align: center; font-weight: 600;
            text-shadow: 0 0 18px rgba(242, 201, 76, 0.22);
        }

        #drawing-screen #chosen-cards-display { display: flex; gap: 1.5rem; justify-content: center; margin-bottom: 2.4rem; min-height: 180px; height: auto; align-items: flex-start; }
        #chosen-cards-display.spread-1,
        #chosen-cards-display.spread-3 { margin-bottom: 0.3rem; }
        #chosen-cards-display.spread-5 { margin-bottom: 3rem; }
        #drawing-screen .chosen-card-placeholder {
            position: relative;
            overflow: hidden;
            width: 132px; height: 224.4px; border: 1px solid rgba(242, 201, 76, 0.36);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            color: rgba(242, 201, 76, 0.55); font-size: 1.5rem; font-weight: 700;
            background: linear-gradient(145deg, rgba(255,255,255,0.07), rgba(255,255,255,0.015));
            box-shadow: inset 0 0 22px rgba(242,201,76,0.08), 0 12px 28px rgba(0,0,0,0.18);
        }
        #drawing-screen .chosen-card-placeholder::before {
            content: '';
            position: absolute;
            inset: 10px;
            border: 1px dashed rgba(242, 201, 76, 0.22);
            border-radius: 6px;
        }
        #drawing-screen .chosen-card-placeholder::after {
            content: '';
            position: absolute;
            width: 80%;
            height: 120%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transform: translateX(-140%) rotate(18deg);
            animation: slotSheen 3.4s ease-in-out infinite;
        }
        #drawing-screen .chosen-card-item { width: 132px; text-align: center; animation: chosenCardSettle 0.22s ease-out both; }
        #drawing-screen .chosen-card-item img { width: 100%; border-radius: 8px; box-shadow: 0 0 0 1px rgba(255,255,255,0.16), 0 18px 34px rgba(0,0,0,0.35), 0 0 22px rgba(242, 201, 76, 0.32); }
        #drawing-screen .chosen-card-item img.reversed { transform: rotate(180deg); }
        #drawing-screen .chosen-card-item .card-name { margin-top: 0.5rem; font-weight: 700; color: #fff; font-size: 0.9rem; text-shadow: none; }
        #drawing-screen .chosen-card-item .card-orientation { font-size: 0.8rem; color: var(--gold-color, #F2C94C); text-shadow: none; }

        #drawing-screen #card-spread-container { display: flex; flex-direction: column; gap: 14px; width: 100%; max-width: 1160px; align-items: center; padding-left: 0; margin: 0 auto; perspective: 1000px; }
        #card-spread-container .card-fan-stage {
            position: relative;
            width: min(100%, 1160px);
            height: clamp(440px, 40vw, 520px);
            margin: -2.1rem auto 0;
            overflow: visible;
            border-radius: 0 0 18px 18px;
            transform: translateY(-4px);
        }
        #card-spread-container .card-fan-stage.spread-1 {
            height: clamp(300px, 30vw, 380px);
            margin-top: -5.8rem;
            margin-bottom: 3rem;
        }
        #card-spread-container .card-fan-stage.spread-3 { margin-top: -6.2rem; }
        #card-spread-container .card-fan-stage.spread-5 { margin-top: -2.1rem; }
        #card-spread-container .card-fan-stage::before {
            content: '';
            position: absolute;
            left: 50%;
            bottom: -84px;
            width: 76%;
            height: 120px;
            transform: translateX(-50%);
            border-radius: 50%;
            background: radial-gradient(ellipse, rgba(0,0,0,0.44), transparent 68%);
            filter: blur(12px);
            pointer-events: none;
        }
        #card-spread-container .card-row { display: flex; justify-content: center; width: 100%; }
        #card-spread-container .facedown-card {
            width: 132px; height: 224.4px; background-image: url('/card-back.jpg'); background-size: cover;
            border-radius: 8px; margin-left: -40px; cursor: pointer;
            border: 1px solid rgba(255,255,255,0.18);
            transition: transform 0.28s ease, filter 0.28s ease, box-shadow 0.28s ease, opacity 0.28s ease;
            box-shadow: -5px 5px 10px rgba(0,0,0,0.28), 0 0 0 rgba(242,201,76,0);
            transform: translateY(0) rotate(var(--card-tilt, 0deg));
            will-change: transform, filter;
        }
        #card-spread-container .fan-card {
            position: absolute;
            left: 50%;
            bottom: var(--fan-bottom);
            margin-left: 0;
            opacity: 0;
            width: 132px;
            height: 224.4px;
            aspect-ratio: auto;
            flex-shrink: 0;
            transform-origin: 50% var(--fan-origin);
            transform: translateX(-50%) rotate(var(--fan-angle));
            z-index: var(--fan-z);
            transition: transform 0.16s ease, filter 0.16s ease, box-shadow 0.16s ease, opacity 0.2s ease;
        }
        #card-spread-container .fan-card.is-dealt {
            opacity: 1;
            transform: translateX(-50%) rotate(var(--fan-angle));
        }
        #card-spread-container .facedown-card:hover {
            transform: translateY(-18px) scale(1.09) rotate(var(--card-tilt, 0deg));
            z-index: 10;
            filter: brightness(1.15) saturate(1.08);
            box-shadow: -6px 12px 18px rgba(0,0,0,0.35), 0 0 24px rgba(242,201,76,0.28);
        }
        #card-spread-container .facedown-card.fan-card:hover {
            z-index: 9999;
            transform: translateX(-50%) rotate(var(--fan-angle)) translateY(-6px) scale(1.025);
        }
        #card-spread-container .card-fan-stage.hover-paused .facedown-card.fan-card:hover {
            z-index: var(--fan-z);
            transform: translateX(-50%) rotate(var(--fan-angle));
            filter: none;
            box-shadow: -5px 5px 10px rgba(0,0,0,0.28), 0 0 0 rgba(242,201,76,0);
        }
        #card-spread-container .facedown-card.is-chosen { opacity: 0; pointer-events: none; transform: translateY(-22px) scale(.9); }
        #card-spread-container .facedown-card.fan-card.is-chosen { opacity: 0; pointer-events: none; transform: translateX(-50%) rotate(var(--fan-angle)) translateY(-34px) scale(.92); }
        .mobile-row { display: none; }
        @media (max-width: 768px) {
            #drawing-screen {
                min-height: auto;
                padding-bottom: 3rem;
                overflow-x: visible;
            }
            .mobile-row { display: flex; }
            #drawing-screen #chosen-cards-display,
            #chosen-cards-display.spread-1,
            #chosen-cards-display.spread-3 {
                gap: 0.18rem;
                min-height: 148px;
                margin-bottom: 1.35rem;
            }
            #drawing-screen .chosen-card-placeholder,
            #drawing-screen .chosen-card-item {
                width: 84px;
            }
            #drawing-screen .chosen-card-placeholder {
                height: calc(84px * 619 / 372);
                font-size: 0.95rem;
            }
            #drawing-screen #card-spread-container {
                width: 100%;
                max-width: calc(100vw - 20px);
                gap: 10px;
                perspective: none;
                margin-top: 0;
                margin-bottom: 2rem;
                overflow-x: visible;
            }
            #card-spread-container .card-row {
                display: flex;
                justify-content: center;
                width: 100%;
                padding-left: 0;
            }
            #card-spread-container .mobile-card-row {
                --mobile-card-w: clamp(42px, 11.6vw, 52px);
                max-width: min(calc(100vw - 28px), calc(var(--mobile-card-w) * 8.2));
                padding-inline: 6px;
                box-sizing: content-box;
                margin: 0 auto;
            }
            #card-spread-container .mobile-card-row .facedown-card {
                width: var(--mobile-card-w);
                aspect-ratio: 372 / 619;
                height: auto;
                margin-left: 0;
                border-radius: 3px;
                opacity: 0;
            }
            #card-spread-container .mobile-card-row .facedown-card + .facedown-card {
                margin-left: calc(var(--mobile-card-w) * -0.62);
            }
            #card-spread-container .mobile-card-row .facedown-card .mobile-card-back-img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: inherit;
                pointer-events: none;
                display: block;
            }
            #card-spread-container .mobile-card-row .facedown-card.is-dealt {
                opacity: 1;
                transform: translateY(0) scale(1) rotate(var(--card-tilt, 0deg));
                -webkit-transform: translateY(0) scale(1) rotate(var(--card-tilt, 0deg));
            }
            #card-spread-container .card-fan-stage {
                width: min(112vw, 680px);
                height: 360px;
                margin-top: -1rem;
            }
            #card-spread-container .card-fan-stage.spread-1,
            #card-spread-container .card-fan-stage.spread-3 { margin-top: -3.2rem; }
            #card-spread-container .card-fan-stage.spread-5 { margin-top: -1rem; }
            #card-spread-container .fan-card {
                width: 78px;
                height: 117px;
                margin-left: 0;
                bottom: calc(var(--fan-bottom) + 18px);
                transform-origin: 50% calc(var(--fan-origin) - 430px);
            }
            #card-spread-container .facedown-card.fan-card:hover {
                transform: translateX(-50%) rotate(var(--fan-angle)) translateY(-4px) scale(1.02);
            }
        }

        @media (min-width: 769px) and (max-width: 1180px), (pointer: coarse) and (min-width: 769px) and (max-width: 1366px) {
            #drawing-screen #chosen-cards-display,
            #chosen-cards-display.spread-1,
            #chosen-cards-display.spread-3 {
                margin-bottom: 2.6rem;
            }
            #drawing-screen #card-spread-container {
                width: 100%;
                max-width: calc(100vw - 40px);
                gap: 18px;
                margin-top: 0.8rem;
                margin-bottom: 2.4rem;
                overflow-x: visible;
                perspective: none;
            }
            #card-spread-container .card-row {
                display: flex;
                justify-content: center;
                width: 100%;
                padding-left: 0;
            }
            #card-spread-container .mobile-card-row.tablet-card-row {
                --mobile-card-w: clamp(52px, 5.7vw, 78px);
                max-width: min(calc(100vw - 48px), calc(var(--mobile-card-w) * 14.4));
                padding-inline: 12px;
                box-sizing: content-box;
                margin: 0 auto;
            }
            #card-spread-container .mobile-card-row.tablet-card-row .facedown-card {
                width: var(--mobile-card-w);
                aspect-ratio: 372 / 619;
                height: auto;
                margin-left: 0;
                border-radius: 5px;
                opacity: 0;
                position: relative;
                overflow: hidden;
                flex-shrink: 0;
                background-color: rgba(19, 32, 64, 0.92);
                background-image: url('/card-back.jpg');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                -webkit-backface-visibility: hidden;
                backface-visibility: hidden;
            }
            #card-spread-container .mobile-card-row.tablet-card-row .facedown-card + .facedown-card {
                margin-left: calc(var(--mobile-card-w) * -0.64);
            }
        }

        @media (max-width: 768px) and (orientation: landscape) {
            #drawing-screen #chosen-cards-display,
            #chosen-cards-display.spread-1,
            #chosen-cards-display.spread-3 {
                margin-bottom: 2.4rem;
            }
            #drawing-screen #card-spread-container {
                margin-top: 0.8rem;
                gap: 14px;
                max-width: calc(100vw - 36px);
            }
            #card-spread-container .mobile-card-row {
                --mobile-card-w: clamp(38px, 6.8vw, 50px);
                max-width: min(calc(100vw - 44px), calc(var(--mobile-card-w) * 8.4));
            }
            #card-spread-container .mobile-card-row .facedown-card + .facedown-card {
                margin-left: calc(var(--mobile-card-w) * -0.62);
            }
        }

        .action-button {
            display: none;
            opacity: 0; transform: scale(0.9);
            background: linear-gradient(135deg, #D4AF37 0%, #F2C94C 50%, #FFD700 100%);
            color: #050A1F; border: none; padding: 1rem 3rem;
            border-radius: 50px;
            font-size: 1.1rem; font-weight: 700; box-shadow: 0 0 20px rgba(242, 201, 76, 0.4);
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .action-button.visible { display: inline-block; opacity: 1; transform: scale(1); }
        .action-button:hover { transform: scale(1.05) translateY(-3px); box-shadow: 0 0 30px rgba(242, 201, 76, 0.8); }

        /* === INTERPRETATION RESULT === */
        #interpretation-results-display {
            display: none;
            width: 100%; max-width: 800px; margin: 2rem auto;
            background: rgba(11, 19, 43, 0.8); border: 1px solid rgba(242, 201, 76, 0.3);
            border-radius: 16px; padding: 2.5rem; backdrop-filter: blur(10px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3); text-align: left;
        }
        #interpretation-results-display h1, #interpretation-results-display h2, #interpretation-results-display h3 {
            font-family: var(--font-title);
            color: var(--gold-color, #F2C94C);
            margin-top: 1.5rem; margin-bottom: 1rem; text-shadow: none;
        }
        #interpretation-results-display p, #interpretation-results-display li {
            color: #e0e0e0; line-height: 1.8; font-size: 1.05rem; text-shadow: none;
        }
        #interpretation-results-display strong { color: #fff; }

        /* --- LOADER HÀNH TINH 3D --- */
        .interpretation-loader {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 1.5rem 1rem; perspective: 800px; overflow: hidden;
        }
        .loader-planet-system {
            position: relative; width: 200px; height: 200px; display: flex;
            align-items: center; justify-content: center; transform-style: preserve-3d;
            animation: system-wobble 15s infinite ease-in-out;
        }
        .loader-planet-sphere {
            width: 100px; height: 100px; border-radius: 50%;
            background-image: url('/planet.png'); background-size: cover; background-position: center;
            position: absolute; animation: planet-glow 2.5s infinite ease-in-out;
        }
        .loader-orbit {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            border-radius: 50%; transform-style: preserve-3d;
            animation-iteration-count: infinite; animation-timing-function: linear;
        }
        .orbit-1 { animation: orbit-spin-1 3s linear infinite; }
        .orbit-2 { animation: orbit-spin-2 5s linear infinite; }
        .orbit-3 { animation: orbit-spin-3 7s linear infinite; }
        .orbit-4 { animation: orbit-spin-4 10s linear infinite; }
        .orbit-5 { animation: orbit-spin-5 14s linear infinite; }
        .orbit-1::before, .orbit-2::before, .orbit-3::before, .orbit-4::before, .orbit-5::before {
            content: ''; position: absolute; border-radius: 50%; top: 50%; left: 0;
            transform: translate(-50%, -50%); filter: blur(3px);
        }
        .orbit-1::before { width: 10px; height: 10px; background: #fff; box-shadow: 0 0 15px #fff; }
        .orbit-2::before { width: 7px; height: 7px; background: #ffc; box-shadow: 0 0 15px #ffc; }
        .orbit-3::before { width: 5px; height: 5px; background: #fcc; box-shadow: 0 0 15px #fcc; }
        .orbit-4::before { width: 6px; height: 6px; background: #0ff; box-shadow: 0 0 15px #0ff; }
        .orbit-5::before { width: 8px; height: 8px; background: #f0f; box-shadow: 0 0 15px #f0f; }
        .loader-text {
            margin-top: 1.5rem; font-size: 1.1rem; font-weight: 600;
            color: var(--gold-color, #F2C94C); text-shadow: 0 0 10px rgba(242, 201, 76, 0.3);
            animation: text-fade 2s infinite ease-in-out;
        }

        .loader-note {
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #a0aec0; /* Màu xám sáng nhẹ */
            max-width: 90%;
            text-align: center;
            line-height: 1.6;
            opacity: 0; /* Ẩn ban đầu */
            animation: fadeIn 1s ease-in-out 1.5s forwards; /* Hiện lên sau 1.5s để đỡ rối mắt */
        }
        .loader-note strong {
            color: var(--gold-color, #F2C94C);
            font-weight: 700;

        }
        @keyframes system-wobble { 0%, 100% { transform: rotateY(-10deg) rotateX(5deg); } 50% { transform: rotateY(10deg) rotateX(-5deg); } }
