    <script>
/* ============================================= */
/* === TAROT.JS (Logic cho trang 1/3 lá) === */
/* ============================================= */

const N8N_WEBHOOK_URL = '/api/yesno-interpret';
const N8N_VALIDATE_URL = '/api/yesno-validate';

// DOM Elements
