---
interface PreviewItem {
  title?: string;
  text?: string;
  data?: any;
}

interface Props {
  items?: PreviewItem[];
  maxItems?: number;
  maxChars?: number;
  ctaLabel?: string;
}

const {
  items = [],
  maxItems = 2,
  maxChars = 260,
  ctaLabel = 'Mở khóa để xem toàn bộ'
} = Astro.props;

const decodeEntities = (value: string) => value
  .replace(/&nbsp;/g, ' ')
  .replace(/&amp;/g, '&')
  .replace(/&lt;/g, '<')
  .replace(/&gt;/g, '>')
  .replace(/&quot;/g, '"')
  .replace(/&#39;/g, "'");

const stripHtml = (value: string) => decodeEntities(value)
  .replace(/<script[\s\S]*?<\/script>/gi, ' ')
  .replace(/<style[\s\S]*?<\/style>/gi, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const resolveValue = async (value: any) => {
  const resolved = await Promise.resolve(value);
  return resolved == null ? '' : String(resolved);
};

const textFromBlocks = async (blocks: any[] = []) => {
  const parts = await Promise.all(
    blocks.map(async (block) => {
      if (Array.isArray(block.items)) {
        const items = await Promise.all(block.items.map(resolveValue));
        return items.join(' ');
      }
      return resolveValue(block.content);
    })
  );

  return parts.join(' ');
};

const getItemText = async (item: PreviewItem) => {
  const data = item.data || {};
  const blockText = data.blocks ? await textFromBlocks(data.blocks) : '';
  const raw = await resolveValue(item.text || blockText || data.content || '');
  return stripHtml(raw);
};

const truncate = (value: string, limit: number) => {
  if (value.length <= limit) return value;
  const sliced = value.slice(0, limit);
  const lastSpace = sliced.lastIndexOf(' ');
  return `${sliced.slice(0, lastSpace > 120 ? lastSpace : limit).trim()}...`;
};

const previews = (await Promise.all(items.map(async (item) => ({
    title: item.title || item.data?.title || '',
    text: truncate(await getItemText(item), maxChars)
  }))))
  .filter((item) => item.text.length > 0)
  .slice(0, maxItems);
---

<div class="locked-preview">
  {previews.length > 0 ? (
    <div class="locked-preview__fade">
      {previews.map((item) => (
        <div class="locked-preview__item">
          {item.title && <h5>{item.title}</h5>}
          <p>{item.text}</p>
        </div>
      ))}
    </div>
  ) : (
    <div class="locked-preview__empty">
      <i class="fas fa-eye-slash"></i>
      <span>Nội dung Premium đang bị khóa</span>
    </div>
  )}

  <div class="locked-preview__gate">
    <button class="btn-open-unlock-modal" type="button">
      <i class="fas fa-unlock"></i> {ctaLabel}
    </button>
  </div>
</div>

<style>
  .locked-preview {
    position: relative;
    overflow: hidden;
    margin-top: 1.5rem;
    padding: 1.25rem 1.25rem 1.5rem;
    border: 1px dashed rgba(242, 201, 76, 0.45);
    border-radius: 1rem;
    background: rgba(0, 0, 0, 0.35);
    cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s ease;
  }

  .locked-preview:hover {
    border-color: rgba(242, 201, 76, 0.85);
    background: rgba(0, 0, 0, 0.5);
    transform: translateY(-2px);
  }

  .locked-preview__fade {
    max-height: 168px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 38%, rgba(0, 0, 0, 0.58) 62%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 38%, rgba(0, 0, 0, 0.58) 62%, transparent 100%);
  }

  .locked-preview__item {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .locked-preview__item:last-child {
    margin-bottom: 0;
  }

  .locked-preview__item h5 {
    margin: 0 0 0.45rem;
    color: #f2c94c;
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .locked-preview__item p {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 0.92rem;
    line-height: 1.75;
    text-align: justify;
  }

  .locked-preview__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 1rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 1.05rem;
  }

  .locked-preview__empty i {
    color: rgba(242, 201, 76, 0.75);
    font-size: 2rem;
  }

  .locked-preview__gate {
    display: flex;
    justify-content: center;
    padding-top: 1.1rem;
    margin-top: -0.15rem;
  }

  .btn-open-unlock-modal {
    background: rgba(242, 201, 76, 0.16);
    border: 1px solid rgba(242, 201, 76, 0.62);
    color: #f2c94c;
    padding: 0.72rem 1.5rem;
    border-radius: 9999px;
    cursor: pointer;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.25s ease;
  }

  .locked-preview:hover .btn-open-unlock-modal {
    background: #f2c94c;
    color: #000;
    box-shadow: 0 0 20px rgba(242, 201, 76, 0.38);
  }
</style>

<script>
  document.querySelectorAll('.locked-preview').forEach((el) => {
    if ((el as HTMLElement).dataset.unlockBound === 'true') return;
    (el as HTMLElement).dataset.unlockBound = 'true';

    el.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'feature_usage',
        feature_name: 'numerology_result',
        action: 'click_unlock_btn'
      });

      const modal = document.getElementById('unlock-modal');
      if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });
</script>
